-- ========== CONFIG SYSTEM ==========
function Library:GetConfigList()
    local configs = {}
    if not file.exists(self.ConfigFolder) then
        self.ConfigList = configs
        return configs
    end
    local files = file.list_folder(self.ConfigFolder)
    if files then
        for _, name in ipairs(files) do
            if type(name) == "string" then
                local cn = name:match("^(.+)%.json$")
                if cn then table.insert(configs, cn) end
            end
        end
    end
    table.sort(configs)
    self.ConfigList = configs
    return configs
end

function Library:UpdateManifest()  self.ConfigList = self:GetConfigList() end
function Library:RemoveFromManifest() self.ConfigList = self:GetConfigList() end

function Library:SaveConfig(name)
    if not file.exists(self.ConfigFolder) then file.write(self.ConfigFolder .. ".keep", "") end
    local config = {
        toggles = {}, options = {},
        version = 2, saved_at = tonumber(get_unixtime()) or 0, game = get_placeid(),
    }
    for id, toggle in pairs(self.Toggles) do
        config.toggles[id] = toggle.Value
    end
    for id, opt in pairs(self.Options) do
        if opt.Type == "Slider" then
            config.options[id] = { type = "Slider", value = opt.Value }
        elseif opt.Type == "Dropdown" then
            config.options[id] = { type = "Dropdown", value = opt.Value, multi = opt.Multi or false }
        elseif opt.Type == "Input" then
            config.options[id] = { type = "Input", value = opt.Value }
        elseif opt.Type == "KeyPicker" then
            config.options[id] = { type = "KeyPicker", value = opt.Value, mode = opt.Mode or "Hold" }
        elseif opt.Type == "ColorPicker" then
            local c = opt.Value
            config.options[id] = { type = "ColorPicker", value = { r=c.r, g=c.g, b=c.b, a=c.a } }
        end
    end
    config.windows = {}
    for i, win in ipairs(self.Windows) do
        config.windows[i] = { pos = { x = win.Pos.x, y = win.Pos.y } }
    end
    config.watermark = { x = self.Watermark.Pos.x, y = self.Watermark.Pos.y }
    file.write(self.ConfigFolder .. name .. ".json", self:TableToJSON(config))
    self.CurrentConfig = name
    self:Notify("Config saved: " .. name, 3)
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue(name)
    end
    return true
end

function Library:LoadConfig(name)
    local filename = self.ConfigFolder .. name .. ".json"
    if not file.exists(filename) then self:Notify("Config not found: " .. name, 3); return false end
    local raw = file.read(filename)
    if not raw or raw == "" then self:Notify("Config empty: " .. name, 3); return false end
    local config = self:JSONToTable(raw)
    if not config then self:Notify("Failed to parse config: " .. name, 3); return false end
    for id, value in pairs(config.toggles or {}) do
        if self.Toggles[id] then self.Toggles[id]:SetValue(value) end
    end
    for id, data in pairs(config.options or {}) do
        local opt = self.Options[id]
        if opt then
            if data.type == "Slider" then opt:SetValue(data.value)
            elseif data.type == "Dropdown" then opt:SetValue(data.value)
            elseif data.type == "Input" then opt:SetValue(data.value)
            elseif data.type == "KeyPicker" then
                opt:SetValue(data.value)
                if data.mode then opt.Mode = data.mode end
            elseif data.type == "ColorPicker" then
                local c = data.value
                opt:SetValue(color(c.r, c.g, c.b, c.a))
            end
        end
    end
    for i, wd in ipairs(config.windows or {}) do
        if self.Windows[i] then
            self.Windows[i].Pos = vector2(wd.pos.x, wd.pos.y)
        end
    end
    if config.watermark then
        self.Watermark.Pos = vector2(config.watermark.x, config.watermark.y)
    end
    self.ConfigLoaded = true
    self.CurrentConfig = name
    self:Notify("Config loaded: " .. name, 3)
    if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
    return true
end

function Library:DeleteConfig(name)
    local filename = self.ConfigFolder .. name .. ".json"
    if not file.exists(filename) then return false end
    if file.delete_file then
        file.delete_file(filename)
    else
        file.write(filename, "")
    end
    self:Notify("Config deleted: " .. name, 3)
    if self.CurrentConfig == name then self.CurrentConfig = "" end
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue("")
    end
    return true
end

function Library:ResetAll()
    for _, toggle in pairs(self.Toggles) do toggle:SetValue(false) end
    for _, opt in pairs(self.Options) do
        if opt.Type == "Slider" then opt:SetValue((opt.Min + opt.Max) / 2)
        elseif opt.Type == "Dropdown" and not opt.Multi then opt:SetValue(opt.Values[1])
        elseif opt.Type == "Input" then opt:SetValue("")
        elseif opt.Type == "KeyPicker" then opt:SetValue("...")
        elseif opt.Type == "ColorPicker" then opt:SetValue(self.AccentColor) end
    end
    self.CurrentConfig = ""
    if self.ConfigDropdown then self.ConfigDropdown:SetValue("") end
    self:Notify("All settings reset!", 3)
end

function Library:TableToJSON(tbl)
    local function ser(val)
        local t = type(val)
        if t == "string" then return '"' .. val:gsub('\\', '\\\\'):gsub('"', '\\"') .. '"'
        elseif t == "number" then return tostring(val)
        elseif t == "boolean" then return val and "true" or "false"
        elseif t == "table" then
            local max_i, is_arr = 0, true
            for k in pairs(val) do
                if type(k) ~= "number" or k ~= math.floor(k) or k <= 0 then is_arr = false; break end
                if k > max_i then max_i = k end
            end
            local items = {}
            if is_arr and max_i > 0 then
                for i = 1, max_i do items[i] = ser(val[i]) end
                return "[" .. table.concat(items, ",") .. "]"
            else
                for k, v in pairs(val) do
                    table.insert(items, ser(tostring(k)) .. ":" .. ser(v))
                end
                return "{" .. table.concat(items, ",") .. "}"
            end
        end
        return "null"
    end
    return ser(tbl)
end

function Library:JSONToTable(str)
    local fn, err = load("return " .. str, "json_parse", "t")
    if fn then
        local ok, result = pcall(fn)
        if ok then return result end
    end
    return nil
end

function Library:CreateConfigSection(groupbox)
    local configs = self:GetConfigList()
    local dropdown = groupbox:AddDropdown("config_dropdown", {
        Text = "Load Config", Default = 1, Values = configs, Tooltip = "Select a config to load",
    })
    self.ConfigDropdown = dropdown
    groupbox:AddButton({ Text = "Save As New Config", Tooltip = "Save current settings as a new config",
        Func = function() self:Notify("Type config name in console", 3); print("Enter config name:") end })
    groupbox:AddButton({ Text = "Overwrite Current", Tooltip = "Save over the currently loaded config",
        Func = function()
            if self.CurrentConfig ~= "" then self:SaveConfig(self.CurrentConfig)
            else self:Notify("No config loaded to overwrite", 3) end
        end })
    groupbox:AddDivider()
    groupbox:AddButton({ Text = "Delete Selected", DoubleClick = true, Tooltip = "Double click to delete selected config",
        Func = function()
            local cur = dropdown.Value
            if cur and cur ~= "" then self:DeleteConfig(cur)
            else self:Notify("No config selected", 3) end
        end })
    groupbox:AddButton({ Text = "Reset to Defaults", DoubleClick = true, Tooltip = "Double click to reset all settings",
        Func = function() self:ResetAll() end })
    groupbox:AddButton({ Text = "Refresh Config List", Tooltip = "Refresh the config dropdown list",
        Func = function()
            dropdown:SetValues(self:GetConfigList()); self:Notify("Config list refreshed", 2)
        end })
    dropdown:OnChanged(function(value)
        if value and value ~= "" then self:LoadConfig(value) end
    end)
    return dropdown
end

