local function render_tooltip(alpha)
    if not Library.Tooltip or not Library.Tooltip.Text or alpha < 0.01 then return end
    local mp  = input.get_mouse_position()
    local ts  = render.get_text_size(Library.Tooltip.Text)
    local tsz = vector2(ts.x+12, ts.y+8)
    local tp  = mp:add(vector2(13,13))
    draw_shadow(tp, tsz, 5, alpha)
    render.add_rect_filled(tp, tp:add(tsz), apply_alpha(Library.MainColor, alpha), 5)
    -- accent pip on tooltip left edge
    render.add_rect_filled(tp, tp:add(vector2(2, tsz.y)), apply_alpha(Library.AccentColor, alpha), 2)
    render.add_text(tp:add(vector2(7,4)), Library.Tooltip.Text, apply_alpha(Library.FontColor, alpha))
end

