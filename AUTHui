                        draw_shadow(group_pos, group_size, 8, wa * 0.5)
                        render.add_rect_filled(group_pos, group_pos:add(group_size), apply_alpha(Library.MainColor, wa), 8)
                        render.add_rect(group_pos, group_pos:add(group_size), apply_alpha(Library.OutlineColor, wa), 8, 1)
                        render.add_text(group_pos:add(vector2(10, 8)), groupbox.Name, apply_alpha(dynamic_accent, wa))
                        
                        local element_y = 30
                        for _, element in ipairs(groupbox.Elements) do
                            local ep = group_pos:add(vector2(10, element_y))
                            local efw = vector2(group_size.x - 20, element.Height)
                            
                            if element.Type == "Toggle" then
                                local target_x = element.Value and 1 or 0
                                element.SwitchAnim = element.SwitchAnim + (target_x - element.SwitchAnim) * 0.07
                                local sw_size = vector2(30, 17)
                                local sw_pos = ep:add(vector2(0, 5))
                                local base_bg = color(0.12, 0.12, 0.16, 1)
                                -- Use accent color for toggle when active
                                local fill_bg = color(
                                    base_bg.r + (dynamic_accent.r - base_bg.r) * element.SwitchAnim,
                                    base_bg.g + (dynamic_accent.g - base_bg.g) * element.SwitchAnim,
                                    base_bg.b + (dynamic_accent.b - base_bg.b) * element.SwitchAnim, 1)
                                render.add_rect_filled(sw_pos, sw_pos:add(sw_size), apply_alpha(fill_bg, wa), 9)
                                render.add_rect(sw_pos, sw_pos:add(sw_size), apply_alpha(Library.OutlineColor, wa), 9, 1)
                                local knob_x = sw_pos.x + 2 + (sw_size.x - 15) * element.SwitchAnim
                                render.add_rect_filled(vector2(knob_x, sw_pos.y + 2), vector2(knob_x + 11, sw_pos.y + 15), apply_alpha(color(1, 1, 1, 1), wa), 6)
                                -- Text color uses accent when active, otherwise white
                                local text_color = element.Risky and Library.RiskColor or (element.Value and dynamic_accent or Library.FontColor)
                                render.add_text(ep:add(vector2(38, 4)), element.Text, apply_alpha(text_color, wa))
                                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(ep, vector2(170, 20)) then
                                    element:SetValue(not element.Value)
                                end
                                
                            elseif element.Type == "Slider" then
                                local ratio = (element.Value - element.Min) / (element.Max - element.Min)
                                element.ThumbAnim = element.ThumbAnim + (ratio - element.ThumbAnim) * 0.08
                                local s_pos = ep:add(vector2(0, 22))
                                local s_size = vector2(group_size.x - 20, 14)
                                local thumb_x = s_pos.x + s_size.x * element.ThumbAnim
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                                -- Value text uses accent color
                                render.add_text(ep:add(vector2(group_size.x - 20 - 40, 0)), tostring(element.Value) .. element.Suffix, apply_alpha(dynamic_accent, wa))
                                render.add_rect_filled(s_pos, s_pos:add(s_size), apply_alpha(Library.BackgroundColor, wa), 7)
                                render.add_rect(s_pos, s_pos:add(s_size), apply_alpha(Library.OutlineColor, wa), 7, 1)
                                if element.ThumbAnim > 0.001 then
                                    local fill_w = math.max(0, s_size.x * element.ThumbAnim - 2)
                                    render.add_rect_filled(s_pos:add(vector2(2, 2)), s_pos:add(vector2(2 + fill_w, s_size.y - 2)), apply_alpha(dynamic_accent, wa), 5)
                                end
                                render.add_rect_filled(vector2(thumb_x - 4, s_pos.y - 2), vector2(thumb_x + 4, s_pos.y + s_size.y + 2), apply_alpha(Library.FontColor, wa), 4)
                                if is_mouse_in_rect(s_pos, s_size) and mdown then
                                    local r = (math.clamp(mp.x, s_pos.x, s_pos.x + s_size.x) - s_pos.x) / s_size.x
                                    local v = element.Min + (element.Max - element.Min) * r
                                    if element.Value ~= v then element:SetValue(v) end
                                end
                                
                            elseif element.Type == "Button" then
                                local b_pos = ep
                                local b_size = vector2(group_size.x - 20, 24)
                                local is_hover = is_mouse_in_rect(b_pos, b_size)
                                element.HoverAnim = element.HoverAnim + ((is_hover and 1 or 0) - element.HoverAnim) * 0.07
                                local ha = element.HoverAnim
                                -- Button uses accent color on hover
                                local bg = color(
                                    dynamic_accent.r + (Library.FontColor.r - dynamic_accent.r) * (1 - ha),
                                    dynamic_accent.g + (Library.FontColor.g - dynamic_accent.g) * (1 - ha),
                                    dynamic_accent.b + (Library.FontColor.b - dynamic_accent.b) * (1 - ha), 1)
                                local fg = color(
                                    Library.FontColor.r + (dynamic_accent.r - Library.FontColor.r) * ha,
                                    Library.FontColor.g + (dynamic_accent.g - Library.FontColor.g) * ha,
                                    Library.FontColor.b + (dynamic_accent.b - Library.FontColor.b) * ha, 1)
                                render.add_rect_filled(b_pos, b_pos:add(b_size), apply_alpha(bg, wa), 6)
                                render.add_rect(b_pos, b_pos:add(b_size), apply_alpha(Library.OutlineColor, wa), 6, 1)
                                local text_color = is_hover and fg or dynamic_accent
                                render.add_text(b_pos:add(vector2(b_size.x / 2 - render.get_text_size(element.Text).x / 2, 4)), element.Text, apply_alpha(text_color, wa))
                                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(b_pos, b_size) then
                                    if element.DoubleClick then
                                        local now = get_unixtime()
                                        if now - (element.LastClick or 0) < 0.5 then
                                            if element.Func then element.Func() end
                                            element.LastClick = 0
                                        else
                                            element.LastClick = now
                                        end
                                    else
                                        if element.Func then element.Func() end
                                    end
                                end
                                
                            elseif element.Type == "Dropdown" then
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                                local d_pos = ep:add(vector2(0, 18))
                                local d_size = vector2(group_size.x - 20, 22)
                                local display_text = element.Multi and "Multiple" or tostring(element.Value)
                                render.add_rect_filled(d_pos, d_pos:add(d_size), apply_alpha(Library.BackgroundColor, wa), 6)
                                render.add_rect(d_pos, d_pos:add(d_size), apply_alpha(Library.OutlineColor, wa), 6, 1)
                                render.add_text(d_pos:add(vector2(8, 3)), get_clipped_text(display_text, d_size.x - 24), apply_alpha(dynamic_accent, wa))
                                -- Dropdown arrow uses accent
                                render.add_triangle_filled(d_pos:add(vector2(d_size.x - 13, 8)), d_pos:add(vector2(d_size.x - 5, 8)), d_pos:add(vector2(d_size.x - 9, 15)), apply_alpha(dynamic_accent, wa))
                                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(d_pos, d_size) then
                                    element.Open = not element.Open
                                end
                                
                            elseif element.Type == "Input" then
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                                local i_pos = ep:add(vector2(0, 18))
                                local i_size = vector2(group_size.x - 20, 22)
                                element.layout = { pos = i_pos, size = i_size }
                                local is_active = (Library.ActiveInput == element)
                                render.add_rect_filled(i_pos, i_pos:add(i_size), apply_alpha(Library.BackgroundColor, wa), 6)
                                render.add_rect(i_pos, i_pos:add(i_size), is_active and apply_alpha(dynamic_accent, wa) or apply_alpha(Library.OutlineColor, wa), 6, 1)
                                local d_text = (element.Value ~= "") and element.Value or element.Placeholder
                                render.add_text(i_pos:add(vector2(8, 3)), get_clipped_text(d_text, i_size.x - 14), apply_alpha(Library.FontColor, wa))
                                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(i_pos, i_size) then
                                    Library.ActiveInput = element
                                end
                                
                            elseif element.Type == "KeyPicker" then
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                                local k_pos = ep:add(vector2(0, 18))
                                local k_size = vector2(group_size.x - 20, 22)
                                render.add_rect_filled(k_pos, k_pos:add(k_size), apply_alpha(Library.BackgroundColor, wa), 6)
                                render.add_rect(k_pos, k_pos:add(k_size), element.Picking and apply_alpha(dynamic_accent, wa) or apply_alpha(Library.OutlineColor, wa), 6, 1)
                                local mode_tag = ""
                                if element.Mode == "Hold" then mode_tag = " [H]" elseif element.Mode == "Toggle" then mode_tag = " [T]" elseif element.Mode == "Always" then mode_tag = " [A]" end
                                local ktext = element.Picking and "press a key..." or (element.Value .. mode_tag)
                                render.add_text(k_pos:add(vector2(k_size.x / 2 - render.get_text_size(ktext).x / 2, 3)), ktext, apply_alpha(dynamic_accent, wa))
                                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(k_pos, k_size) then
                                    element.Picking = true
                                end
                                
                            elseif element.Type == "ColorPicker" then
                                local box_size = vector2(18, 14)
                                local box_pos = ep:add(vector2(group_size.x - 20 - box_size.x, 4))
                                render.add_text(ep:add(vector2(0, 3)), element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                                render.add_rect_filled(box_pos:add(vector2(1, 1)), box_pos:add(box_size):subtract(vector2(1, 1)), apply_alpha(element.Value, wa), 4)
                                render.add_rect(box_pos, box_pos:add(box_size), apply_alpha(Library.OutlineColor, wa), 4, 1)
                                
                            elseif element.Type == "Divider" then
                                local dy = ep.y + element.Height / 2
                                render.add_line(vector2(ep.x, dy), vector2(ep.x + group_size.x - 20, dy), apply_alpha(Library.OutlineColor, wa), 1)
                                
                            elseif element.Type == "Label" then
                                render.add_text(ep:add(vector2(0, 4)), element.Text, apply_alpha(Library.FontColor, wa))
                            end
                            
                            element_y = element_y + element.Height
                        end
                        
                        if groupbox.Side == "Left" then
                            left_y = left_y + group_size.y + 12
                        else
                            right_y = right_y + group_size.y + 12
                        end
                    end
                end
            end
        end
        ::continue_window::
    end
    
    -- Draw dropdown list
    if Library.OpenedDropdown then
        local e = Library.OpenedDropdown
        local list_pos = e.Layout.pos:add(vector2(0, e.Layout.size.y + 2))
        local list_h = math.min(#e.Values, 6) * 22 + 4
        local list_size = vector2(e.Layout.size.x, list_h)
        e.Layout.list_pos = list_pos
        e.Layout.list_size = list_size
        draw_shadow(list_pos, list_size, 6, 1)
        render.add_rect_filled(list_pos, list_pos:add(list_size), Library.MainColor, 6)
        render.add_rect(list_pos, list_pos:add(list_size), Library.OutlineColor, 6, 1)
        local item_y = 2
        for _, value in ipairs(e.Values) do
            local ip = list_pos:add(vector2(1, item_y))
            local isz = vector2(list_size.x - 2, 22)
            local is_sel = (e.Multi and e.Value[value]) or (e.Value == value)
            local tc = is_sel and dynamic_accent or Library.FontColor
            if is_mouse_in_rect(ip, isz) then
                render.add_rect_filled(ip, ip:add(isz), apply_alpha(dynamic_accent, 0.18), 4)
                tc = dynamic_accent
                if mpressed then
                    if e.Multi then
                        e.Value[value] = not e.Value[value]
                        e:SetValue(e.Value)
                    else
                        e:SetValue(value)
                        e.Open = false
                        Library.OpenedDropdown = nil
                    end
                end
            end
            render.add_text(ip:add(vector2(8, 3)), value, tc)
            item_y = item_y + 22
        end
    end
    
    -- Draw color picker
    if Library.ActiveColorPicker then
        local e = Library.ActiveColorPicker.obj
        local pad = 8
        local sv_dim = 135
        local bar_w = 12
        local bar_gap = 6
        local bars_x = pad + sv_dim + pad
        local num_bars = e.EnableAlpha and 2 or 1
        local p_w = bars_x + bar_w * num_bars + bar_gap * (num_bars - 1) + pad
        local p_h = pad + sv_dim + pad
        local p_size = vector2(p_w, p_h)
        
        local scr = get_screen_size()
        local p_pos = e.layout.pos:add(vector2(e.layout.size.x + 8, 0))
        if p_pos.x + p_w > scr.x - 4 then p_pos = vector2(e.layout.pos.x - p_w - 8, p_pos.y) end
        if p_pos.y + p_h > scr.y - 4 then p_pos = vector2(p_pos.x, scr.y - p_h - 4) end
        
        e.layout.picker_pos = p_pos
        e.layout.picker_size = p_size
        
        draw_shadow(p_pos, p_size, 8, 1)
        render.add_rect_filled(p_pos, p_pos:add(p_size), Library.MainColor, 8)
        render.add_rect(p_pos, p_pos:add(p_size), Library.OutlineColor, 8, 1)
        
        local sv_pos = p_pos:add(vector2(pad, pad))
        local sv_size = vector2(sv_dim, sv_dim)
        e.layout.sv_pos = sv_pos
        e.layout.sv_size = sv_size
        
        local function hsv_to_rgb_local(h, s, v)
            local i = math.floor(h * 6)
            local f = h * 6 - i
            local p = v * (1 - s)
            local q = v * (1 - f * s)
            local t = v * (1 - (1 - f) * s)
            i = i % 6
            if i == 0 then return v, t, p
            elseif i == 1 then return q, v, p
            elseif i == 2 then return p, v, t
            elseif i == 3 then return p, q, v
            elseif i == 4 then return t, p, v
            else return v, p, q end
        end
        
        local ahr_r, ahr_g, ahr_b = hsv_to_rgb_local(e.Hue, 1, 1)
        render.add_rect_filled(sv_pos, sv_pos:add(sv_size), color(1, 1, 1, 1), 0)
        for i = 0, sv_size.x - 1 do
            render.add_line(sv_pos:add(vector2(i, 0)), sv_pos:add(vector2(i, sv_size.y)), color(ahr_r, ahr_g, ahr_b, i / sv_size.x), 1)
        end
        for i = 0, sv_size.y - 1 do
            render.add_line(sv_pos:add(vector2(0, i)), sv_pos:add(vector2(sv_size.x, i)), color(0, 0, 0, i / sv_size.y), 1)
        end
        render.add_rect(sv_pos, sv_pos:add(sv_size), Library.OutlineColor, 0, 1)
        
        local cx = sv_pos.x + sv_size.x * e.Saturation
        local cy = sv_pos.y + sv_size.y * (1 - e.ValueHSV)
        render.add_circle(vector2(cx, cy), 5, e.ValueHSV > 0.5 and color(0, 0, 0, 1) or color(1, 1, 1, 1), 1)
        
        local hue_pos = p_pos:add(vector2(bars_x, pad))
        local hue_size = vector2(bar_w, sv_dim)
        e.layout.hue_pos = hue_pos
        e.layout.hue_size = hue_size
        for i = 0, hue_size.y - 1 do
            local r, g, b = hsv_to_rgb_local(i / hue_size.y, 1, 1)
            render.add_line(hue_pos:add(vector2(0, i)), hue_pos:add(vector2(hue_size.x, i)), color(r, g, b, 1), 1)
        end
        render.add_rect(hue_pos, hue_pos:add(hue_size), Library.OutlineColor, 0, 1)
        local hcy = hue_pos.y + hue_size.y * e.Hue
        render.add_rect(vector2(hue_pos.x - 2, hcy - 2), vector2(hue_pos.x + hue_size.x + 2, hcy + 2), color(1, 1, 1, 1), 2, 1)
        
        if e.EnableAlpha then
            local a_pos = p_pos:add(vector2(bars_x + bar_w + bar_gap, pad))
            local a_size = vector2(bar_w, sv_dim)
            e.layout.alpha_pos = a_pos
            e.layout.alpha_size = a_size
            local function draw_checkerboard(pos, size, sq)
                local c1 = color(0.2, 0.2, 0.2, 1)
                local c2 = color(0.1, 0.1, 0.1, 1)
                for y = 0, math.ceil(size.y / sq) - 1 do
                    for x = 0, math.ceil(size.x / sq) - 1 do
                        local p = pos:add(vector2(x * sq, y * sq))
                        local s = vector2(math.min(sq, size.x - x * sq), math.min(sq, size.y - y * sq))
                        render.add_rect_filled(p, p:add(s), (x + y) % 2 == 0 and c1 or c2, 0)
                    end
                end
            end
            draw_checkerboard(a_pos, a_size, 4)
            local rop_r, rop_g, rop_b = hsv_to_rgb_local(e.Hue, e.Saturation, e.ValueHSV)
            for i = 0, a_size.y - 1 do
                render.add_line(a_pos:add(vector2(0, i)), a_pos:add(vector2(a_size.x, i)), color(rop_r, rop_g, rop_b, i / a_size.y), 1)
            end
            render.add_rect(a_pos, a_pos:add(a_size), Library.OutlineColor, 0, 1)
            local acy = a_pos.y + a_size.y * e.Alpha
            render.add_rect(vector2(a_pos.x - 2, acy - 2), vector2(a_pos.x + a_size.x + 2, acy + 2), color(1, 1, 1, 1), 2, 1)
        end
    end
    
    -- Draw right-click menu
    if Library.RightClickMenu then
        local rcm = Library.RightClickMenu
        local options = {"Always", "Hold", "Toggle"}
        local item_h = 24
        local pad = 4
        local rcm_w = 110
        local rcm_h = #options * item_h + pad * 2
        local rcm_sz = vector2(rcm_w, rcm_h)
        local scr = get_screen_size()
        local rp = vector2(math.min(rcm.pos.x, scr.x - rcm_w - 4), math.min(rcm.pos.y, scr.y - rcm_h - 4))
        rcm.Alpha = rcm.Alpha + (1 - rcm.Alpha) * 0.12
        draw_shadow(rp, rcm_sz, 8, rcm.Alpha)
        render.add_rect_filled(rp, rp:add(rcm_sz), apply_alpha(Library.MainColor, rcm.Alpha), 7)
        for i, opt in ipairs(options) do
            local ip = rp:add(vector2(pad, pad + (i - 1) * item_h))
            local isz = vector2(rcm_w - pad * 2, item_h)
            local is_sel = (rcm.obj.Mode == opt) or (opt == "Always" and not rcm.obj.Mode)
            local is_hov = is_mouse_in_rect(ip, isz)
            if is_hov or is_sel then
                render.add_rect_filled(ip, ip:add(isz), apply_alpha(dynamic_accent, (is_sel and 0.25 or 0.12) * rcm.Alpha), 4)
            end
            local tc = (is_sel or is_hov) and apply_alpha(dynamic_accent, rcm.Alpha) or apply_alpha(Library.FontColor, rcm.Alpha * 0.7)
            render.add_text(ip:add(vector2(8, 4)), opt, tc)
            if is_sel then
                render.add_rect_filled(ip:add(vector2(rcm_w - pad * 2 - 8, item_h / 2 - 2)), ip:add(vector2(rcm_w - pad * 2 - 4, item_h / 2 + 2)), apply_alpha(dynamic_accent, rcm.Alpha), 2)
            end
            if mpressed and is_hov then
                rcm.obj.Mode = (opt == "Always") and nil or opt
                Library.RightClickMenu = nil
            end
        end
    end
    
    -- Draw notifications
    local scr_w = get_screen_size().x
    local notif_y = 50
    for i = #Library.Notifications, 1, -1 do
        local n = Library.Notifications[i]
        local t = get_unixtime() - n.StartTime
        if t > n.Duration then
            n.TargetAlpha = 0
            n.TargetOffsetX = 30
        end
        n.Alpha = n.Alpha + (n.TargetAlpha - n.Alpha) * 0.07
        n.OffsetX = n.OffsetX + (n.TargetOffsetX - n.OffsetX) * 0.07
        if n.TargetAlpha == 0 and n.Alpha < 0.01 then
            table.remove(Library.Notifications, i)
        else
            local nsz = vector2(render.get_text_size(n.Text).x + 20, 26)
            local np = vector2(scr_w - 290 + n.OffsetX, notif_y)
            draw_shadow(np, nsz, 6, n.Alpha)
            render.add_rect_filled(np, np:add(nsz), color(Library.MainColor.r, Library.MainColor.g, Library.MainColor.b, n.Alpha), 6)
            render.add_rect(np, np:add(nsz), color(Library.OutlineColor.r, Library.OutlineColor.g, Library.OutlineColor.b, n.Alpha), 6, 1)
            render.add_rect_filled(np:add(vector2(0, 3)), np:add(vector2(2, nsz.y - 3)), color(dynamic_accent.r, dynamic_accent.g, dynamic_accent.b, n.Alpha), 2)
            render.add_text(np:add(vector2(10, 5)), n.Text, color(Library.FontColor.r, Library.FontColor.g, Library.FontColor.b, n.Alpha))
            notif_y = notif_y + nsz.y + 5
        end
    end
    
    -- Draw tooltip
    if Library.Tooltip and Library.Tooltip.Text then
        local mp = input.get_mouse_position()
        local ts = render.get_text_size(Library.Tooltip.Text)
        local tsz = vector2(ts.x + 14, ts.y + 10)
        local tp = mp:add(vector2(14, 14))
        draw_shadow(tp, tsz, 6, 1)
        render.add_rect_filled(tp, tp:add(tsz), Library.MainColor, 6)
        render.add_rect(tp, tp:add(tsz), Library.OutlineColor, 6, 1)
        render.add_text(tp:add(vector2(7, 5)), Library.Tooltip.Text, dynamic_accent)
    end
end)

