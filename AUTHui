local function glass_panel(pos, size, radius, alpha, window)
    if not pos or not size then return end
    
    local a = alpha or 1
    if not window then window = { Glasscolor = color(0.55, 0.60, 0.90, 1), Glasstp = 0.1, Blur = 0.06 } end
    
    local glass_color = window.Glasscolor or color(0.55, 0.60, 0.90, 1)
    local blur_intensity = window.Blur or 0.06
    local tp = window.Glasstp or 0.1
    
    render.add_rect_filled(pos, pos:add(size), color(0.05, 0.05, 0.10, (0.82 * tp) * a), radius)
    render.add_rect_filled(pos, pos:add(vector2(size.x, math.min(size.y, 24))), color(1, 1, 1, 0.04 * a), radius)
    render.add_rect_filled(pos, pos:add(size), color(glass_color.r, glass_color.g, glass_color.b, blur_intensity * a), radius)
    render.add_rect(pos, pos:add(size), color(1, 1, 1, 0.10 * a), radius, 1)
    render.add_rect(pos:add(vector2(1, 1)), pos:add(size):add(vector2(-1, -1)), color(0.4, 0.45, 0.80, 0.18 * a), radius - 1, 1)
end

-- ========== CONFIG SYSTEM ==========
function Library:GetConfigList()
    local configs = {}
    if not file.exists(self.ConfigFolder) then return configs end
    local files = file.list_folder(self.ConfigFolder)
    if files then
        for _, name in ipairs(files) do
            local config_name = name:match("^(.+)%.json$")
            if config_name then
                table.insert(configs, config_name)
            end
        end
    end
    table.sort(configs)
    self.ConfigList = configs
    return configs
end

function Library:UpdateManifest(config_name) self.ConfigList = self:GetConfigList(); return self.ConfigList end
function Library:RemoveFromManifest(config_name) self.ConfigList = self:GetConfigList(); return self.ConfigList end

function Library:SaveConfig(name)
    if not file.exists(self.ConfigFolder) then file.write(self.ConfigFolder .. ".keep", "") end
    local config = { toggles = {}, options = {}, version = 2, saved_at = get_unixtime(), game = get_placeid() }
    for id, toggle in pairs(self.Toggles) do config.toggles[id] = toggle.Value end
    for id, opt in pairs(self.Options) do
        if opt.Type == "Slider" then
            config.options[id] = { type = "Slider", value = opt.Value }
        elseif opt.Type == "Dropdown" then
            config.options[id] = { type = "Dropdown", value = opt.Value, multi = opt.Multi or false }
        elseif opt.Type == "Input" then
            config.options[id] = { type = "Input", value = opt.Value }
        elseif opt.Type == "KeyPicker" then
            config.options[id] = { type = "KeyPicker", value = opt.Value, mode = opt.Mode or "Hold" }
        elseif opt.Type == "ColorPicker" then
            local c = opt.Value
            config.options[id] = { type = "ColorPicker", value = { r = c.r, g = c.g, b = c.b, a = c.a } }
        end
    end
    config.windows = {}
    for i, win in ipairs(self.Windows) do config.windows[i] = { pos = { x = win.Pos.x, y = win.Pos.y } } end
    config.watermark = { x = self.Watermark.Pos.x, y = self.Watermark.Pos.y }
    file.write(self.ConfigFolder .. name .. ".json", self:TableToJSON(config))
    self.CurrentConfig = name
    self:Notify("Config saved: " .. name, 3)
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue(name)
    end
    return true
end

function Library:LoadConfig(name)
    local filename = self.ConfigFolder .. name .. ".json"
    if not file.exists(filename) then self:Notify("Config not found: " .. name, 3); return false end
    local config = self:JSONToTable(file.read(filename))
    if not config then self:Notify("Failed to load config: " .. name, 3); return false end
    for id, value in pairs(config.toggles or {}) do
        if self.Toggles[id] then self.Toggles[id]:SetValue(value) end
    end
    for id, data in pairs(config.options or {}) do
        if self.Options[id] then
            if data.type == "Slider" then self.Options[id]:SetValue(data.value)
            elseif data.type == "Dropdown" then self.Options[id]:SetValue(data.value)
            elseif data.type == "Input" then self.Options[id]:SetValue(data.value)
            elseif data.type == "KeyPicker" then
                self.Options[id]:SetValue(data.value)
                if data.mode then self.Options[id].Mode = data.mode end
            elseif data.type == "ColorPicker" then
                local c = data.value
                self.Options[id]:SetValue(color(c.r, c.g, c.b, c.a))
            end
        end
    end
    for i, win_data in ipairs(config.windows or {}) do
        if self.Windows[i] then self.Windows[i].Pos = vector2(win_data.pos.x, win_data.pos.y) end
    end
    if config.watermark then self.Watermark.Pos = vector2(config.watermark.x, config.watermark.y) end
    self.ConfigLoaded = true
    self.CurrentConfig = name
    self:Notify("Config loaded: " .. name, 3)
    if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
    return true
end

function Library:DeleteConfig(name)
    local filename = self.ConfigFolder .. name .. ".json"
    if file.exists(filename) then
        if file.delete_file then
            file.delete_file(filename)
        else
            file.write(filename, "")
        end
        self:Notify("Config deleted: " .. name, 3)
        if self.CurrentConfig == name then self.CurrentConfig = "" end
        if self.ConfigDropdown then
            self.ConfigDropdown:SetValues(self:GetConfigList())
            self.ConfigDropdown:SetValue("")
        end
        return true
    end
    return false
end

function Library:ResetAll()
    for id, toggle in pairs(self.Toggles) do toggle:SetValue(false) end
    for id, opt in pairs(self.Options) do
        if opt.Type == "Slider" then opt:SetValue((opt.Min + opt.Max) / 2)
        elseif opt.Type == "Dropdown" and not opt.Multi then opt:SetValue(opt.Values[1])
        elseif opt.Type == "Input" then opt:SetValue("")
        elseif opt.Type == "KeyPicker" then opt:SetValue("...")
        elseif opt.Type == "ColorPicker" then opt:SetValue(self.AccentColor) end
    end
    self.CurrentConfig = ""
    if self.ConfigDropdown then self.ConfigDropdown:SetValue("") end
    self:Notify("All settings reset!", 3)
end

function Library:TableToJSON(tbl)
    local function serialize(val)
        if type(val) == "string" then return '"' .. val:gsub('"', '\\"') .. '"'
        elseif type(val) == "number" then return tostring(val)
        elseif type(val) == "boolean" then return val and "true" or "false"
        elseif type(val) == "table" then
            local items = {}
            local is_array = true
            local max_idx = 0
            for k, v in pairs(val) do
                if type(k) ~= "number" or k ~= math.floor(k) or k <= 0 then is_array = false; break end
                if k > max_idx then max_idx = k end
            end
            if is_array and max_idx > 0 then
                for i = 1, max_idx do table.insert(items, serialize(val[i])) end
                return "[" .. table.concat(items, ",") .. "]"
            else
                for k, v in pairs(val) do table.insert(items, serialize(k) .. ":" .. serialize(v)) end
                return "{" .. table.concat(items, ",") .. "}"
            end
        else return "null" end
    end
    return serialize(tbl)
end

function Library:JSONToTable(str)
    local func, err = load("return " .. str, "json_parse")
    if func then
        local success, result = pcall(func)
        if success then return result end
    end
    return nil
end

function Library:CreateConfigSection(groupbox)
    local configs = self:GetConfigList()
    local dropdown = groupbox:AddDropdown("config_dropdown", {
        Text = "Load Config", Default = 1, Values = configs, Tooltip = "Select a config to load"
    })
    self.ConfigDropdown = dropdown
    groupbox:AddButton({ Text = "Save As New Config", Func = function() self:Notify("Type config name in console", 3); print("Enter config name:") end, Tooltip = "Save current settings as a new config" })
    groupbox:AddButton({ Text = "Overwrite Current", Func = function()
        if self.CurrentConfig and self.CurrentConfig ~= "" then self:SaveConfig(self.CurrentConfig)
        else self:Notify("No config loaded to overwrite", 3) end
    end, Tooltip = "Save over the currently loaded config" })
    groupbox:AddDivider()
    groupbox:AddButton({ Text = "Delete Selected", DoubleClick = true, Func = function()
        local current = dropdown.Value
        if current and current ~= "" then self:DeleteConfig(current)
        else self:Notify("No config selected", 3) end
    end, Tooltip = "Double click to delete selected config" })
    groupbox:AddButton({ Text = "Reset to Defaults", DoubleClick = true, Func = function() self:ResetAll() end, Tooltip = "Double click to reset all settings" })
    groupbox:AddButton({ Text = "Refresh Config List", Func = function()
        dropdown:SetValues(self:GetConfigList()); self:Notify("Config list refreshed", 2)
    end, Tooltip = "Refresh the config dropdown list" })
    dropdown:OnChanged(function(value) if value and value ~= "" then self:LoadConfig(value) end end)
    return dropdown
end

