--  Watermark
-- ─────────────────────────────────────────────
local function draw_watermark()
    if not Library.Watermark.Visible then return end
    local ts = render.get_text_size(Library.Watermark.Text)
    local wsz = vector2(ts.x+16, 24)
    Library.Watermark.Pos = clamp_position(Library.Watermark.Pos, wsz)
    local pos = Library.Watermark.Pos
    draw_shadow(pos, wsz, 6, 1)
    draw_liquid_glass(pos, wsz, 6, 1, Library.MainColor)
    render.add_text(pos:add(vector2(8,4)), Library.Watermark.Text, Library.FontColor)
end

-- ─────────────────────────────────────────────
--  Main render hook
-- ─────────────────────────────────────────────
hook.add("render", "auth_photon_render", function()
    refresh_screen()
    Library.ScrollHoverZones = {}

    local anim = Library.Animation
    if anim.State == "FadingOut" then
        anim.CurrentAlpha = anim.CurrentAlpha - anim.Speed
        if anim.CurrentAlpha <= 0 then
            anim.CurrentAlpha = 0
            if anim.PendingTab then anim.PendingTab.Parent.ActiveTab = anim.PendingTab; anim.PendingTab=nil end
            anim.State = "FadingIn"
        end
    elseif anim.State == "FadingIn" then
        anim.CurrentAlpha = anim.CurrentAlpha + anim.Speed
        if anim.CurrentAlpha >= 1 then anim.CurrentAlpha=1; anim.State="Idle" end
    end

    Library.Hue = (Library.Hue + 0.002) % 1
    Library.CurrentRainbowColor = hsv_to_rgb(Library.Hue, 0.8, 1)

    local accent   = Library.AccentColor
    local mp       = input.get_mouse_position()
    local mpressed = input.is_key_pressed(0x01)
    local mdown    = input.key_down(0x01)

    Library.ModalOpen = Library.OpenedDropdown or Library.ActiveColorPicker or Library.ActiveKeyPicker or Library.ActiveInput or Library.RightClickMenu

    -- ── release active scrollbar drag ──
    if Library.ActiveScrollbar then
        if mdown then
            local s = Library.ActiveScrollbar
            -- actual scroll delta is computed during draw_scrollbar via drag
        else
            Library.ActiveScrollbar.dragging = false
            Library.ActiveScrollbar = nil
        end
    end

    -- ── handle active scrollbar thumb drag motion ──
    -- The thumb drag maths live here so we can access the full layout computed
    -- by draw_scrollbar on the previous frame, stored in _last_drag_layout.
    if Library.ActiveScrollbar and mdown then
        local s = Library.ActiveScrollbar
        if s._track_h and s._content_h and s._visible_h then
            local max_off    = math.max(0, s._content_h - s._visible_h)
            local ratio      = s._visible_h / s._content_h
            local thumb_h    = math.max(SB_MIN_THUMB, math.floor(s._track_h * ratio))
            local thumb_travel = s._track_h - thumb_h
            if thumb_travel > 0 then
                local delta = mp.y - s.drag_start_y
                s.offset = s.drag_start_off + delta * (max_off / thumb_travel)
                clamp_scroll(s, s._content_h, s._visible_h)
            end
        end
    end

    -- ── dismiss modals on outside click ──
    if mpressed and Library.ModalOpen then
        if Library.OpenedDropdown then
            local dd = Library.OpenedDropdown
            if dd.Layout and not (is_mouse_in_rect(dd.Layout.pos, dd.Layout.size) or is_mouse_in_rect(dd.Layout.list_pos, dd.Layout.list_size)) then
                dd.Open=false; Library.OpenedDropdown=nil
            end
        end
        if Library.ActiveColorPicker then
            local acp = Library.ActiveColorPicker
            if not is_mouse_in_rect(acp.layout.picker_pos, acp.layout.picker_size) then
                acp.obj.Open=false; Library.ActiveColorPicker=nil
            end
        end
        if Library.ActiveKeyPicker then
            local akp = Library.ActiveKeyPicker
            if not is_mouse_in_rect(akp.layout.pos, akp.layout.size) then
                akp.obj.Picking=false; Library.ActiveKeyPicker=nil
            end
        end
        if Library.ActiveInput then
            if not is_mouse_in_rect(Library.ActiveInput.layout.pos, Library.ActiveInput.layout.size) then
                Library.ActiveInput=nil
            end
        end
    end

    if mpressed and Library.RightClickMenu then
        local rcm_sz = vector2(110, 3*24+8)
        if not is_mouse_in_rect(Library.RightClickMenu.pos, rcm_sz) then
            Library.RightClickMenu = nil
        end
    end

    -- ── window drag ──
    if Library.DraggingWindow then
        if mdown then
            Library.DraggingWindow.Pos = clamp_position(
                mp:subtract(Library.DragOffset), Library.DraggingWindow.Size)
        else Library.DraggingWindow=nil end
    end

    -- ── slider drag ──
    if Library.ActiveSlider then
        if mdown then
            local s,l = Library.ActiveSlider.obj, Library.ActiveSlider.layout
            local r = (math.clamp(mp.x, l.pos.x, l.pos.x+l.size.x) - l.pos.x) / l.size.x
            local v = s.Min + (s.Max-s.Min)*r
            if s.Value~=v then s:SetValue(v) end
        else Library.ActiveSlider=nil end
    end

    -- ── colour picker drag ──
    if Library.ActiveColorPicker and mdown then
        local cp     = Library.ActiveColorPicker.obj
        local layout = Library.ActiveColorPicker.layout
        if is_mouse_in_rect(layout.sv_pos, layout.sv_size) then
            cp.Saturation = math.clamp((mp.x - layout.sv_pos.x) / layout.sv_size.x, 0, 1)
            cp.ValueHSV   = 1 - math.clamp((mp.y - layout.sv_pos.y) / layout.sv_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        elseif layout.hue_pos and is_mouse_in_rect(layout.hue_pos, layout.hue_size) then
            cp.Hue = math.clamp((mp.y - layout.hue_pos.y) / layout.hue_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        elseif cp.EnableAlpha and layout.alpha_pos and is_mouse_in_rect(layout.alpha_pos, layout.alpha_size) then
            cp.Alpha = math.clamp((mp.y - layout.alpha_pos.y) / layout.alpha_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        end
    end

    -- ── watermark drag ──
    local ts_wm   = render.get_text_size(Library.Watermark.Text)
    local wm_size = vector2(ts_wm.x+16, 24)
    if not Library.DraggingWatermark and mpressed and is_mouse_in_rect(Library.Watermark.Pos, wm_size) then
        Library.DraggingWatermark=true; Library.DragOffset=mp:subtract(Library.Watermark.Pos)
    end
    if Library.DraggingWatermark then
        if mdown then
            local wsz = vector2(render.get_text_size(Library.Watermark.Text).x+16, 24)
            Library.Watermark.Pos = clamp_position(mp:subtract(Library.DragOffset), wsz)
        else Library.DraggingWatermark=false end
    end

    local can_interact = not Library.ModalOpen and anim.State=="Idle"
    Library.Tooltip = nil

    -- ─────────────────────────────────────────
    --  Windows
    -- ─────────────────────────────────────────
    for win_idx, window in ipairs(Library.Windows) do
        if window.Visible then
            window.Pos = clamp_position(window.Pos, window.Size)
            window.Alpha = window.Alpha + (window.TargetAlpha - window.Alpha) * 0.07
            local wa = window.Alpha
            if wa < 0.01 then goto continue_window end

            -- Lazy-init unique IDs
            if not window.TabScrollId then
                window.TabScrollId = "win_tab_" .. tostring(win_idx)
            end

            local title_bar_pos  = window.Pos
            local title_bar_size = vector2(window.Size.x, 34)
            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(title_bar_pos, title_bar_size) and not Library.ModalOpen then
                Library.DraggingWindow=window; Library.DragOffset=mp:subtract(window.Pos)
            end

            draw_shadow(window.Pos, window.Size, 12, wa)
            draw_liquid_glass(window.Pos, window.Size, 10, wa, Library.Glass.Tint)

            local msp = window.Pos:add(vector2(12,36))
            local mss = vector2(window.Size.x-24, window.Size.y-48)
            draw_liquid_glass(msp, mss, 8, wa, Library.BackgroundColor)
            render.add_text(window.Pos:add(vector2(14,10)), window.Title, apply_alpha(Library.FontColor, wa))

            local tab_area_pos = msp:add(vector2(4,4))
            local tab_x = 0
            for _, tab in ipairs(window.Tabs) do
                local tw  = render.get_text_size(tab.Name).x + 20
                local tp2 = tab_area_pos:add(vector2(tab_x,0))
                local ts2 = vector2(tw, 24)
                local active_target = anim.PendingTab or window.ActiveTab
                local is_active = (active_target == tab)
                local tab_bg = is_active and apply_alpha(Library.FontColor, wa) or apply_alpha(color(0.1,0.1,0.13,1), wa)
                local tab_fg = is_active and apply_alpha(Library.BackgroundColor, wa) or apply_alpha(Library.SecondaryFontColor, wa)
                render.add_rect_filled(tp2, tp2:add(ts2), tab_bg, 6)
                render.add_text(tp2:add(vector2(10,4)), tab.Name, tab_fg)
                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(tp2, ts2) and anim.State=="Idle" and window.ActiveTab~=tab then
                    anim.State="FadingOut"; anim.PendingTab=tab
                end
                tab_x = tab_x + tw + 6
            end

            -- ── tab content area (scrollable) ──
            -- The tab container itself can scroll vertically if its total
            -- groupbox height exceeds the available area.
            local tab_container_pos  = msp:add(vector2(0, 36))
            local tab_container_size = vector2(window.Size.x-24, mss.y - 36)

            if window.ActiveTab and anim.CurrentAlpha > 0 then
                local op = anim.CurrentAlpha * wa

                -- First pass: measure total content height needed by the active tab.
                local left_total_h  = 0
                local right_total_h = 0
                for _, groupbox in ipairs(window.ActiveTab.Groupboxes) do
                    if groupbox:IsVisible() then
                        local content_h = 32
                        for _,e in ipairs(groupbox.Elements) do content_h=content_h+e.Height end
                        -- Honour MaxHeight capping for groupbox-level scroll
                        local used_h = groupbox.MaxHeight and math.min(content_h, groupbox.MaxHeight) or content_h
                        if groupbox.Side == "Left" then
                            left_total_h = left_total_h + used_h + 12
                        else
                            right_total_h = right_total_h + used_h + 12
                        end
                    end
                end
                local tab_content_h = math.max(left_total_h, right_total_h)

                -- Tab-level scroll state
                local tab_scroll_state = get_scroll_state(window.TabScrollId)
                local tab_needs_scroll = tab_content_h > tab_container_size.y
                clamp_scroll(tab_scroll_state, tab_content_h, tab_container_size.y)

                -- Scrollbar for the whole tab container (right edge of window)
                if tab_needs_scroll then
                    local sb_track_pos = tab_container_pos:add(vector2(tab_container_size.x - SB_WIDTH, 4))
                    local sb_track_h   = tab_container_size.y - 8

                    tab_scroll_state._track_h   = sb_track_h
                    tab_scroll_state._content_h = tab_content_h
                    tab_scroll_state._visible_h = tab_container_size.y

                    draw_scrollbar(sb_track_pos, sb_track_h,
                        tab_content_h, tab_container_size.y,
                        tab_scroll_state, op, mpressed, mdown, mp)

                    register_scroll_zone(
                        tab_container_pos:add(vector2(0, 4)),
                        vector2(tab_container_size.x, tab_container_size.y - 4),
                        tab_scroll_state, tab_content_h, tab_container_size.y)
                end

                local scroll_off    = tab_scroll_state.offset
                local content_area  = tab_container_pos:add(vector2(4, 4 - scroll_off))
                local left_y, right_y = 0, 0
                -- Effective inner width (subtract scrollbar space when active)
                local inner_w = tab_container_size.x - (tab_needs_scroll and (SB_WIDTH + SB_PAD) or 0) - 8

                for gb_idx, groupbox in ipairs(window.ActiveTab.Groupboxes) do
                    if groupbox:IsVisible() then
                        -- Lazy-init unique scroll ID per groupbox
                        if not groupbox._scroll_id then
                            groupbox._scroll_id = "gb_" .. tostring(win_idx) .. "_" .. tostring(gb_idx)
                        end

                        local side_off = (groupbox.Side=="Left") and 0 or (inner_w/2 + 2)
                        local y_off    = (groupbox.Side=="Left") and left_y or right_y
                        local group_pos = content_area:add(vector2(side_off, y_off))

                        -- Measure raw content height of this groupbox
                        local raw_content_h = 32
                        for _,e in ipairs(groupbox.Elements) do raw_content_h=raw_content_h+e.Height end

                        -- Determine capped visible height
                        local group_visible_h = groupbox.MaxHeight or raw_content_h
                        local group_size = vector2(inner_w/2 - 6, group_visible_h)
                        local gb_needs_scroll = (raw_content_h > group_visible_h)

                        -- Groupbox-level scroll state
                        local gb_scroll_state = get_scroll_state(groupbox._scroll_id)
                        clamp_scroll(gb_scroll_state, raw_content_h, group_visible_h)

                        if gb_needs_scroll then
                            gb_scroll_state._track_h   = group_visible_h - 8
                            gb_scroll_state._content_h = raw_content_h
                            gb_scroll_state._visible_h = group_visible_h
                        end

                        draw_shadow(group_pos, group_size, 8, op * 0.5)
                        draw_liquid_glass(group_pos, group_size, 8, op, Library.MainColor)
                        render.add_text(group_pos:add(vector2(10,8)), groupbox.Name, apply_alpha(Library.FontColor, op))

                        -- Groupbox scrollbar
                        if gb_needs_scroll then
                            local sb_pos = group_pos:add(vector2(group_size.x - SB_WIDTH - 2, 30))
                            local sb_h   = group_visible_h - 34
                            draw_scrollbar(sb_pos, sb_h, raw_content_h, group_visible_h,
                                gb_scroll_state, op, mpressed, mdown, mp)
                            register_scroll_zone(
                                group_pos:add(vector2(0, 28)),
                                vector2(group_size.x, group_visible_h - 28),
                                gb_scroll_state, raw_content_h, group_visible_h)
                        end

                        local gb_scroll_off = gb_scroll_state.offset
                        -- Inner element width (subtract scrollbar space when active)
                        local efw_w = group_size.x - 20 - (gb_needs_scroll and (SB_WIDTH + SB_PAD) or 0)

                        local element_y = 30 - gb_scroll_off
                        for _, element in ipairs(groupbox.Elements) do
                            -- Only interact with elements that are within the visible clip region
                            local ep  = group_pos:add(vector2(10, element_y))
                            local efw = vector2(efw_w, element.Height)

                            -- Clip check: element must be within the groupbox visible bounds
                            local elem_top    = ep.y
                            local elem_bot    = ep.y + element.Height
                            local clip_top    = group_pos.y + 28
                            local clip_bot    = group_pos.y + group_visible_h - 2
                            local is_clipped  = (elem_bot < clip_top) or (elem_top > clip_bot)

                            if not is_clipped then
                                if is_mouse_in_rect(ep, efw) and element.Tooltip then
                                    Library.Tooltip={Text=element.Tooltip, Element=element}
                                end

                                -- ── Toggle ──
                                if element.Type=="Toggle" then
                                    local target_x = element.Value and 1 or 0
                                    element.SwitchAnim = element.SwitchAnim + (target_x - element.SwitchAnim) * 0.07
                                    local sw_size = vector2(30, 17)
                                    local sw_pos  = ep:add(vector2(0, 5))
                                    local base_bg = color(0.08,0.08,0.10,1)
                                    local fill_bg = color(
                                        lerp(base_bg.r, Library.AccentColor.r, element.SwitchAnim),
                                        lerp(base_bg.g, Library.AccentColor.g, element.SwitchAnim),
                                        lerp(base_bg.b, Library.AccentColor.b, element.SwitchAnim), 1)
                                    render.add_rect_filled(sw_pos, sw_pos:add(sw_size), apply_alpha(fill_bg, op), 9)
                                    render.add_rect(sw_pos, sw_pos:add(sw_size), apply_alpha(Library.OutlineColor, op), 9, 1)
                                    local knob_x = lerp(sw_pos.x+2, sw_pos.x+sw_size.x-13, element.SwitchAnim)
                                    local knob_col = color(
                                        lerp(0.5, Library.BackgroundColor.r, element.SwitchAnim),
                                        lerp(0.5, Library.BackgroundColor.g, element.SwitchAnim),
                                        lerp(0.55,Library.BackgroundColor.b, element.SwitchAnim), 1)
                                    render.add_rect_filled(vector2(knob_x, sw_pos.y+2), vector2(knob_x+11, sw_pos.y+13), apply_alpha(knob_col, op), 6)
                                    render.add_text(ep:add(vector2(38,4)), element.Text, element.Risky and apply_alpha(Library.RiskColor,op) or apply_alpha(Library.FontColor,op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(ep, vector2(170,20)) and can_interact then
                                        element:SetValue(not element.Value)
                                    end

                                -- ── Slider ──
                                elseif element.Type=="Slider" then
                                    local ratio = (element.Value - element.Min) / (element.Max - element.Min)
                                    element.ThumbAnim = element.ThumbAnim + (ratio - element.ThumbAnim) * 0.08
                                    local s_pos  = ep:add(vector2(0, 22))
                                    local s_size = vector2(efw_w, 14)
                                    local thumb_x = s_pos.x + s_size.x * element.ThumbAnim
                                    local is_hovering = is_mouse_in_rect(s_pos, s_size)
                                    local is_dragging = Library.ActiveSlider and Library.ActiveSlider.obj == element
                                    element.BubbleAlpha = element.BubbleAlpha + (((is_hovering or is_dragging) and 1 or 0) - element.BubbleAlpha) * 0.08
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    render.add_rect_filled(s_pos, s_pos:add(s_size), apply_alpha(Library.BackgroundColor, op), 7)
                                    render.add_rect(s_pos, s_pos:add(s_size), apply_alpha(Library.OutlineColor, op), 7, 1)
                                    if element.ThumbAnim > 0.001 then
                                        local fill_w = math.max(0, s_size.x * element.ThumbAnim - 2)
                                        render.add_rect_filled(s_pos:add(vector2(2,2)), s_pos:add(vector2(2+fill_w, s_size.y-2)), apply_alpha(accent, op), 5)
                                    end
                                    local thumb_pos = vector2(thumb_x-4, s_pos.y-2)
                                    render.add_rect_filled(thumb_pos, thumb_pos:add(vector2(8, s_size.y+4)), apply_alpha(Library.FontColor, op), 4)
                                    if element.BubbleAlpha > 0.01 then
                                        local val_text = tostring(element.Value) .. element.Suffix
                                        local bub_w = render.get_text_size(val_text).x + 10
                                        local bub_pos = vector2(thumb_x - bub_w/2, s_pos.y-22)
                                        local bub_a = element.BubbleAlpha * op
                                        render.add_rect_filled(bub_pos, bub_pos:add(vector2(bub_w,16)), apply_alpha(Library.MainColor, bub_a), 4)
                                        render.add_rect(bub_pos, bub_pos:add(vector2(bub_w,16)), apply_alpha(Library.OutlineColor, bub_a), 4, 1)
                                        render.add_text(bub_pos:add(vector2(5,1)), val_text, apply_alpha(Library.FontColor, bub_a))
                                    end
                                    if not Library.DraggingWindow and not Library.ActiveSlider and mpressed and is_mouse_in_rect(s_pos, s_size) and can_interact then
                                        Library.ActiveSlider={obj=element, layout={pos=s_pos, size=s_size}}
                                    end

                                -- ── Button ──
                                elseif element.Type=="Button" then
                                    local b_pos  = ep
                                    local b_size = vector2(efw_w, 24)
                                    local is_hover = is_mouse_in_rect(b_pos, b_size)
                                    element.HoverAnim = element.HoverAnim + ((is_hover and 1 or 0) - element.HoverAnim) * 0.07
                                    local ha = element.HoverAnim
                                    local bg = color(lerp(Library.BackgroundColor.r,Library.FontColor.r,ha), lerp(Library.BackgroundColor.g,Library.FontColor.g,ha), lerp(Library.BackgroundColor.b,Library.FontColor.b,ha), 1)
                                    local fg = color(lerp(Library.FontColor.r,Library.BackgroundColor.r,ha), lerp(Library.FontColor.g,Library.BackgroundColor.g,ha), lerp(Library.FontColor.b,Library.BackgroundColor.b,ha), 1)
                                    render.add_rect_filled(b_pos, b_pos:add(b_size), apply_alpha(bg, op), 6)
                                    render.add_rect(b_pos, b_pos:add(b_size), apply_alpha(Library.OutlineColor, op), 6, 1)
                                    local btn_text = element.Text
                                    if element.DoubleClick and get_unixtime()-element.LastClick<1 and element.LastClick~=0 then btn_text="Confirm?" end
                                    local clip = get_clipped_text(btn_text, b_size.x-12)
                                    render.add_text(b_pos:add(vector2(b_size.x/2 - render.get_text_size(clip).x/2, 4)), clip, apply_alpha(fg, op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(b_pos, b_size) and can_interact then
                                        if element.DoubleClick then
                                            if get_unixtime()-element.LastClick<1 then
                                                if element.Func then element.Func() end; element.LastClick=0
                                            else element.LastClick=get_unixtime() end
                                        else
                                            if element.Func then element.Func() end
                                        end
                                    end

                                -- ── Dropdown ──
                                elseif element.Type=="Dropdown" then
                                    -- Lazy-init list scroll ID
                                    if not element._list_scroll_id then
                                        element._list_scroll_id = "dd_list_" .. tostring(element) -- unique per element table
                                    end
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local d_pos  = ep:add(vector2(0,18))
                                    local d_size = vector2(efw_w, 22)
                                    element.Layout = {pos=d_pos, size=d_size, list_pos=vector2(0,0), list_size=vector2(0,0)}
                                    local is_hover = is_mouse_in_rect(d_pos, d_size)
                                    element.HoverAlpha = element.HoverAlpha + ((is_hover and 1 or 0) - element.HoverAlpha) * 0.07
                                    local bg = color(
                                        lerp(Library.BackgroundColor.r, Library.MainColor.r, element.HoverAlpha),
                                        lerp(Library.BackgroundColor.g, Library.MainColor.g, element.HoverAlpha),
                                        lerp(Library.BackgroundColor.b, Library.MainColor.b, element.HoverAlpha), 1)
                                    render.add_rect_filled(d_pos, d_pos:add(d_size), apply_alpha(bg, op), 6)
                                    render.add_rect(d_pos, d_pos:add(d_size), apply_alpha(Library.OutlineColor, op), 6, 1)
                                    local display_text
                                    if element.Multi then
                                        local sel={}
                                        for k,v in pairs(element.Value) do if v then table.insert(sel,k) end end
                                        display_text = #sel>0 and table.concat(sel,", ") or "None"
                                    else
                                        display_text = tostring(element.Value)
                                    end
                                    render.add_text(d_pos:add(vector2(8,3)), get_clipped_text(display_text, d_size.x-24), apply_alpha(Library.FontColor,op))
                                    render.add_triangle_filled(d_pos:add(vector2(d_size.x-13,8)), d_pos:add(vector2(d_size.x-5,8)), d_pos:add(vector2(d_size.x-9,15)), apply_alpha(Library.FontColor,op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(d_pos, d_size) and can_interact then
                                        element.Open=not element.Open
                                        Library.OpenedDropdown = element.Open and element or nil
                                    end

                                -- ── Input ──
                                elseif element.Type=="Input" then
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local i_pos  = ep:add(vector2(0,18))
                                    local i_size = vector2(efw_w, 22)
                                    element.layout = {pos=i_pos, size=i_size}
                                    local is_active = Library.ActiveInput==element
                                    render.add_rect_filled(i_pos, i_pos:add(i_size), apply_alpha(Library.BackgroundColor,op), 6)
                                    render.add_rect(i_pos, i_pos:add(i_size), is_active and apply_alpha(accent,op) or apply_alpha(Library.OutlineColor,op), 6, 1)
                                    local d_text = #element.Value>0 and element.Value or element.Placeholder
                                    local tc = #element.Value>0 and Library.FontColor or color(0.35,0.35,0.4,1)
                                    render.add_text(i_pos:add(vector2(8,3)), get_clipped_text(d_text, i_size.x-14), apply_alpha(tc,op))
                                    if is_active and (math.floor(get_unixtime()*2)%2==0) then
                                        local tw2 = render.get_text_size(get_clipped_text(element.Value, i_size.x-14)).x
                                        render.add_line(i_pos:add(vector2(8+tw2,5)), i_pos:add(vector2(8+tw2,i_size.y-5)), apply_alpha(Library.FontColor,op), 1)
                                    end
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(i_pos, i_size) and can_interact then
                                        Library.ActiveInput=element
                                    end

                                -- ── KeyPicker ──
                                elseif element.Type=="KeyPicker" then
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local k_pos  = ep:add(vector2(0,18))
                                    local k_size = vector2(efw_w, 22)
                                    element.layout = {pos=k_pos, size=k_size}
                                    render.add_rect_filled(k_pos, k_pos:add(k_size), apply_alpha(Library.BackgroundColor,op), 6)
                                    render.add_rect(k_pos, k_pos:add(k_size), (element.Picking and apply_alpha(accent,op)) or apply_alpha(Library.OutlineColor,op), 6, 1)
                                    local mode_tag = ""
                                    if element.Mode=="Hold" then mode_tag=" [H]" elseif element.Mode=="Toggle" then mode_tag=" [T]" end
                                    local ktext = element.Picking and "press a key..." or (element.Value .. mode_tag)
                                    render.add_text(k_pos:add(vector2(k_size.x/2 - render.get_text_size(ktext).x/2, 3)), ktext, apply_alpha(Library.FontColor,op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(k_pos, k_size) and can_interact then
                                        element.Picking=true
                                        Library.ActiveKeyPicker={obj=element, layout=element.layout}
                                    end
                                    if not Library.DraggingWindow and input.is_key_pressed(0x02) and is_mouse_in_rect(k_pos, k_size) and can_interact then
                                        Library.RightClickMenu={obj=element, pos=mp, Alpha=0}
                                    end

                                -- ── ColorPicker ──
                                elseif element.Type=="ColorPicker" then
                                    local box_size = vector2(18,14)
                                    local box_pos  = ep:add(vector2(efw_w-box_size.x, 4))
                                    element.layout.pos  = box_pos
                                    element.layout.size = box_size
                                    render.add_text(ep:add(vector2(0,3)), element.Text, apply_alpha(Library.SecondaryFontColor,op))
                                    if element.EnableAlpha then draw_checkerboard(box_pos:add(vector2(1,1)), box_size:subtract(vector2(2,2)), 4) end
                                    render.add_rect_filled(box_pos:add(vector2(1,1)), box_pos:add(box_size):subtract(vector2(1,1)), apply_alpha(element.Value,op), 4)
                                    render.add_rect(box_pos, box_pos:add(box_size), apply_alpha(Library.OutlineColor,op), 4, 1)
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(box_pos, box_size) and can_interact then
                                        element.Open = not element.Open
                                        if element.Open then
                                            Library.ActiveColorPicker = {obj=element, layout=element.layout}
                                        else
                                            Library.ActiveColorPicker = nil
                                        end
                                    end

                                -- ── Divider ──
                                elseif element.Type=="Divider" then
                                    local dy = ep.y + element.Height/2
                                    render.add_line(vector2(ep.x,dy), vector2(ep.x+efw_w,dy), apply_alpha(Library.OutlineColor,op), 1)

                                -- ── Label ──
                                elseif element.Type=="Label" then
                                    render.add_text(ep:add(vector2(0,4)), element.Text, apply_alpha(Library.FontColor,op))
                                end
                            end -- not is_clipped

                            element_y = element_y + element.Height
                        end

                        -- Overdraw masking for groupbox clip region
                        if gb_needs_scroll then
                            -- Mask above header area
                            apply_clip_mask(
                                group_pos:add(vector2(0, 28)),
                                vector2(group_size.x, group_visible_h - 28),
                                Library.MainColor, op)
                            -- Re-draw the groupbox border on top so it doesn't get masked
                            render.add_rect(group_pos, group_pos:add(group_size), apply_alpha(Library.OutlineColor, op), 8, 1)
                            render.add_text(group_pos:add(vector2(10,8)), groupbox.Name, apply_alpha(Library.FontColor, op))
                        end

                        local used_h = groupbox.MaxHeight and math.min(raw_content_h, groupbox.MaxHeight) or raw_content_h
                        if groupbox.Side=="Left" then  left_y  = left_y  + used_h + 12
                        else                           right_y = right_y + used_h + 12 end
                    end
                end

                -- Overdraw masking for the tab container clip region
                if tab_needs_scroll then
                    apply_clip_mask(
                        tab_container_pos:add(vector2(0, 4)),
                        vector2(tab_container_size.x, tab_container_size.y - 4),
                        Library.BackgroundColor, wa)
                    -- Re-draw window bottom edge so it looks clean
                    render.add_rect(window.Pos, window.Pos:add(window.Size), apply_alpha(Library.OutlineColor, wa), 10, 1)
                end
            end
        end
        ::continue_window::
    end

    -- ─────────────────────────────────────────
    --  Dropdown list (drawn above everything, with scrollbar)
    -- ─────────────────────────────────────────
    if Library.OpenedDropdown then
        local e = Library.OpenedDropdown
        -- Lazy ID
        if not e._list_scroll_id then
            e._list_scroll_id = "dd_" .. tostring(e)
        end

        local max_visible = e.MaxVisible or 6
        local total_items = #e.Values
        local visible_items = math.min(total_items, max_visible)
        local item_h = 22
        local needs_list_scroll = total_items > max_visible

        local list_h    = visible_items * item_h + 4
        local list_size = vector2(e.Layout.size.x, list_h)
        local list_pos  = fit_popup_position(e.Layout.pos, e.Layout.size, list_size)
        e.Layout.list_pos  = list_pos
        e.Layout.list_size = list_size

        local dd_scroll = get_scroll_state(e._list_scroll_id)
        local content_h_dd = total_items * item_h + 4
        clamp_scroll(dd_scroll, content_h_dd, list_h)

        if needs_list_scroll then
            dd_scroll._track_h   = list_h - 8
            dd_scroll._content_h = content_h_dd
            dd_scroll._visible_h = list_h
        end

        draw_shadow(list_pos, list_size, 6, 1)
        draw_liquid_glass(list_pos, list_size, 6, 1, Library.MainColor)

        -- Scrollbar for the dropdown list
        if needs_list_scroll then
            local sb_pos = list_pos:add(vector2(list_size.x - SB_WIDTH - 2, 4))
            draw_scrollbar(sb_pos, list_h - 8, content_h_dd, list_h,
                dd_scroll, 1, mpressed, mdown, mp)
            register_scroll_zone(
                list_pos:add(vector2(0, 2)),
                vector2(list_size.x, list_h - 4),
                dd_scroll, content_h_dd, list_h)
        end

        local item_y = 2 - dd_scroll.offset
        local text_max_w = list_size.x - (needs_list_scroll and (SB_WIDTH + SB_PAD + 8) or 8) - 8

        for _, value in ipairs(e.Values) do
            local ip  = list_pos:add(vector2(1, item_y))
            local isz = vector2(list_size.x - (needs_list_scroll and (SB_WIDTH + SB_PAD + 4) or 2), item_h)

            -- Only render items within the visible list area
            local visible_top = list_pos.y + 2
            local visible_bot = list_pos.y + list_h - 2
            if ip.y + item_h >= visible_top and ip.y <= visible_bot then
                local is_sel = (e.Multi and e.Value[value]) or (e.Value==value)
                local tc = is_sel and Library.AccentColor or Library.FontColor
                if is_mouse_in_rect(ip, isz) and ip.y >= list_pos.y and ip.y + item_h <= list_pos.y + list_h then
                    render.add_rect_filled(ip, ip:add(isz), apply_alpha(Library.AccentColor, 0.18), 4)
                    tc = Library.AccentColor
                    if mpressed then
                        if e.Multi then e.Value[value]=not e.Value[value]; e:SetValue(e.Value)
                        else e:SetValue(value); e.Open=false; Library.OpenedDropdown=nil end
                    end
                end
                render.add_text(ip:add(vector2(8,3)), get_clipped_text(tostring(value), text_max_w), tc)
            end

            item_y = item_y + item_h
        end

        -- Mask overflow above/below the list box
        if needs_list_scroll then
            apply_clip_mask(
                list_pos:add(vector2(0, 2)),
                vector2(list_size.x, list_h - 4),
                Library.MainColor, 1)
            render.add_rect(list_pos, list_pos:add(list_size), Library.OutlineColor, 6, 1)
        end
    end

    apply_wheel_scroll(get_wheel_delta())

    -- ─────────────────────────────────────────
    --  Colour picker panel
    -- ─────────────────────────────────────────
    if Library.ActiveColorPicker then
        local e       = Library.ActiveColorPicker.obj
        local pad     = 8
        local sv_dim  = 135
        local bar_w   = 12
        local bar_gap = 6
        local bars_x  = pad + sv_dim + pad
        local num_bars = e.EnableAlpha and 2 or 1
        local p_w = bars_x + bar_w * num_bars + bar_gap * (num_bars-1) + pad
        local p_h = pad + sv_dim + pad
        local p_size = vector2(p_w, p_h)

        local p_pos = e.layout.pos:add(vector2(e.layout.size.x + 8, 0))
        if p_pos.x + p_w > SCREEN.x - Library.ScreenPadding then
            p_pos = vector2(e.layout.pos.x - p_w - 8, p_pos.y)
        end
        if p_pos.y + p_h > SCREEN.y - Library.ScreenPadding then
            p_pos = vector2(p_pos.x, SCREEN.y - p_h - Library.ScreenPadding)
        end
        p_pos = clamp_position(p_pos, p_size)

        e.layout.picker_pos  = p_pos
        e.layout.picker_size = p_size

        draw_shadow(p_pos, p_size, 8, 1)
        draw_liquid_glass(p_pos, p_size, 8, 1, Library.MainColor)

        local sv_pos  = p_pos:add(vector2(pad, pad))
        local sv_size = vector2(sv_dim, sv_dim)
        e.layout.sv_pos  = sv_pos
        e.layout.sv_size = sv_size

        local ahr = hsv_to_rgb(e.Hue, 1, 1)
        render.add_rect_filled(sv_pos, sv_pos:add(sv_size), color(1,1,1,1), 0)
        for i = 0, sv_size.x-1 do
            render.add_line(sv_pos:add(vector2(i,0)), sv_pos:add(vector2(i,sv_size.y)), color(ahr.r,ahr.g,ahr.b, i/sv_size.x), 1)
        end
        for i = 0, sv_size.y-1 do
            render.add_line(sv_pos:add(vector2(0,i)), sv_pos:add(vector2(sv_size.x,i)), color(0,0,0, i/sv_size.y), 1)
        end
        render.add_rect(sv_pos, sv_pos:add(sv_size), Library.OutlineColor, 0, 1)

        local cx = sv_pos.x + sv_size.x * e.Saturation
        local cy = sv_pos.y + sv_size.y * (1 - e.ValueHSV)
        render.add_circle(vector2(cx,cy), 5, e.ValueHSV>0.5 and color(0,0,0,1) or color(1,1,1,1), 1)

        local hue_pos  = p_pos:add(vector2(bars_x, pad))
        local hue_size = vector2(bar_w, sv_dim)
        e.layout.hue_pos  = hue_pos
        e.layout.hue_size = hue_size
        for i = 0, hue_size.y-1 do
            render.add_line(hue_pos:add(vector2(0,i)), hue_pos:add(vector2(hue_size.x,i)), hsv_to_rgb(i/hue_size.y,1,1), 1)
        end
        render.add_rect(hue_pos, hue_pos:add(hue_size), Library.OutlineColor, 0, 1)
        local hcy = hue_pos.y + hue_size.y * e.Hue
        render.add_rect(vector2(hue_pos.x-2, hcy-2), vector2(hue_pos.x+hue_size.x+2, hcy+2), color(1,1,1,1), 2, 1)

        if e.EnableAlpha then
            local a_pos  = p_pos:add(vector2(bars_x + bar_w + bar_gap, pad))
            local a_size = vector2(bar_w, sv_dim)
            e.layout.alpha_pos  = a_pos
            e.layout.alpha_size = a_size
            draw_checkerboard(a_pos, a_size, 4)
            local rop = hsv_to_rgb(e.Hue, e.Saturation, e.ValueHSV)
            for i = 0, a_size.y-1 do
                render.add_line(a_pos:add(vector2(0,i)), a_pos:add(vector2(a_size.x,i)), color(rop.r,rop.g,rop.b, i/a_size.y), 1)
            end
            render.add_rect(a_pos, a_pos:add(a_size), Library.OutlineColor, 0, 1)
            local acy = a_pos.y + a_size.y * e.Alpha
            render.add_rect(vector2(a_pos.x-2, acy-2), vector2(a_pos.x+a_size.x+2, acy+2), color(1,1,1,1), 2, 1)
        end
    end

    -- ─────────────────────────────────────────
    --  Right-click menu
    -- ─────────────────────────────────────────
    if Library.RightClickMenu then
        local rcm     = Library.RightClickMenu
        local options = {"Always","Hold","Toggle"}
        local item_h  = 24
        local pad     = 4
        local rcm_w   = 110
        local rcm_h   = #options * item_h + pad*2
        local rcm_sz  = vector2(rcm_w, rcm_h)
        local rp      = clamp_position(
            vector2(math.min(rcm.pos.x, SCREEN.x - rcm_w - Library.ScreenPadding),
                    math.min(rcm.pos.y, SCREEN.y - rcm_h - Library.ScreenPadding)),
            rcm_sz)
        rcm.Alpha = rcm.Alpha + (1 - rcm.Alpha) * 0.12
        draw_shadow(rp, rcm_sz, 8, rcm.Alpha)
        draw_liquid_glass(rp, rcm_sz, 7, rcm.Alpha, Library.MainColor)
        for i, opt in ipairs(options) do
            local ip     = rp:add(vector2(pad, pad+(i-1)*item_h))
            local isz    = vector2(rcm_w-pad*2, item_h)
            local is_sel = (rcm.obj.Mode==opt) or (opt=="Always" and not rcm.obj.Mode)
            local is_hov = is_mouse_in_rect(ip, isz)
            if is_hov or is_sel then
                render.add_rect_filled(ip, ip:add(isz), apply_alpha(accent, (is_sel and 0.18 or 0.10) * rcm.Alpha), 4)
            end
            local tc = (is_sel or is_hov) and apply_alpha(accent, rcm.Alpha) or apply_alpha(Library.FontColor, rcm.Alpha*0.7)
            render.add_text(ip:add(vector2(8,4)), opt, tc)
            if is_sel then
                render.add_rect_filled(ip:add(vector2(rcm_w-pad*2-8, item_h/2-2)), ip:add(vector2(rcm_w-pad*2-4, item_h/2+2)), apply_alpha(accent, rcm.Alpha), 2)
            end
            if mpressed and is_hov then
                rcm.obj.Mode = (opt=="Always") and nil or opt
                Library.RightClickMenu = nil
            end
        end
    end

    -- ─────────────────────────────────────────
    --  Notifications
    -- ─────────────────────────────────────────
    local scr_w, scr_h = SCREEN.x, SCREEN.y
    local nx, ny, vdir = 20, 50, 1
    if     Library.NotificationPosition=="Top Right"    then nx=scr_w-290; ny=50
    elseif Library.NotificationPosition=="Top Left"     then nx=20;        ny=50
    elseif Library.NotificationPosition=="Bottom Right" then nx=scr_w-290; ny=scr_h-60; vdir=-1
    elseif Library.NotificationPosition=="Bottom Left"  then nx=20;        ny=scr_h-60; vdir=-1 end
    nx = math.clamp(nx, Library.ScreenPadding, scr_w - 290)

    local run_y = 0
    for i=#Library.Notifications,1,-1 do
        local n = Library.Notifications[i]
        local t = get_unixtime()-n.StartTime
        if t>n.Duration then n.TargetAlpha=0; n.TargetOffsetX=30 end
        n.Alpha   = n.Alpha   + (n.TargetAlpha   - n.Alpha)   * 0.07
        n.OffsetX = n.OffsetX + (n.TargetOffsetX - n.OffsetX) * 0.07
        if n.TargetAlpha==0 and n.Alpha<0.01 then
            table.remove(Library.Notifications, i)
        else
            local nsz  = vector2(render.get_text_size(n.Text).x+20, 26)
            local cur_y = ny + vdir*run_y
            if vdir==-1 then cur_y=cur_y-nsz.y end
            local slide_sign = (Library.NotificationPosition=="Top Right" or Library.NotificationPosition=="Bottom Right") and 1 or -1
            local np = clamp_position(vector2(nx + slide_sign*n.OffsetX, cur_y), nsz)
            draw_shadow(np, nsz, 6, n.Alpha)
            draw_liquid_glass(np, nsz, 6, n.Alpha, Library.MainColor)
            render.add_rect_filled(np:add(vector2(0,3)), np:add(vector2(2,nsz.y-3)), color(Library.AccentColor.r,Library.AccentColor.g,Library.AccentColor.b,n.Alpha), 2)
            render.add_text(np:add(vector2(10,5)), n.Text, color(Library.FontColor.r,Library.FontColor.g,Library.FontColor.b,n.Alpha))
            run_y = run_y + nsz.y + 6
        end
    end

    draw_watermark()
    local tooltip_target = (Library.Tooltip ~= nil) and 1 or 0
    Library.TooltipAlpha = Library.TooltipAlpha + (tooltip_target - Library.TooltipAlpha) * 0.07
    if anim.State=="Idle" then render_tooltip(Library.TooltipAlpha) end
end)

-- ─────────────────────────────────────────────
--  Key handler
-- ─────────────────────────────────────────────
hook.add("init", "auth_key_handler_init", function()
    hook.add("render", "key_picker_capture", function()
        if Library.ActiveKeyPicker then
            for vk, name in pairs(KEY_NAMES) do
                if input.is_key_pressed(vk) then
                    Library.ActiveKeyPicker.obj:SetValue(name)
                    Library.ActiveKeyPicker.obj.Picking = false
                    Library.ActiveKeyPicker = nil
                    Library:Notify("Key bound to: " .. name, 2)
                    return
                end
            end
        end
    end)

    hook.add("render", "toggle_keys_handler", function()
        for id, opt in pairs(Library.Options) do
            if opt.Type == "KeyPicker" and opt.Mode == "Toggle" and opt.Value and opt.Value ~= "..." then
                local vk = nil
                for code, name in pairs(KEY_NAMES) do
                    if name == opt.Value then vk = code; break end
                end
                if vk and input.is_key_pressed(vk) then
                    opt.Active = not opt.Active
                    if opt.Callback then opt.Callback(opt.Active) end
                    if opt.OnChangedFunc then opt.OnChangedFunc(opt.Active) end
                end
            end
        end
    end)

    hook.add("render", "text_input_handler", function()
        if Library.ActiveInput then
            for vk, char in pairs(CHAR_MAP_NORMAL) do
                if input.is_key_pressed(vk) then
                    if vk == 0x08 then
                        local v = Library.ActiveInput.Value
                        if #v > 0 then Library.ActiveInput:SetValue(string.sub(v, 1, -2)) end
                    elseif vk == 0x0D or vk == 0x1B then
                        Library.ActiveInput = nil
                    else
                        local shift = input.key_down(0x10)
                        local ch = (shift and CHAR_MAP_SHIFT[vk]) or char
                        if ch then Library.ActiveInput:SetValue(Library.ActiveInput.Value .. ch) end
                    end
                    return
                end
            end
        end
    end)

    local last_menu_press = 0
    hook.add("render", "menu_toggle_handler", function()
        local menu_key_obj = Library.Options.menu_key
        if menu_key_obj and menu_key_obj.Value and menu_key_obj.Value ~= "..." then
            local vk = nil
            for code, name in pairs(KEY_NAMES) do
                if name == menu_key_obj.Value then vk = code; break end
            end
            if vk and input.is_key_pressed(vk) then
                local now = get_tickcount()
                if now - last_menu_press > 200 then
                    for _, w in ipairs(Library.Windows) do
                        if w.TargetAlpha > 0.5 then
                            w.TargetAlpha = 0; w.Visible = false
                        else
                            w.Visible = true; w.TargetAlpha = 1
                        end
                    end
                    last_menu_press = now
                end
            end
        end
    end)
end)

Library.Options.menu_key = Library.Options.menu_key or { Value = "Insert", Mode = "Toggle" }

_G.Library = Library
return Library
