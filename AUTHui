            Func = function() self:ShowSaveConfigDialog() end,
            Tooltip = "Save current settings as a new config"
        })
        groupbox:AddButton({
            Text = "Overwrite Current",
            Func = function()
                if self.CurrentConfig and self.CurrentConfig ~= "" then
                    self:SaveConfig(self.CurrentConfig)
                else
                    self:Notify("No config loaded to overwrite", 3)
                end
            end,
            Tooltip = "Save over the currently loaded config"
        })
        groupbox:AddDivider()
        groupbox:AddButton({
            Text = "Delete Selected", DoubleClick = true,
            Func = function()
                local current = dropdown.Value
                if current and current ~= "" then self:DeleteConfig(current)
                else self:Notify("No config selected", 3) end
            end,
            Tooltip = "Double click to delete selected config"
        })
        groupbox:AddButton({
            Text = "Reset to Defaults", DoubleClick = true,
            Func = function() self:ResetAll() end,
            Tooltip = "Double click to reset all settings"
