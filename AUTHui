-- Helper: Convert HSV to RGB
local function hsv_to_rgb(h, s, v, a)
    local r, g, b
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then r, g, b = v, t, p
    elseif i == 1 then r, g, b = q, v, p
    elseif i == 2 then r, g, b = p, v, t
    elseif i == 3 then r, g, b = p, q, v
    elseif i == 4 then r, g, b = t, p, v
    else r, g, b = v, p, q
    end
    return color(r, g, b, a or 1)
end

-- Helper: Convert RGB to HSV
local function rgb_to_hsv(c)
    local r, g, b = c.r, c.g, c.b
    local maxc = math.max(r, g, b)
    local minc = math.min(r, g, b)
    local h, s, v = 0, 0, maxc
    local diff = maxc - minc
    if maxc ~= 0 then s = diff / maxc else return 0, 0, 0 end
    if diff > 1e-5 then
        if maxc == r then
            h = (g - b) / diff
        elseif maxc == g then
            h = 2 + (b - r) / diff
        else
            h = 4 + (r - g) / diff
        end
        h = h / 6
        if h < 0 then h = h + 1 end
    end
    return h, s, v
end

-- Helper: Convert hex string to RGB colour
local function hex_to_color(hex)
    hex = hex:gsub("#", "")
    if #hex == 6 then
        local r = tonumber("0x" .. hex:sub(1, 2)) / 255
        local g = tonumber("0x" .. hex:sub(3, 4)) / 255
        local b = tonumber("0x" .. hex:sub(5, 6)) / 255
        return color(r, g, b, 1)
    elseif #hex == 8 then
        local r = tonumber("0x" .. hex:sub(1, 2)) / 255
        local g = tonumber("0x" .. hex:sub(3, 4)) / 255
        local b = tonumber("0x" .. hex:sub(5, 6)) / 255
        local a = tonumber("0x" .. hex:sub(7, 8)) / 255
        return color(r, g, b, a)
    end
    return color(1, 1, 1, 1)
end

-- Helper: Convert colour to hex string
local function color_to_hex(c)
    local function to_hex(v)
        local n = math.floor(v * 255 + 0.5)
        if n < 0 then n = 0 elseif n > 255 then n = 255 end
        return string.format("%02X", n)
    end
    if c.a and c.a < 1 then
        return "#" .. to_hex(c.r) .. to_hex(c.g) .. to_hex(c.b) .. to_hex(c.a)
    else
        return "#" .. to_hex(c.r) .. to_hex(c.g) .. to_hex(c.b)
    end
end

-- ============================================================================
-- ICON SYSTEM
-- ============================================================================
function Library:LoadBrushIcon()
    local icon_path = "icons/brush.png"
    if file.exists(icon_path) then
        local tex = render.load_texture(icon_path)
        if tex then
            self.Icons.brush = tex.id
            self.Icons.loaded = true
            print("[Library] Brush icon loaded from disk")
            return true
        end
    end

    print("[Library] Downloading brush icon from:", self.Icons.brush_url)
    http.get(self.Icons.brush_url, function(body, status)
        if status == 200 then
            if not file.exists("icons/") then
                file.write("icons/.keep", "")
            end
            file.write(icon_path, body, "binary")
            local tex = render.load_texture(icon_path)
            if tex then
                self.Icons.brush = tex.id
                self.Icons.loaded = true
                print("[Library] Brush icon downloaded and loaded")
            end
        else
            print("[Library] Failed to download brush icon, status:", status)
        end
    end)
    return false
end

