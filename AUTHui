    },

    ConfigFolder = "photon_configs/",

    -- ══════════════════════════════════════
    --  Config system  (unchanged logic)
    -- ══════════════════════════════════════
    GetConfigList = function(self)
        local configs = {}
        local f = self.ConfigFolder .. "manifest.json"
        if file.exists(f) then
            local m = self:JSONToTable(file.read(f))
            if m and m.configs then configs = m.configs end
        end
        return configs
    end,

    UpdateManifest = function(self, name)
        local configs = self:GetConfigList()
        local found = false
        for _, n in ipairs(configs) do if n == name then found = true; break end end
        if not found then table.insert(configs, name) end
        file.write(self.ConfigFolder .. "manifest.json",
            self:TableToJSON({ configs = configs, last_updated = get_unixtime() }))
        self.ConfigList = configs
        return configs
    end,

    RemoveFromManifest = function(self, name)
        local new = {}
        for _, n in ipairs(self:GetConfigList()) do
            if n ~= name then table.insert(new, n) end
        end
        file.write(self.ConfigFolder .. "manifest.json",
            self:TableToJSON({ configs = new, last_updated = get_unixtime() }))
        self.ConfigList = new
        return new
    end,

    SaveConfig = function(self, name)
        if not file.exists(self.ConfigFolder) then file.write(self.ConfigFolder .. ".keep", "") end
        local cfg = { toggles = {}, options = {}, version = 2, saved_at = get_unixtime(), game = get_placeid() }
        for id, t in pairs(self.Toggles) do cfg.toggles[id] = t.Value end
        for id, o in pairs(self.Options) do
            if     o.Type == "Slider"      then cfg.options[id] = { type="Slider",      value=o.Value }
            elseif o.Type == "Dropdown"    then cfg.options[id] = { type="Dropdown",    value=o.Value, multi=o.Multi or false }
            elseif o.Type == "Input"       then cfg.options[id] = { type="Input",       value=o.Value }
            elseif o.Type == "KeyPicker"   then cfg.options[id] = { type="KeyPicker",   value=o.Value, mode=o.Mode or "Hold" }
            elseif o.Type == "ColorPicker" then
                local c = o.Value
                cfg.options[id] = { type="ColorPicker", value={ r=c.r, g=c.g, b=c.b, a=c.a } }
            end
        end
        cfg.windows = {}
        for i, w in ipairs(self.Windows) do cfg.windows[i] = { pos={ x=w.Pos.x, y=w.Pos.y } } end
        cfg.watermark = { x=self.Watermark.Pos.x, y=self.Watermark.Pos.y }
        file.write(self.ConfigFolder .. name .. ".json", self:TableToJSON(cfg))
        self:UpdateManifest(name)
        self.CurrentConfig = name
        self:Notify("Config saved: " .. name, 3)
        if self.ConfigDropdown then
            self.ConfigDropdown:SetValues(self:GetConfigList())
            self.ConfigDropdown:SetValue(name)
        end
        return true
    end,

    LoadConfig = function(self, name)
        local fn = self.ConfigFolder .. name .. ".json"
        if not file.exists(fn) then self:Notify("Config not found: " .. name, 3); return false end
        local cfg = self:JSONToTable(file.read(fn))
        if not cfg then self:Notify("Failed to parse config: " .. name, 3); return false end
        for id, v in pairs(cfg.toggles or {}) do
            if self.Toggles[id] then self.Toggles[id]:SetValue(v) end
        end
        for id, d in pairs(cfg.options or {}) do
            if self.Options[id] then
                if d.type == "Slider"      then self.Options[id]:SetValue(d.value)
                elseif d.type == "Dropdown"    then self.Options[id]:SetValue(d.value)
                elseif d.type == "Input"       then self.Options[id]:SetValue(d.value)
                elseif d.type == "KeyPicker"   then
                    self.Options[id]:SetValue(d.value)
                    if d.mode then self.Options[id].Mode = d.mode end
                elseif d.type == "ColorPicker" then
                    local c = d.value
                    self.Options[id]:SetValue(color(c.r, c.g, c.b, c.a))
                end
            end
        end
        for i, wd in ipairs(cfg.windows or {}) do
            if self.Windows[i] then self.Windows[i].Pos = vector2(wd.pos.x, wd.pos.y) end
        end
        if cfg.watermark then self.Watermark.Pos = vector2(cfg.watermark.x, cfg.watermark.y) end
        self.ConfigLoaded = true
        self.CurrentConfig = name
        self:Notify("Config loaded: " .. name, 3)
        if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
        return true
    end,

    DeleteConfig = function(self, name)
        local fn = self.ConfigFolder .. name .. ".json"
        if file.exists(fn) then
            file.write(fn, "")
            self:RemoveFromManifest(name)
            self:Notify("Config deleted: " .. name, 3)
            if self.CurrentConfig == name then self.CurrentConfig = "" end
            if self.ConfigDropdown then
                self.ConfigDropdown:SetValues(self:GetConfigList())
                self.ConfigDropdown:SetValue("")
            end
            return true
        end
        return false
    end,

    ListConfigs = function(self) return self:GetConfigList() end,

    ResetAll = function(self)
        for _, t in pairs(self.Toggles) do t:SetValue(false) end
        for _, o in pairs(self.Options) do
            if     o.Type == "Slider"   then o:SetValue((o.Min + o.Max) / 2)
            elseif o.Type == "Dropdown" and not o.Multi then o:SetValue(o.Values[1])
            elseif o.Type == "Input"       then o:SetValue("")
            elseif o.Type == "KeyPicker"   then o:SetValue("...")
            elseif o.Type == "ColorPicker" then o:SetValue(color(1, 1, 1, 1))
            end
        end
        self.CurrentConfig = ""
        if self.ConfigDropdown then self.ConfigDropdown:SetValue("") end
        self:Notify("All settings reset!", 3)
    end,

    TableToJSON = function(self, tbl)
        local function s(v)
            if type(v) == "string"  then return '"' .. v:gsub('"', '\\"') .. '"'
            elseif type(v) == "number"  then return tostring(v)
            elseif type(v) == "boolean" then return v and "true" or "false"
            elseif type(v) == "table" then
                local items, is_arr, max = {}, true, 0
                for k in pairs(v) do
                    if type(k) ~= "number" or k ~= math.floor(k) or k <= 0 then is_arr = false; break end
                    if k > max then max = k end
                end
                if is_arr and max > 0 then
                    for i = 1, max do table.insert(items, s(v[i])) end
                    return "[" .. table.concat(items, ",") .. "]"
                else
                    for k, val in pairs(v) do table.insert(items, s(k) .. ":" .. s(val)) end
                    return "{" .. table.concat(items, ",") .. "}"
                end
            else return "null" end
        end
        return s(tbl)
    end,

    JSONToTable = function(self, str)
        local fn, _ = load("return " .. str, "json_parse")
        if fn then local ok, r = pcall(fn); if ok then return r end end
        return nil
    end,

    CreateConfigSection = function(self, groupbox)
        local configs = self:GetConfigList()
        local dd = groupbox:AddDropdown("config_dropdown", { Text="Load Config", Default=1, Values=configs, Tooltip="Select a config to load" })
        self.ConfigDropdown = dd
        groupbox:AddButton({ Text="Overwrite Current", Func=function()
            if self.CurrentConfig ~= "" then self:SaveConfig(self.CurrentConfig)
            else self:Notify("No config loaded", 3) end
        end, Tooltip="Save over currently loaded config" })
        groupbox:AddButton({ Text="Delete Selected", DoubleClick=true, Func=function()
            if dd.Value ~= "" then self:DeleteConfig(dd.Value)
            else self:Notify("No config selected", 3) end
        end, Tooltip="Double-click to delete" })
        groupbox:AddButton({ Text="Reset to Defaults", DoubleClick=true, Func=function() self:ResetAll() end, Tooltip="Double-click to reset all" })
        groupbox:AddButton({ Text="Refresh List", Func=function()
            dd:SetValues(self:GetConfigList()); self:Notify("Config list refreshed", 2)
        end })
        dd:OnChanged(function(v) if v ~= "" then self:LoadConfig(v) end end)
        return dd
    end,

    LoadRemoteUI = function(self, url)
        http.get(url, function(body, code)
            if code == 200 then
                local ok, r = pcall(load(body, "@remote"))
                if ok and type(r) == "table" then self:BuildFromConfig(r); self:Notify("Remote UI loaded", 3)
                else self:Notify("Remote UI execute error", 5) end
            else self:Notify("HTTP " .. tostring(code), 5) end
        end)
    end,

    BuildFromConfig = function(self, config)
        if not config.windows then return end
        for _, wc in ipairs(config.windows) do
            local win = self:CreateWindow(wc)
            for _, tc in ipairs(wc.tabs or {}) do
                local tab = win:AddTab(tc.name)
                for _, gc in ipairs(tc.groupboxes or {}) do
                    local gb = gc.side == "Left" and tab:AddLeftGroupbox(gc.name, gc) or tab:AddRightGroupbox(gc.name, gc)
                    for _, e in ipairs(gc.elements or {}) do self:AddElementToGroupbox(gb, e) end
                end
            end
        end
    end,

    AddElementToGroupbox = function(self, gb, e)
        if     e.type == "Toggle"      then gb:AddToggle(e.id,     { Text=e.text, Default=e.default or false, Tooltip=e.tooltip, Risky=e.risky or false })
        elseif e.type == "Slider"      then gb:AddSlider(e.id,     { Text=e.text, Default=e.default or 0, Min=e.min or 0, Max=e.max or 100, Rounding=e.rounding or 0, Suffix=e.suffix or "", Tooltip=e.tooltip })
        elseif e.type == "Button"      then gb:AddButton(          { Text=e.text, Func=function() if e.func then local f=load(e.func,"rf"); if f then f() end end end, Tooltip=e.tooltip, DoubleClick=e.double_click or false })
        elseif e.type == "Dropdown"    then gb:AddDropdown(e.id,   { Text=e.text, Default=e.default or 1, Values=e.values or {}, Tooltip=e.tooltip, Multi=e.multi or false })
        elseif e.type == "Input"       then gb:AddInput(e.id,      { Text=e.text, Default=e.default or "", Placeholder=e.placeholder or "", Tooltip=e.tooltip })
        elseif e.type == "KeyPicker"   then gb:AddKeyPicker(e.id,  { Text=e.text, Default=e.default or "...", Tooltip=e.tooltip, Mode=e.mode or "Hold" })
        elseif e.type == "ColorPicker" then gb:AddColorPicker(e.id,{ Text=e.text, Default=e.default and color(e.default.r,e.default.g,e.default.b,e.default.a) or color(1,1,1,1), EnableAlpha=e.enable_alpha or false, Tooltip=e.tooltip })
        elseif e.type == "Divider"     then gb:AddDivider(e.height)
        elseif e.type == "Label"       then gb:AddLabel(e.text)
        end
    end,
}

