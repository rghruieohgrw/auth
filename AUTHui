-- ────────────────────────────────────────────
--  ELEMENT METHODS
-- ────────────────────────────────────────────
local ElementMethods = {}
function ElementMethods:OnChanged(fn) self.OnChangedFunc=fn; return self end
function ElementMethods:SetTooltip(t) self.Tooltip=t; return self end

local function CE(base, methods)  -- CreateElement
    if methods then for k,v in pairs(methods) do base[k]=v end end
    return setmetatable(base, {__index=ElementMethods})
end

local function fire(el, v)  -- unified callback fire
    if el.Callback then el.Callback(v) end
    if el.OnChangedFunc then el.OnChangedFunc(v) end
end

local TM={} -- ToggleMethods
function TM:SetValue(v) self.Value=v; fire(self,v) end

local SM={} -- SliderMethods
function SM:SetValue(v)
    local fmt="%.".. (self.Rounding or 0) .."f"
    self.Value=clamp(tonumber(string.format(fmt,v)), self.Min, self.Max)
    fire(self, self.Value)
end

local DM={} -- DropdownMethods
function DM:SetValue(v) self.Value=v; fire(self,v) end
function DM:SetValues(nv)
    self.Values=nv
    if not self.Multi and nv and #nv>0 then self:SetValue(nv[1]) end
end

local IM={} -- InputMethods
function IM:SetValue(v) self.Value=v; fire(self,v) end

local KM={} -- KeyPickerMethods
function KM:IsActive()
    if not self.Value or self.Value=="..." then return false end
    local vk
    for code,name in pairs(KEY_NAMES) do if name==self.Value then vk=code; break end end
    if not vk then return false end
    if self.Mode=="Toggle" then return self.Active or false end
    return input.key_down(vk)
end
function KM:SetValue(v) self.Value=v; fire(self,v) end

local CPM={} -- ColorPickerMethods
function CPM:SetValue(v)
    self.Value=v; fire(self,v)
    local h,s,val = rgb_to_hsv(v)
    self.Hue=h; self.Saturation=s; self.ValueHSV=val; self.Alpha=v.a or 1
end
function CPM:InitWithTheme()
    if not self.Value or (self.Value.r==1 and self.Value.g==1 and self.Value.b==1) then
        self:SetValue(Library.AccentColor)
    end
end

