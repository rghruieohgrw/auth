-- ══════════════════════════════════════════════
--  Math / colour helpers
-- ══════════════════════════════════════════════
local function rgb_to_hsv(c)
    local r,g,b = c.r,c.g,c.b
    local mx = math.max(r,g,b); local mn = math.min(r,g,b)
    local h,s,v = 0,0,mx; local d = mx-mn
    if mx ~= 0 then s = d/mx else return 0,0,0 end
    if d > 1e-5 then
        if mx==r then h=(g-b)/d elseif mx==g then h=2+(b-r)/d else h=4+(r-g)/d end
        h=h/6; if h<0 then h=h+1 end
    end
    return h,s,v
end

local function hsv_to_rgb(h,s,v,a)
    local r,g,b
    local i=math.floor(h*6); local f=h*6-i
    local p=v*(1-s); local q=v*(1-f*s); local t=v*(1-(1-f)*s)
    i=i%6
    if i==0 then r,g,b=v,t,p elseif i==1 then r,g,b=q,v,p
    elseif i==2 then r,g,b=p,v,t elseif i==3 then r,g,b=p,q,v
    elseif i==4 then r,g,b=t,p,v elseif i==5 then r,g,b=v,p,q end
    return color(r,g,b,a or 1)
end

local function lerp(a,b,t) return a+(b-a)*t end

local function apply_alpha(col, mult)
    return color(col.r, col.g, col.b, (col.a or 1) * mult)
end

local function is_mouse_in_rect(pos, size)
    if not pos or not size then return false end
    local m = input.get_mouse_position()
    return m.x>=pos.x and m.x<=pos.x+size.x and m.y>=pos.y and m.y<=pos.y+size.y
end

local function get_clipped_text(text, max_w)
    if render.get_text_size(text).x <= max_w then return text end
    local t = text
    while render.get_text_size(t.."...").x > max_w and #t > 0 do t = string.sub(t,1,-2) end
    return t.."..."
end

local function draw_checkerboard(pos, size, sq)
    local c1=color(0.2,0.2,0.2,1); local c2=color(0.1,0.1,0.1,1)
    for y=0,math.ceil(size.y/sq)-1 do
        for x=0,math.ceil(size.x/sq)-1 do
            local p=pos:add(vector2(x*sq,y*sq))
            local s=vector2(math.min(sq,size.x-x*sq),math.min(sq,size.y-y*sq))
            render.add_rect_filled(p,p:add(s),(x+y)%2==0 and c1 or c2,0)
        end
    end
end

-- Stronger shadow: 10 layers, max alpha 0.38
local function draw_shadow(pos, size, radius, alpha_mult)
    for i = 1, 10 do
        local spread = i * 2.8
        local a = (1 - i/10) * 0.38 * (alpha_mult or 1)
        local sp = pos:add(vector2(-spread, -spread + spread*0.4))
        local ss = size:add(vector2(spread*2, spread*2))
        render.add_rect_filled(sp, sp:add(ss), color(0, 0, 0, a), radius + i)
    end
end

-- ══════════════════════════════════════════════
--  Scrollbar system  (unchanged logic)
-- ══════════════════════════════════════════════
local SB_WIDTH = 3; local SB_MIN_THUMB = 12; local SB_PAD = 4

local function get_scroll_state(id)
    if not Library.ScrollState[id] then
        Library.ScrollState[id] = { offset=0, dragging=false, drag_start_y=0, drag_start_off=0, _track_h=0, _content_h=0, _visible_h=0 }
    end
    return Library.ScrollState[id]
end

local function clamp_scroll(state, ch, vh)
    state.offset = math.max(0, math.min(state.offset, math.max(0, ch-vh)))
end

local function draw_scrollbar(track_pos, track_h, content_h, visible_h, state, alpha, mpressed, mdown, mp)
    local max_off = math.max(0, content_h - visible_h)
    if max_off <= 0 then return end
    state._track_h=track_h; state._content_h=content_h; state._visible_h=visible_h
    local ratio      = visible_h/content_h
    local thumb_h    = math.max(SB_MIN_THUMB, math.floor(track_h*ratio))
    local thumb_travel = track_h - thumb_h
    local sr         = max_off > 0 and state.offset/max_off or 0
    local thumb_y    = track_pos.y + math.floor(thumb_travel*sr)
    local ts         = vector2(SB_WIDTH, track_h)
    local tp         = vector2(track_pos.x, thumb_y)
    local ths        = vector2(SB_WIDTH, thumb_h)
    render.add_rect_filled(track_pos, track_pos:add(ts), apply_alpha(color(0.07,0.07,0.09,1), alpha), 2)
    local hov = is_mouse_in_rect(tp, ths)
    render.add_rect_filled(tp, tp:add(ths),
        (state.dragging or hov) and apply_alpha(Library.AccentColor, alpha) or apply_alpha(color(0.28,0.28,0.38,1), alpha), 2)
    if mpressed and hov and not Library.ActiveScrollbar then
        state.dragging=true; state.drag_start_y=mp.y; state.drag_start_off=state.offset
        Library.ActiveScrollbar=state
    end
    if mpressed and is_mouse_in_rect(track_pos, ts) and not hov and not Library.ActiveScrollbar then
        local rel = (mp.y - track_pos.y - thumb_h*0.5) / math.max(1, thumb_travel)
        state.offset = rel*max_off; clamp_scroll(state, content_h, visible_h)
    end
end

local function apply_clip_mask(clip_pos, clip_size, bg_color, alpha)
    render.add_rect_filled(clip_pos:subtract(vector2(0,64)), vector2(clip_pos.x+clip_size.x, clip_pos.y), apply_alpha(bg_color, alpha), 0)
    render.add_rect_filled(vector2(clip_pos.x, clip_pos.y+clip_size.y), clip_pos:add(vector2(clip_size.x, clip_size.y+64)), apply_alpha(bg_color, alpha), 0)
end

-- ══════════════════════════════════════════════
--  Element base / methods
-- ══════════════════════════════════════════════
local ElementMethods = {}
function ElementMethods:OnChanged(fn) self.OnChangedFunc=fn; return self end
function ElementMethods:SetTooltip(t) self.Tooltip=t; return self end

local function CreateElement(base, methods)
    if type(methods)=="table" then for k,v in pairs(methods) do base[k]=v end end
    return setmetatable(base, {__index=ElementMethods})
end

local ToggleMethods = {}
function ToggleMethods:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end

local SliderMethods = {}
function SliderMethods:SetValue(v)
    local rv = tonumber(string.format("%.".. (self.Rounding or 0) .."f", v))
    self.Value = math.clamp(rv, self.Min, self.Max)
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local DropdownMethods = {}
function DropdownMethods:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end
function DropdownMethods:SetValues(nv)
    self.Values=nv
    if not self.Multi and #nv > 0 then self:SetValue(nv[1]) end
end

local InputMethods = {}
function InputMethods:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end

local KeyPickerMethods = {}
function KeyPickerMethods:IsActive()
    if not self.Value or self.Value=="..." then return false end
    local vk = nil
    for code, name in pairs(KEY_NAMES) do if name==self.Value then vk=code; break end end
    if not vk then return false end
    if self.Mode=="Hold" then return input.key_down(vk)
    elseif self.Mode=="Toggle" then return self.Active or false end
    return input.key_down(vk)
end
function KeyPickerMethods:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end

local ColorPickerMethods = {}
function ColorPickerMethods:SetValue(v)
    self.Value=v
    if self.Callback then self.Callback(v) end
    if self.OnChangedFunc then self.OnChangedFunc(v) end
    local h,s,vv = rgb_to_hsv(v)
    self.Hue=h; self.Saturation=s; self.ValueHSV=vv; self.Alpha=v.a
end

