-- Simple Photon UI Library with Working Config System

local Library = {
    Windows = {},
    Toggles = {},
    Options = {},
    FontColor = color(0.9, 0.9, 0.95, 1),
    MainColor = color(0.12, 0.12, 0.15, 1),
    BackgroundColor = color(0.08, 0.08, 0.1, 1),
    AccentColor = color(0.4, 0.5, 0.9, 1),
    Notifications = {},
    Watermark = { Text = "Menu", Pos = vector2(15, 15), Visible = true },
    ConfigFolder = "photon_configs/",
    CurrentConfig = "",
    
    -- Config System
    GetConfigList = function(self)
        local configs = {}
        local manifest_file = self.ConfigFolder .. "manifest.json"
        if file.exists(manifest_file) then
            local data = file.read(manifest_file)
            local manifest = self:JSONToTable(data)
            if manifest and manifest.configs then
                for _, name in ipairs(manifest.configs) do
                    if file.exists(self.ConfigFolder .. name .. ".json") then
                        table.insert(configs, name)
                    end
                end
            end
        end
        table.sort(configs)
        return configs
    end,
    
    SaveConfig = function(self, name)
        if not file.exists(self.ConfigFolder) then
            file.write(self.ConfigFolder .. ".keep", "")
        end
        
        local config = { toggles = {}, options = {}, saved_at = get_unixtime() }
        
        for id, toggle in pairs(self.Toggles) do
            config.toggles[id] = toggle.Value
        end
        
        for id, opt in pairs(self.Options) do
            if opt.Type == "Slider" then
                config.options[id] = { type = "Slider", value = opt.Value }
            elseif opt.Type == "Dropdown" then
                config.options[id] = { type = "Dropdown", value = opt.Value }
            elseif opt.Type == "Input" then
                config.options[id] = { type = "Input", value = opt.Value }
            elseif opt.Type == "KeyPicker" then
                config.options[id] = { type = "KeyPicker", value = opt.Value, mode = opt.Mode }
            elseif opt.Type == "ColorPicker" then
                local c = opt.Value
                config.options[id] = { type = "ColorPicker", value = { r = c.r, g = c.g, b = c.b, a = c.a } }
            end
        end
        
        local json_str = self:TableToJSON(config)
        file.write(self.ConfigFolder .. name .. ".json", json_str)
        
        -- Update manifest
        local configs = self:GetConfigList()
        local found = false
        for _, n in ipairs(configs) do if n == name then found = true; break end end
        if not found then table.insert(configs, name) end
        table.sort(configs)
        file.write(self.ConfigFolder .. "manifest.json", self:TableToJSON({ configs = configs }))
        
        self.CurrentConfig = name
        self:Notify("Saved: " .. name)
        
        if self.ConfigDropdown then
            self.ConfigDropdown:SetValues(self:GetConfigList())
            self.ConfigDropdown:SetValue(name)
        end
        return true
    end,
    
    LoadConfig = function(self, name)
        local filename = self.ConfigFolder .. name .. ".json"
        if not file.exists(filename) then return false end
        
        local config = self:JSONToTable(file.read(filename))
        if not config then return false end
        
        for id, value in pairs(config.toggles or {}) do
            if self.Toggles[id] then self.Toggles[id]:SetValue(value) end
        end
        
        for id, data in pairs(config.options or {}) do
            if self.Options[id] then
                if data.type == "Slider" then
                    self.Options[id]:SetValue(data.value)
                elseif data.type == "Dropdown" then
                    self.Options[id]:SetValue(data.value)
                elseif data.type == "Input" then
                    self.Options[id]:SetValue(data.value)
                elseif data.type == "KeyPicker" then
                    self.Options[id]:SetValue(data.value)
                elseif data.type == "ColorPicker" then
                    local c = data.value
                    self.Options[id]:SetValue(color(c.r, c.g, c.b, c.a))
                end
            end
        end
        
        self.CurrentConfig = name
        self:Notify("Loaded: " .. name)
        if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
        return true
    end,
    
    DeleteConfig = function(self, name)
        file.write(self.ConfigFolder .. name .. ".json", "")
        local configs = self:GetConfigList()
        local new_configs = {}
        for _, n in ipairs(configs) do if n ~= name then table.insert(new_configs, n) end end
        file.write(self.ConfigFolder .. "manifest.json", self:TableToJSON({ configs = new_configs }))
        self:Notify("Deleted: " .. name)
        if self.ConfigDropdown then
            self.ConfigDropdown:SetValues(new_configs)
            self.ConfigDropdown:SetValue("")
        end
        return true
    end,
    
    ResetAll = function(self)
        for id, toggle in pairs(self.Toggles) do toggle:SetValue(false) end
        for id, opt in pairs(self.Options) do
            if opt.Type == "Slider" then
                opt:SetValue((opt.Min + opt.Max) / 2)
            elseif opt.Type == "Dropdown" and #opt.Values > 0 then
                opt:SetValue(opt.Values[1])
            elseif opt.Type == "Input" then
                opt:SetValue("")
            elseif opt.Type == "KeyPicker" then
                opt:SetValue("...")
            elseif opt.Type == "ColorPicker" then
                opt:SetValue(color(1, 1, 1, 1))
            end
        end
        self:Notify("Reset all settings")
    end,
    
    -- JSON Helpers
    TableToJSON = function(self, tbl)
        local function serialize(val)
            if type(val) == "string" then return '"' .. val:gsub('"', '\\"') .. '"'
            elseif type(val) == "number" then return tostring(val)
            elseif type(val) == "boolean" then return val and "true" or "false"
            elseif type(val) == "table" then
                local items = {}
                for k, v in pairs(val) do
                    table.insert(items, serialize(k) .. ":" .. serialize(v))
                end
                return "{" .. table.concat(items, ",") .. "}"
            else return "null"
            end
        end
        return serialize(tbl)
    end,
    
    JSONToTable = function(self, str)
        if not str or str == "" then return nil end
        local func, err = load("return " .. str, "json")
        if func then
            local success, result = pcall(func)
            if success then return result end
        end
        return nil
    end,
    
    Notify = function(self, text, duration)
        table.insert(self.Notifications, {
            Text = text, Duration = duration or 3, StartTime = get_unixtime(), Alpha = 1
        })
    end,
    
    SetWatermark = function(self, text)
        self.Watermark.Text = text
    end,
    
    -- Window Creation
    CreateWindow = function(self, config)
        local window = {
            Title = config.Title or "Window",
            Pos = config.Center and vector2(get_screen_size().x/2 - config.Size.x/2, get_screen_size().y/2 - config.Size.y/2) or vector2(100, 100),
            Size = config.Size or vector2(500, 400),
            Visible = config.AutoShow or false,
            Tabs = {},
            ActiveTab = nil,
        }
        
        function window:AddTab(name)
            local tab = { Name = name, Parent = window, Groups = {} }
            
            function tab:AddLeftGroupbox(name)
                local group = { Name = name, Side = "left", Parent = tab, Elements = {} }
                table.insert(self.Groups, group)
                return group
            end
            
            function tab:AddRightGroupbox(name)
                local group = { Name = name, Side = "right", Parent = tab, Elements = {} }
                table.insert(self.Groups, group)
                return group
            end
            
            function group:AddToggle(id, info)
                local el = { Type = "Toggle", Id = id, Text = info.Text, Value = info.Default or false, Tooltip = info.Tooltip, Height = 28 }
                function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                function el:OnChanged(f) self.OnChange = f; return self end
                table.insert(self.Elements, el)
                Library.Toggles[id] = el
                return el
            end
            
            function group:AddSlider(id, info)
                local el = { Type = "Slider", Id = id, Text = info.Text, Value = info.Default or 0, Min = info.Min or 0, Max = info.Max or 100, Suffix = info.Suffix or "", Height = 50 }
                function el:SetValue(v) self.Value = math.clamp(v, self.Min, self.Max); if self.OnChange then self.OnChange(self.Value) end end
                function el:OnChanged(f) self.OnChange = f; return self end
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end
            
            function group:AddDropdown(id, info)
                local el = { Type = "Dropdown", Id = id, Text = info.Text, Value = info.Values[1], Values = info.Values, Height = 44 }
                function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                function el:SetValues(v) self.Values = v; if #v > 0 then self:SetValue(v[1]) end end
                function el:OnChanged(f) self.OnChange = f; return self end
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end
            
            function group:AddInput(id, info)
                local el = { Type = "Input", Id = id, Text = info.Text, Value = info.Default or "", Placeholder = info.Placeholder or "", Height = 44 }
                function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                function el:OnChanged(f) self.OnChange = f; return self end
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end
            
            function group:AddKeyPicker(id, info)
                local el = { Type = "KeyPicker", Id = id, Text = info.Text, Value = info.Default or "None", Mode = info.Mode or "Hold", Height = 44, Active = false }
                function el:SetValue(v) self.Value = v end
                function el:IsActive() return self.Active end
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end
            
            function group:AddColorPicker(id, info)
                local el = { Type = "ColorPicker", Id = id, Text = info.Text, Value = info.Default or color(1,1,1,1), Height = 24 }
                function el:SetValue(v) self.Value = v end
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end
            
            function group:AddButton(info)
                local el = { Type = "Button", Text = info.Text, Func = info.Func, Height = 30, DoubleClick = info.DoubleClick or false }
                table.insert(self.Elements, el)
                return el
            end
            
            function group:AddDivider()
                table.insert(self.Elements, { Type = "Divider", Height = 14 })
                return group
            end
            
            function group:AddLabel(text)
                table.insert(self.Elements, { Type = "Label", Text = text, Height = 22 })
                return group
            end
            
            table.insert(window.Tabs, tab)
            if not window.ActiveTab then window.ActiveTab = tab end
            return tab
        end
        
        table.insert(self.Windows, window)
        return window
    end,
    
    -- Config Section Creator (WITH WORKING TEXTBOX)
    CreateConfigSection = function(self, groupbox)
        local configs = self:GetConfigList()
        
        -- Config dropdown
        local dropdown = groupbox:AddDropdown("config_dropdown", {
            Text = "Load Config",
            Values = configs,
            Tooltip = "Select a config to load"
        })
        self.ConfigDropdown = dropdown
        
        -- TEXTBOX for config name
        local name_input = groupbox:AddInput("config_name", {
            Text = "Config Name",
            Default = "",
            Placeholder = "Enter config name here...",
            Tooltip = "Type the name for your config"
        })
        
        groupbox:AddDivider()
        
        -- Save button (uses textbox value)
        groupbox:AddButton({
            Text = "Save Config",
            Func = function()
                local name = name_input.Value
                if name and name ~= "" then
                    self:SaveConfig(name)
                    name_input:SetValue("")
                else
                    self:Notify("Enter a config name first!")
                end
            end
        })
        
        -- Overwrite button
        groupbox:AddButton({
            Text = "Overwrite Selected",
            Func = function()
                local name = dropdown.Value
                if name and name ~= "" then
                    self:SaveConfig(name)
                    self:Notify("Overwrote: " .. name)
                else
                    self:Notify("No config selected")
                end
            end
        })
        
        groupbox:AddDivider()
        
        -- Delete button
        groupbox:AddButton({
            Text = "Delete Selected",
            DoubleClick = true,
            Func = function()
                local name = dropdown.Value
                if name and name ~= "" then
                    self:DeleteConfig(name)
                    name_input:SetValue("")
                else
                    self:Notify("No config selected")
                end
            end
        })
        
        -- Reset button
        groupbox:AddButton({
            Text = "Reset All",
            DoubleClick = true,
            Func = function()
                self:ResetAll()
            end
        })
        
        -- Refresh button
        groupbox:AddButton({
            Text = "Refresh List",
            Func = function()
                local updated = self:GetConfigList()
                dropdown:SetValues(updated)
                self:Notify("Config list refreshed")
            end
        })
        
        dropdown:OnChanged(function(value)
            if value and value ~= "" then
                self:LoadConfig(value)
                name_input:SetValue(value)
            end
        end)
        
        return dropdown
    end
}

-- Render Hook
hook.add("render", "library_render", function()
    -- Draw watermark
    if Library.Watermark.Visible then
        local ts = render.get_text_size(Library.Watermark.Text)
        local wsz = vector2(ts.x + 16, 24)
        render.add_rect_filled(Library.Watermark.Pos, Library.Watermark.Pos:add(wsz), Library.MainColor, 6)
        render.add_text(Library.Watermark.Pos:add(vector2(8, 4)), Library.Watermark.Text, Library.FontColor)
    end
    
    -- Draw windows
    for _, window in ipairs(Library.Windows) do
        if window.Visible then
            local pos = window.Pos
            local size = window.Size
            
            -- Window background
            render.add_rect_filled(pos, pos:add(size), Library.BackgroundColor, 10)
            render.add_text(pos:add(vector2(12, 8)), window.Title, Library.FontColor)
            
            -- Tabs
            local tab_y = pos.y + 35
            local tab_x = pos.x + 10
            
            for _, tab in ipairs(window.Tabs) do
                local tw = render.get_text_size(tab.Name).x + 20
                local is_active = (window.ActiveTab == tab)
                local bg = is_active and Library.AccentColor or color(0.15, 0.15, 0.2, 1)
                render.add_rect_filled(vector2(tab_x, tab_y), vector2(tab_x + tw, tab_y + 26), bg, 6)
                render.add_text(vector2(tab_x + 10, tab_y + 6), tab.Name, Library.FontColor)
                
                if not is_active and is_mouse_in_rect(vector2(tab_x, tab_y), vector2(tw, 26)) and input.is_key_pressed(0x01) then
                    window.ActiveTab = tab
                end
                tab_x = tab_x + tw + 5
            end
            
            -- Content area
            local content_y = tab_y + 35
            local content_height = size.y - content_y + pos.y - 10
            
            -- Draw active tab content
            if window.ActiveTab then
                local left_x = pos.x + 15
                local right_x = pos.x + size.x / 2 + 5
                local y_offset = content_y + 5
                
                for _, group in ipairs(window.ActiveTab.Groups) do
                    local gx = (group.Side == "left") and left_x or right_x
                    local gw = size.x / 2 - 25
                    
                    -- Calculate group height
                    local gh = 35
                    for _, el in ipairs(group.Elements) do
                        gh = gh + el.Height + 5
                    end
                    
                    -- Group background
                    render.add_rect_filled(vector2(gx, y_offset), vector2(gx + gw, y_offset + gh), color(0.1, 0.1, 0.13, 1), 6)
                    render.add_text(vector2(gx + 10, y_offset + 8), group.Name, Library.FontColor)
                    
                    local ey = y_offset + 35
                    for _, element in ipairs(group.Elements) do
                        if element.Type == "Toggle" then
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, Library.FontColor)
                            local sw_pos = vector2(gx + gw - 40, ey + 3)
                            render.add_rect_filled(sw_pos, sw_pos:add(vector2(30, 17)), element.Value and Library.AccentColor or color(0.2, 0.2, 0.25, 1), 8)
                            render.add_rect_filled(vector2(sw_pos.x + (element.Value and 15 or 2), sw_pos.y + 2), vector2(sw_pos.x + (element.Value and 28 or 13), sw_pos.y + 15), color(1,1,1,1), 6)
                            
                            if is_mouse_in_rect(vector2(gx + 10, ey), vector2(gw - 20, 25)) and input.is_key_pressed(0x01) then
                                element:SetValue(not element.Value)
                            end
                            
                        elseif element.Type == "Slider" then
                            local ratio = (element.Value - element.Min) / (element.Max - element.Min)
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, Library.FontColor)
                            render.add_text(vector2(gx + gw - 50, ey + 5), tostring(element.Value) .. element.Suffix, Library.FontColor)
                            render.add_rect_filled(vector2(gx + 10, ey + 25), vector2(gx + gw - 10, ey + 35), color(0.2, 0.2, 0.25, 1), 4)
                            render.add_rect_filled(vector2(gx + 10, ey + 25), vector2(gx + 10 + ((gw - 20) * ratio), ey + 35), Library.AccentColor, 4)
                            
                        elseif element.Type == "Dropdown" then
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, Library.FontColor)
                            render.add_rect_filled(vector2(gx + 10, ey + 22), vector2(gx + gw - 10, ey + 40), color(0.2, 0.2, 0.25, 1), 4)
                            render.add_text(vector2(gx + 15, ey + 28), tostring(element.Value), Library.FontColor)
                            
                        elseif element.Type == "Input" then
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, Library.FontColor)
                            render.add_rect_filled(vector2(gx + 10, ey + 22), vector2(gx + gw - 10, ey + 40), color(0.2, 0.2, 0.25, 1), 4)
                            local display = (element.Value ~= "") and element.Value or element.Placeholder
                            render.add_text(vector2(gx + 15, ey + 28), display, color(0.6, 0.6, 0.7, 1))
                            
                            if is_mouse_in_rect(vector2(gx + 10, ey + 22), vector2(gw - 20, 18)) and input.is_key_pressed(0x01) then
                                Library.ActiveInput = element
                            end
                            
                        elseif element.Type == "KeyPicker" then
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, Library.FontColor)
                            render.add_rect_filled(vector2(gx + 10, ey + 22), vector2(gx + gw - 10, ey + 40), color(0.2, 0.2, 0.25, 1), 4)
                            render.add_text(vector2(gx + (gw/2) - render.get_text_size(element.Value).x/2, ey + 28), element.Value, Library.FontColor)
                            
                        elseif element.Type == "ColorPicker" then
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, Library.FontColor)
                            render.add_rect_filled(vector2(gx + gw - 30, ey + 3), vector2(gx + gw - 10, ey + 19), element.Value, 4)
                            
                        elseif element.Type == "Button" then
                            render.add_rect_filled(vector2(gx + 10, ey), vector2(gx + gw - 10, ey + 24), color(0.2, 0.2, 0.25, 1), 6)
                            render.add_text(vector2(gx + (gw/2) - render.get_text_size(element.Text).x/2, ey + 6), element.Text, Library.FontColor)
                            
                            if is_mouse_in_rect(vector2(gx + 10, ey), vector2(gw - 20, 24)) and input.is_key_pressed(0x01) then
                                if element.DoubleClick then
                                    if get_unixtime() - (element.LastClick or 0) < 0.5 then
                                        if element.Func then element.Func() end
                                        element.LastClick = 0
                                    else
                                        element.LastClick = get_unixtime()
                                    end
                                else
                                    if element.Func then element.Func() end
                                end
                            end
                            
                        elseif element.Type == "Divider" then
                            render.add_line(vector2(gx + 10, ey + 7), vector2(gx + gw - 10, ey + 7), color(0.2, 0.2, 0.25, 1), 1)
                            
                        elseif element.Type == "Label" then
                            render.add_text(vector2(gx + 10, ey + 5), element.Text, color(0.6, 0.6, 0.7, 1))
                        end
                        
                        ey = ey + element.Height + 5
                    end
                    
                    y_offset = y_offset + gh + 10
                end
            end
        end
    end
    
    -- Draw notifications
    for i = #Library.Notifications, 1, -1 do
        local n = Library.Notifications[i]
        if get_unixtime() - n.StartTime > n.Duration then
            table.remove(Library.Notifications, i)
        else
            local nsz = vector2(render.get_text_size(n.Text).x + 20, 26)
            local np = vector2(get_screen_size().x - nsz.x - 10, 50 + (i-1) * 35)
            render.add_rect_filled(np, np:add(nsz), Library.MainColor, 6)
            render.add_text(np:add(vector2(10, 5)), n.Text, Library.FontColor)
        end
    end
end)

