local function rgb_to_hsv(c)
    local r,g,b = c.r,c.g,c.b
    local maxc = math.max(r,g,b); local minc = math.min(r,g,b)
    local h,s,v = 0,0,maxc; local diff = maxc-minc
    if maxc~=0 then s=diff/maxc else return 0,0,0 end
    if diff>1e-5 then
        if maxc==r then h=(g-b)/diff
        elseif maxc==g then h=2+(b-r)/diff
        else h=4+(r-g)/diff end
        h=h/6; if h<0 then h=h+1 end
    end
    return h,s,v
end

local function hsv_to_rgb(h,s,v,a)
    local r,g,b
    local i=math.floor(h*6); local f=h*6-i
    local p=v*(1-s); local q=v*(1-f*s); local t=v*(1-(1-f)*s)
    i=i%6
    if i==0 then r,g,b=v,t,p elseif i==1 then r,g,b=q,v,p
    elseif i==2 then r,g,b=p,v,t elseif i==3 then r,g,b=p,q,v
    elseif i==4 then r,g,b=t,p,v elseif i==5 then r,g,b=v,p,q end
    return color(r,g,b,a or 1)
end

local function lerp(a,b,t) return a+(b-a)*t end

local function apply_alpha(col, mult)
    return color(col.r, col.g, col.b, (col.a or 1) * mult)
end

local function is_mouse_in_rect(pos, size)
    if not pos or not size then return false end
    local m = input.get_mouse_position()
    return m.x>=pos.x and m.x<=pos.x+size.x and m.y>=pos.y and m.y<=pos.y+size.y
end

local function get_clipped_text(text, max_width)
    if render.get_text_size(text).x <= max_width then return text end
    local t = text
    while render.get_text_size(t.."...").x > max_width and #t>0 do t=string.sub(t,1,-2) end
    return t.."..."
end

local function draw_checkerboard(pos, size, sq)
    local c1=color(0.2,0.2,0.2,1); local c2=color(0.1,0.1,0.1,1)
    for y=0,math.ceil(size.y/sq)-1 do
        for x=0,math.ceil(size.x/sq)-1 do
            local p=pos:add(vector2(x*sq,y*sq))
            local s=vector2(math.min(sq,size.x-x*sq),math.min(sq,size.y-y*sq))
            render.add_rect_filled(p,p:add(s),(x+y)%2==0 and c1 or c2,0)
        end
    end
end

local SB_WIDTH       = 5
local SB_MIN_THUMB   = 16
local SB_PAD         = 3
local WHEEL_UP       = 0x100
local WHEEL_DOWN     = 0x101

local SCREEN = vector2(1920, 1080)

local function refresh_screen()
    SCREEN = get_screen_size()
end

local function clamp_position(pos, size, pad)
    pad = pad or Library.ScreenPadding
    local x = math.clamp(pos.x, pad, math.max(pad, SCREEN.x - size.x - pad))
    local y = math.clamp(pos.y, pad, math.max(pad, SCREEN.y - size.y - pad))
    return vector2(x, y)
end

local function fit_popup_position(anchor_pos, anchor_size, popup_size, gap)
    gap = gap or 2
    local pad = Library.ScreenPadding
    local below = anchor_pos:add(vector2(0, anchor_size.y + gap))
    local above = vector2(anchor_pos.x, anchor_pos.y - popup_size.y - gap)
    local pos = below
    if below.y + popup_size.y > SCREEN.y - pad then
        if above.y >= pad then pos = above
        else pos = clamp_position(below, popup_size, pad) end
    end
    pos = vector2(
        math.clamp(pos.x, pad, math.max(pad, SCREEN.x - popup_size.x - pad)),
        math.clamp(pos.y, pad, math.max(pad, SCREEN.y - popup_size.y - pad)))
    return pos
end

local function get_wheel_delta()
    if type(input.get_mouse_wheel) == "function" then
        return input.get_mouse_wheel()
    end
    if type(input.get_mouse_wheel_delta) == "function" then
        return input.get_mouse_wheel_delta()
    end
    if type(input.mouse_wheel) == "function" then
        return input.mouse_wheel()
    end
    local d = 0
    if input.is_key_pressed(WHEEL_UP) then d = d + 1 end
    if input.is_key_pressed(WHEEL_DOWN) then d = d - 1 end
    if input.is_key_pressed(0x21) then d = d + 1 end
    if input.is_key_pressed(0x22) then d = d - 1 end
    return d
end

local function register_scroll_zone(zone_pos, zone_size, state, content_h, visible_h)
    if content_h <= visible_h then return end
    table.insert(Library.ScrollHoverZones, {
        pos = zone_pos, size = zone_size,
        state = state, content_h = content_h, visible_h = visible_h,
    })
end

local function apply_wheel_scroll(delta)
    if delta == 0 or #Library.ScrollHoverZones == 0 then return end
    local best, best_area = nil, math.huge
    for _, zone in ipairs(Library.ScrollHoverZones) do
        if is_mouse_in_rect(zone.pos, zone.size) then
            local area = zone.size.x * zone.size.y
            if area < best_area then
                best_area = area; best = zone
            end
        end
    end
    if best then
        best.state.offset = best.state.offset - delta * Library.ScrollWheelSpeed
        clamp_scroll(best.state, best.content_h, best.visible_h)
    end
end

local function draw_shadow(pos, size, radius, alpha_mult)
    local pad = Library.ScreenPadding
    local max_spread = math.huge
    max_spread = math.min(max_spread, pos.x - pad)
    max_spread = math.min(max_spread, pos.y - pad)
    max_spread = math.min(max_spread, (SCREEN.x - pad) - (pos.x + size.x))
    max_spread = math.min(max_spread, (SCREEN.y - pad) - (pos.y + size.y))
    max_spread = math.max(0, max_spread)
    local layers = 8
    for i = 1, layers do
        local ideal = i * 3
        local spread = math.min(ideal, max_spread + 1)
        if spread <= 0 then break end
        local fade = spread / ideal
        local a = (1 - i / layers) * 0.18 * (alpha_mult or 1) * fade
        local sp = pos:add(vector2(-spread, -spread + spread * 0.5))
        local maxp = sp:add(size:add(vector2(spread * 2, spread * 2)))
        if maxp.x > 0 and maxp.y > 0 and sp.x < SCREEN.x and sp.y < SCREEN.y then
            render.add_rect_filled(sp, maxp, color(0, 0, 0, a), radius + i)
        end
    end
end

local function draw_liquid_glass(pos, size, rounding, alpha_mult, tint_override)
    local g = Library.Glass
    local tint = tint_override or g.Tint
    local alpha = alpha_mult or 1
    
    if not g.Enabled then
        render.add_rect_filled(pos, pos:add(size), apply_alpha(tint, alpha), rounding)
        render.add_rect(pos, pos:add(size), apply_alpha(Library.OutlineColor, alpha), rounding, 1)
        return
    end

    local blur_layers = math.floor(math.clamp(g.Blur, 0, 8))
    local base_a = (1 - g.Transparency) * alpha

    if blur_layers > 0 then
        for i = blur_layers, 1, -1 do
            local off = i * 0.75
            local ba = base_a * 0.035 * (i / blur_layers)
            render.add_rect_filled(
                pos:add(vector2(-off, -off)), 
                pos:add(size):add(vector2(off, off)), 
                color(tint.r, tint.g, tint.b, ba), 
                rounding + i
            )
        end
    end

    render.add_rect_filled(pos, pos:add(size), color(tint.r, tint.g, tint.b, base_a * 0.82), rounding)

    local shine_h = math.min(size.y * 0.42, 36)
    for i = 0, shine_h - 1 do
        local t = i / math.max(1, shine_h)
        local ha = g.Highlight.a * (1 - t) * alpha * 0.55
        render.add_line(
            pos:add(vector2(rounding, i + 1)), 
            vector2(pos.x + size.x - rounding, pos.y + i + 1), 
            color(g.Highlight.r, g.Highlight.g, g.Highlight.b, ha), 
            1
        )
    end

    local streak_a = g.Shine.a * alpha
    render.add_line(
        pos:add(vector2(size.x * 0.08, 2)), 
        pos:add(vector2(size.x * 0.52, shine_h)), 
        color(g.Shine.r, g.Shine.g, g.Shine.b, streak_a), 
        1
    )

    render.add_rect(pos, pos:add(size), apply_alpha(g.Border, alpha), rounding, 1)
    render.add_rect(
        pos:add(vector2(1, 1)), 
        pos:add(size):subtract(vector2(1, 1)), 
        color(1, 1, 1, 0.04 * alpha), 
        math.max(0, rounding - 1), 
        1
    )
end

local function get_scroll_state(id)
    if not Library.ScrollState[id] then
        Library.ScrollState[id] = {
            offset = 0, dragging = false, drag_start_y = 0, drag_start_off = 0,
        }
    end
    return Library.ScrollState[id]
end

local function clamp_scroll(state, content_h, visible_h)
    local max_off = math.max(0, content_h - visible_h)
    state.offset = math.max(0, math.min(state.offset, max_off))
end

local function draw_scrollbar(track_pos, track_h, content_h, visible_h, state, alpha, mpressed, mdown, mp)
    local max_off = math.max(0, content_h - visible_h)
    if max_off <= 0 then return end

    local ratio = visible_h / content_h
    local thumb_h = math.max(SB_MIN_THUMB, math.floor(track_h * ratio))
    local thumb_travel = track_h - thumb_h
    local scroll_ratio = (max_off > 0) and (state.offset / max_off) or 0
    local thumb_y = track_pos.y + math.floor(thumb_travel * scroll_ratio)

    local track_size = vector2(SB_WIDTH, track_h)
    local thumb_pos = vector2(track_pos.x, thumb_y)
    local thumb_size = vector2(SB_WIDTH, thumb_h)

    render.add_rect_filled(track_pos, track_pos:add(track_size), apply_alpha(color(0.08, 0.08, 0.10, 1), alpha), 3)

    local is_thumb_hov = is_mouse_in_rect(thumb_pos, thumb_size)
    local thumb_col = (state.dragging or is_thumb_hov) and apply_alpha(Library.AccentColor, alpha) or apply_alpha(color(0.35, 0.35, 0.45, 1), alpha)
    render.add_rect_filled(thumb_pos, thumb_pos:add(thumb_size), thumb_col, 3)

    if mpressed and is_thumb_hov and not Library.ActiveScrollbar then
        state.dragging = true
        state.drag_start_y = mp.y
        state.drag_start_off = state.offset
        Library.ActiveScrollbar = state
    end

    if mpressed and is_mouse_in_rect(track_pos, track_size) and not is_thumb_hov and not Library.ActiveScrollbar then
        local rel = (mp.y - track_pos.y - thumb_h / 2) / math.max(1, thumb_travel)
        state.offset = rel * max_off
        clamp_scroll(state, content_h, visible_h)
    end
end

local function apply_clip_mask(clip_pos, clip_size, bg_color, alpha)
    local fill = apply_alpha(bg_color, alpha)
    if Library.Glass.Enabled then
        local g = Library.Glass
        fill = color(
            lerp(g.Tint.r, bg_color.r, 0.35),
            lerp(g.Tint.g, bg_color.g, 0.35),
            lerp(g.Tint.b, bg_color.b, 0.35),
            (1 - g.Transparency) * (alpha or 1)
        )
    end
    local above_h = 60
    render.add_rect_filled(
        clip_pos:subtract(vector2(0, above_h)), 
        vector2(clip_pos.x + clip_size.x, clip_pos.y), 
        fill, 
        0
    )
    local below_h = 60
    render.add_rect_filled(
        vector2(clip_pos.x, clip_pos.y + clip_size.y), 
        clip_pos:add(vector2(clip_size.x, clip_size.y + below_h)), 
        fill, 
        0
    )
end

local ElementMethods = {}
-- (Rest of the library methods and functions continue here...)
function ElementMethods:OnChanged(func) self.OnChangedFunc = func; return self end
function ElementMethods:SetTooltip(text) self.Tooltip = text; return self end

local function CreateElement(base, methods)
    if type(methods)=="table" then for k,v in pairs(methods) do base[k]=v end end
    return setmetatable(base, {__index=ElementMethods})
end

local ToggleMethods = {}
function ToggleMethods:SetValue(val)
    self.Value=val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local SliderMethods = {}
function SliderMethods:SetValue(val)
    local rv = tonumber(string.format("%.".. (self.Rounding or 0) .."f", val))
    self.Value = math.clamp(rv, self.Min, self.Max)
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local DropdownMethods = {}
function DropdownMethods:SetValue(val)
    self.Value=val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end
function DropdownMethods:SetValues(new_values)
    self.Values = new_values
    if not self.Multi then
        if #new_values > 0 then self:SetValue(new_values[1]) end
    end
end

local InputMethods = {}
function InputMethods:SetValue(val)
    self.Value=val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local KeyPickerMethods = {}
function KeyPickerMethods:IsActive()
    if not self.Value or self.Value == "..." then return false end
    local vk = nil
    for code, name in pairs(KEY_NAMES) do
        if name == self.Value then vk = code; break end
    end
    if not vk then return false end
    if self.Mode == "Hold" then return input.key_down(vk)
    elseif self.Mode == "Toggle" then return self.Active or false end
    return input.key_down(vk)
end
function KeyPickerMethods:SetValue(val)
    self.Value=val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local ColorPickerMethods = {}
function ColorPickerMethods:SetValue(val)
    self.Value=val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
    local h,s,v = rgb_to_hsv(val)
    self.Hue,self.Saturation,self.ValueHSV = h,s,v
    self.Alpha = val.a
end

-- ─────────────────────────────────────────────
--  Window creation
-- ─────────────────────────────────────────────
function Library:CreateWindow(config)
    local window = {
        Title     = config.Title or "Window",
        Pos       = config.Center
            and clamp_position(
                vector2(get_screen_size().x/2-(config.Size.x/2), get_screen_size().y/2-(config.Size.y/2)),
                config.Size or vector2(580, 620))
            or  vector2(175, 50),
        Size      = config.Size or vector2(580, 620),
        Visible   = config.AutoShow or false,
        Tabs      = {},
        ActiveTab = nil,
        Alpha     = config.AutoShow and 1 or 0,
        TargetAlpha = config.AutoShow and 1 or 0,
        -- Tab container scroll state ID (set during render, unique per window)
        TabScrollId = nil,
    }

    function window:AddTab(name)
        local tab = {Name=name, Parent=window, Groupboxes={}}
        function tab:AddLeftGroupbox(name,info)  return self:AddGroupbox({Name=name,Side="Left",  Dependencies=info and info.Dependencies or nil}) end
        function tab:AddRightGroupbox(name,info) return self:AddGroupbox({Name=name,Side="Right", Dependencies=info and info.Dependencies or nil}) end
        function tab:AddGroupbox(info)
            local groupbox = {
                Name=info.Name, Side=info.Side or "Left",
                Parent=tab, Elements={}, Dependencies=info.Dependencies,
                -- MaxHeight: set this to limit the groupbox height and enable scrolling.
                -- nil = auto-size (original behaviour, no scroll).
                MaxHeight = info.MaxHeight or nil,
                -- Unique scroll ID, set lazily during render.
                _scroll_id = nil,
            }

            function groupbox:IsVisible()
                if not self.Dependencies then return true end
                for _,dep in ipairs(self.Dependencies) do
                    if dep[1] and dep[1].Value~=dep[2] then return false end
                end
                return true
            end

            function groupbox:SetMaxHeight(h)
                self.MaxHeight = h
            end

            function groupbox:AddToggle(id,info)
                local el=CreateElement({Id=id,Type="Toggle",Text=info.Text,Value=info.Default or false,Callback=info.Callback,Height=28,Tooltip=info.Tooltip,Risky=info.Risky,SwitchAnim=info.Default and 1 or 0},ToggleMethods)
                table.insert(self.Elements,el); Library.Toggles[id]=el; return el
            end
            function groupbox:AddSlider(id,info)
                local el=CreateElement({Id=id,Type="Slider",Text=info.Text,Value=info.Default or 0,Min=info.Min or 0,Max=info.Max or 100,Rounding=info.Rounding or 0,Suffix=info.Suffix or "",Callback=info.Callback,Height=50,Tooltip=info.Tooltip,
                    ThumbAnim=info.Default and (info.Default-(info.Min or 0))/((info.Max or 100)-(info.Min or 0)) or 0,BubbleAlpha=0},SliderMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function groupbox:AddButton(info)
                local el={Type="Button",Text=info.Text,Func=info.Func,Height=30,DoubleClick=info.DoubleClick,LastClick=0,Tooltip=info.Tooltip,HoverAnim=0}
                table.insert(self.Elements,el); return el
            end
            function groupbox:AddDropdown(id,info)
                local el=CreateElement({Id=id,Type="Dropdown",Text=info.Text,Value=info.Default and info.Values[info.Default] or info.Values[1],Values=info.Values,Open=false,Callback=info.Callback,Height=44,Multi=info.Multi,Tooltip=info.Tooltip,HoverAlpha=0,
                    -- MaxVisible: max items shown before the list itself scrolls.
                    MaxVisible=info.MaxVisible or 6,
                    _list_scroll_id=nil,
                },DropdownMethods)
                if info.Multi then el.Value=info.Default or {} end
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function groupbox:AddInput(id,info)
                local el=CreateElement({Id=id,Type="Input",Text=info.Text,Value=info.Default or "",Placeholder=info.Placeholder or "",Callback=info.Callback,Height=44,Tooltip=info.Tooltip},InputMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function groupbox:AddKeyPicker(id,info)
                local el=CreateElement({Id=id,Type="KeyPicker",Text=info.Text,Value=info.Default or "...",Callback=info.Callback,Picking=false,Height=44,Tooltip=info.Tooltip,Mode=info.Mode or "Hold",Active=false},KeyPickerMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function groupbox:AddColorPicker(id,info)
                local val=info.Default or color(1,1,1,1)
                local h,s,v=rgb_to_hsv(val)
                local el=CreateElement({Id=id,Type="ColorPicker",Text=info.Text,Value=val,Open=false,Callback=info.Callback,Height=24,Hue=h,Saturation=s,ValueHSV=v,Alpha=val.a,EnableAlpha=info.EnableAlpha,Tooltip=info.Tooltip,
                    layout={pos=vector2(0,0),size=vector2(0,0),picker_pos=vector2(0,0),picker_size=vector2(0,0)}},ColorPickerMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function groupbox:AddDivider(height)
                local el={Type="Divider",Height=height or 14}; table.insert(self.Elements,el); return el
            end
            function groupbox:AddLabel(text)
                local el={Type="Label",Text=text,Height=22}; table.insert(self.Elements,el); return el
            end

            table.insert(self.Groupboxes,groupbox); return groupbox
        end
        table.insert(window.Tabs,tab)
        if not window.ActiveTab then window.ActiveTab=tab end
        return tab
    end

    table.insert(Library.Windows,window)
    return window
end

