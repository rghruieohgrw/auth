-- ══════════════════════════════════════════════
--  Window creation
-- ══════════════════════════════════════════════
function Library:CreateWindow(config)
    local window = {
        Title       = config.Title or "Window",
        Pos         = config.Center
            and vector2(get_screen_size().x/2-(config.Size.x/2), get_screen_size().y/2-(config.Size.y/2))
            or  vector2(175, 50),
        Size        = config.Size or vector2(560, 580),
        Visible     = config.AutoShow or false,
        Tabs        = {},
        ActiveTab   = nil,
        Alpha       = config.AutoShow and 1 or 0,
        TargetAlpha = config.AutoShow and 1 or 0,
        TabScrollId = nil,
    }

    function window:AddTab(name)
        local tab = {Name=name, Parent=window, Groupboxes={}}

        function tab:AddLeftGroupbox(name, info)
            return self:AddGroupbox({Name=name, Side="Left",  Dependencies=info and info.Dependencies, MaxHeight=info and info.MaxHeight})
        end
        function tab:AddRightGroupbox(name, info)
            return self:AddGroupbox({Name=name, Side="Right", Dependencies=info and info.Dependencies, MaxHeight=info and info.MaxHeight})
        end

        function tab:AddGroupbox(info)
            local gb = {
                Name=info.Name, Side=info.Side or "Left",
                Parent=tab, Elements={}, Dependencies=info.Dependencies,
                MaxHeight=info.MaxHeight or nil, _scroll_id=nil,
            }

            function gb:IsVisible()
                if not self.Dependencies then return true end
                for _, dep in ipairs(self.Dependencies) do
                    if dep[1] and dep[1].Value ~= dep[2] then return false end
                end
                return true
            end
            function gb:SetMaxHeight(h) self.MaxHeight=h end

            -- Element factories with compact heights
            function gb:AddToggle(id, info)
                local el=CreateElement({Id=id,Type="Toggle",Text=info.Text,Value=info.Default or false,
                    Callback=info.Callback,Height=22,Tooltip=info.Tooltip,Risky=info.Risky,
                    SwitchAnim=info.Default and 1 or 0, HoverAlpha=0},ToggleMethods)
                table.insert(self.Elements,el); Library.Toggles[id]=el; return el
            end
            function gb:AddSlider(id, info)
                local def = info.Default or 0
                local mn  = info.Min or 0
                local mx  = info.Max or 100
                local el=CreateElement({Id=id,Type="Slider",Text=info.Text,Value=def,Min=mn,Max=mx,
                    Rounding=info.Rounding or 0,Suffix=info.Suffix or "",Callback=info.Callback,
                    Height=40,Tooltip=info.Tooltip,
                    ThumbAnim=(def-mn)/(mx-mn), BubbleAlpha=0, HoverAlpha=0},SliderMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function gb:AddButton(info)
                local el={Type="Button",Text=info.Text,Func=info.Func,Height=24,
                    DoubleClick=info.DoubleClick,LastClick=0,Tooltip=info.Tooltip,HoverAnim=0}
                table.insert(self.Elements,el); return el
            end
            function gb:AddDropdown(id, info)
                local el=CreateElement({Id=id,Type="Dropdown",Text=info.Text,
                    Value=info.Default and info.Values[info.Default] or info.Values[1],
                    Values=info.Values,Open=false,Callback=info.Callback,Height=36,
                    Multi=info.Multi,Tooltip=info.Tooltip,HoverAlpha=0,
                    MaxVisible=info.MaxVisible or 6, _dd_layout=nil, _list_scroll_id=nil},DropdownMethods)
                if info.Multi then el.Value=info.Default or {} end
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function gb:AddInput(id, info)
                local el=CreateElement({Id=id,Type="Input",Text=info.Text,Value=info.Default or "",
                    Placeholder=info.Placeholder or "",Callback=info.Callback,Height=36,
                    Tooltip=info.Tooltip, HoverAlpha=0},InputMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function gb:AddKeyPicker(id, info)
                local el=CreateElement({Id=id,Type="KeyPicker",Text=info.Text,Value=info.Default or "...",
                    Callback=info.Callback,Picking=false,Height=36,Tooltip=info.Tooltip,
                    Mode=info.Mode or "Hold",Active=false},KeyPickerMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function gb:AddColorPicker(id, info)
                local val=info.Default or color(1,1,1,1)
                local h,s,v=rgb_to_hsv(val)
                local el=CreateElement({Id=id,Type="ColorPicker",Text=info.Text,Value=val,Open=false,
                    Callback=info.Callback,Height=20,Hue=h,Saturation=s,ValueHSV=v,Alpha=val.a,
                    EnableAlpha=info.EnableAlpha,Tooltip=info.Tooltip,
                    layout={pos=vector2(0,0),size=vector2(0,0),picker_pos=vector2(0,0),picker_size=vector2(0,0)}},ColorPickerMethods)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end
            function gb:AddDivider(h)
                table.insert(self.Elements,{Type="Divider",Height=h or 10}); return self.Elements[#self.Elements]
            end
            function gb:AddLabel(text)
                table.insert(self.Elements,{Type="Label",Text=text,Height=18}); return self.Elements[#self.Elements]
            end

            table.insert(self.Groupboxes, gb); return gb
        end

        table.insert(window.Tabs, tab)
        if not window.ActiveTab then window.ActiveTab=tab end
        return tab
    end

    table.insert(Library.Windows, window)
    return window
end

