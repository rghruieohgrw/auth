        groupbox:AddButton({
            Text = "Refresh Config List",
            Func = function()
                local updated = self:GetConfigList()
                dropdown:SetValues(updated)
                self:Notify("Config list refreshed", 2)
            end,
            Tooltip = "Refresh the config dropdown list"
        })
        dropdown:OnChanged(function(value)
            if value and value ~= "" then self:LoadConfig(value) end
        end)
        return dropdown
    end,

    ShowSaveConfigDialog = function(self)
        self:Notify("Enter config name in console", 3)
        print("=== SAVE CONFIG ===")
        print("Type the config name and press Enter:")
        print("Config name prompt - use Library:SaveConfig('name') directly")
    end,

    LoadRemoteUI = function(self, url)
        print("[Library] Fetching remote UI:", url)
        http.get(url, function(body, statuscode)
            if statuscode == 200 then
                local success, result = pcall(load(body, "@remote_config"))
                if success and type(result) == "table" then
                    self:BuildFromConfig(result)
                    self:Notify("Remote UI loaded successfully!", 3)
                else
                    print("[Library] Execute error:", result)
                    self:Notify("Failed to load remote UI", 5)
                end
            else
                print("[Library] HTTP error:", statuscode)
                self:Notify("HTTP " .. tostring(statuscode) .. ": Failed to fetch", 5)
            end
        end)
    end,

    BuildFromConfig = function(self, config)
        if not config.windows then print("[Library] No windows found in config"); return end
        for _, win_config in ipairs(config.windows) do
            local window = self:CreateWindow(win_config)
            if win_config.tabs then
                for _, tab_config in ipairs(win_config.tabs) do
                    local tab = window:AddTab(tab_config.name)
                    if tab_config.groupboxes then
                        for _, gb_config in ipairs(tab_config.groupboxes) do
                            local groupbox = (gb_config.side == "Left") and
                                tab:AddLeftGroupbox(gb_config.name, {Dependencies = gb_config.dependencies}) or
                                tab:AddRightGroupbox(gb_config.name, {Dependencies = gb_config.dependencies})
                            if gb_config.elements then
                                for _, elem in ipairs(gb_config.elements) do
                                    self:AddElementToGroupbox(groupbox, elem)
                                end
                            end
                        end
                    end
                end
            end
        end
    end,

    AddElementToGroupbox = function(self, groupbox, elem)
        if elem.type == "Toggle" then
            groupbox:AddToggle(elem.id, {Text=elem.text,Default=elem.default or false,Tooltip=elem.tooltip,Risky=elem.risky or false})
        elseif elem.type == "Slider" then
            groupbox:AddSlider(elem.id, {Text=elem.text,Default=elem.default or 0,Min=elem.min or 0,Max=elem.max or 100,Rounding=elem.rounding or 0,Suffix=elem.suffix or "",Tooltip=elem.tooltip})
        elseif elem.type == "Button" then
            groupbox:AddButton({Text=elem.text,Func=function()
                if elem.func then
                    local fn, err = load(elem.func, "remote_func")
                    if fn then fn() else print("Button error:", err) end
                end
            end,Tooltip=elem.tooltip,DoubleClick=elem.double_click or false})
        elseif elem.type == "Dropdown" then
            groupbox:AddDropdown(elem.id, {Text=elem.text,Default=elem.default or 1,Values=elem.values or {},Tooltip=elem.tooltip,Multi=elem.multi or false})
        elseif elem.type == "Input" then
            groupbox:AddInput(elem.id, {Text=elem.text,Default=elem.default or "",Placeholder=elem.placeholder or "",Tooltip=elem.tooltip})
        elseif elem.type == "KeyPicker" then
            groupbox:AddKeyPicker(elem.id, {Text=elem.text,Default=elem.default or "...",Tooltip=elem.tooltip,Mode=elem.mode or "Hold"})
        elseif elem.type == "ColorPicker" then
            groupbox:AddColorPicker(elem.id, {Text=elem.text,
                Default=elem.default and color(elem.default.r,elem.default.g,elem.default.b,elem.default.a) or color(1,1,1,1),
                EnableAlpha=elem.enable_alpha or false,Tooltip=elem.tooltip})
        elseif elem.type == "Divider" then
            groupbox:AddDivider(elem.height)
        elseif elem.type == "Label" then
            groupbox:AddLabel(elem.text)
        end
    end
}

