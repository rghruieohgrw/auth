local function render_tooltip(alpha)
    if Library.Tooltip and Library.Tooltip.Text and alpha > 0.01 then
        local mp = input.get_mouse_position()
        local ts = render.get_text_size(Library.Tooltip.Text)
        local tsz = vector2(ts.x+14, ts.y+10)
        local tp = mp:add(vector2(14,14))
        if tp.x + tsz.x > SCREEN.x - Library.ScreenPadding then
            tp = vector2(mp.x - tsz.x - 14, tp.y)
        end
        if tp.y + tsz.y > SCREEN.y - Library.ScreenPadding then
            tp = vector2(tp.x, mp.y - tsz.y - 14)
        end
        tp = clamp_position(tp, tsz)
        draw_shadow(tp, tsz, 6, alpha)
        draw_liquid_glass(tp, tsz, 6, alpha, Library.MainColor)
        render.add_text(tp:add(vector2(7,5)), Library.Tooltip.Text, apply_alpha(Library.FontColor, alpha))
    end
end

