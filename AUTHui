-- ========== ELEMENT METHODS ==========
local ElementMethods = {}
function ElementMethods:OnChanged(func) self.OnChangedFunc = func; return self end
function ElementMethods:SetTooltip(text) self.Tooltip = text; return self end

local function CreateElement(base, methods)
    if methods then for k, v in pairs(methods) do base[k] = v end end
    return setmetatable(base, { __index = ElementMethods })
end

local ToggleMethods = {}
function ToggleMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local SliderMethods = {}
function SliderMethods:SetValue(val)
    local fmt = "%." .. (self.Rounding or 0) .. "f"
    self.Value = math.clamp(tonumber(string.format(fmt, val)), self.Min, self.Max)
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local DropdownMethods = {}
function DropdownMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end
function DropdownMethods:SetValues(new_values)
    self.Values = new_values
    if not self.Multi and new_values and #new_values > 0 then
        self:SetValue(new_values[1])
    end
end

local InputMethods = {}
function InputMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local KeyPickerMethods = {}
function KeyPickerMethods:IsActive()
    if not self.Value or self.Value == "..." then return false end
    local vk
    for code, name in pairs(KEY_NAMES) do
        if name == self.Value then vk = code; break end
    end
    if not vk then return false end
    if self.Mode == "Toggle" then return self.Active or false end
    return input.key_down(vk)
end
function KeyPickerMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local ColorPickerMethods = {}
function ColorPickerMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
    local h, s, v = rgb_to_hsv(val)
    self.Hue, self.Saturation, self.ValueHSV = h, s, v
    self.Alpha = val.a or 1
end
function ColorPickerMethods:InitWithTheme()
    if not self.Value or (self.Value.r == 1 and self.Value.g == 1 and self.Value.b == 1) then
        self:SetValue(Library.AccentColor)
    end
end

-- ========== BRUSH ICON ==========
function Library:LoadBrushIcon()
    if self.BrushLoaded then return end
    self.BrushLoaded = true
    local path = "icons/brush.png"
    if file.exists(path) then
        local tex = render.load_texture(path)
        if tex then self.BrushTexture = tex.id end
    else
        http.get("https://raw.githubusercontent.com/rghruieohgrw/visuals/refs/heads/main/color.png",
            function(body, status)
                if status == 200 then
                    if not file.exists("icons/") then file.write("icons/.keep", "") end
                    file.write(path, body, "binary")
                    local tex = render.load_texture(path)
                    if tex then self.BrushTexture = tex.id end
                end
            end)
    end
end

-- ========== WINDOW CREATION ==========
function Library:CreateWindow(config)
    local sz = config.Size or vector2(580, 620)
    local scr = get_screen_size()
    local window = {
        Title    = config.Title or "Window",
        Pos      = config.Center
                    and vector2(scr.x / 2 - sz.x / 2, scr.y / 2 - sz.y / 2)
                    or vector2(175, 50),
        Size     = sz,
        Visible  = config.AutoShow or false,
        Tabs     = {},
        ActiveTab = nil,
        Alpha    = config.AutoShow and 1 or 0,
        TargetAlpha = config.AutoShow and 1 or 0,
        Glass           = config.Glass or false,
        GlassColor      = config.GlassColor or config.Glasscolor or color(1, 1, 1, 1),
        Blur            = config.Blur or 0,
        GlassTransparency = config.GlassTransparency or config.Glasstransparency or 0.82,
    }

    function window:AddTab(name)
        local tab = { Name = name, Parent = window, Groupboxes = {} }

        function tab:AddLeftGroupbox(name, info)
            return self:AddGroupbox({ Name = name, Side = "Left",
                Dependencies = info and info.Dependencies })
        end
        function tab:AddRightGroupbox(name, info)
            return self:AddGroupbox({ Name = name, Side = "Right",
                Dependencies = info and info.Dependencies })
        end

        function tab:AddGroupbox(info)
            local groupbox = {
                Name = info.Name, Side = info.Side or "Left",
                Parent = tab, Elements = {}, Dependencies = info.Dependencies,
            }

            function groupbox:IsVisible()
                if not self.Dependencies then return true end
                for _, dep in ipairs(self.Dependencies) do
                    if dep[1] and dep[1].Value ~= dep[2] then return false end
                end
                return true
            end

            function groupbox:AddToggle(id, info)
                local el = CreateElement({
                    Id = id, Type = "Toggle", Text = info.Text,
                    Value = info.Default or false, Callback = info.Callback,
                    Height = 28, Tooltip = info.Tooltip, Risky = info.Risky,
                    SwitchAnim = info.Default and 1 or 0,
                }, ToggleMethods)
                table.insert(self.Elements, el); Library.Toggles[id] = el; return el
            end

            function groupbox:AddSlider(id, info)
                local mn = info.Min or 0; local mx = info.Max or 100
                local def = info.Default or 0
                local el = CreateElement({
                    Id = id, Type = "Slider", Text = info.Text,
                    Value = def, Min = mn, Max = mx,
                    Rounding = info.Rounding or 0, Suffix = info.Suffix or "",
                    Callback = info.Callback, Height = 50, Tooltip = info.Tooltip,
                    ThumbAnim = (def - mn) / (mx - mn), BubbleAlpha = 0,
                }, SliderMethods)
                table.insert(self.Elements, el); Library.Options[id] = el; return el
            end

            function groupbox:AddButton(info)
                local el = {
                    Type = "Button", Text = info.Text, Func = info.Func,
                    Height = 30, DoubleClick = info.DoubleClick,
                    LastClick = 0, Tooltip = info.Tooltip, HoverAnim = 0,
                }
                table.insert(self.Elements, el); return el
            end

            function groupbox:AddDropdown(id, info)
                local vals = info.Values or {}
                local def = info.Default and vals[info.Default] or vals[1]
                local el = CreateElement({
                    Id = id, Type = "Dropdown", Text = info.Text,
                    Value = info.Multi and (info.Default or {}) or def,
                    Values = vals, Open = false,
                    Callback = info.Callback, Height = 44,
                    Multi = info.Multi, Tooltip = info.Tooltip, HoverAlpha = 0,
                }, DropdownMethods)
                table.insert(self.Elements, el); Library.Options[id] = el; return el
            end

            function groupbox:AddInput(id, info)
                local el = CreateElement({
                    Id = id, Type = "Input", Text = info.Text,
                    Value = info.Default or "", Placeholder = info.Placeholder or "",
                    Callback = info.Callback, Height = 44, Tooltip = info.Tooltip,
                }, InputMethods)
                table.insert(self.Elements, el); Library.Options[id] = el; return el
            end

            function groupbox:AddKeyPicker(id, info)
                local el = CreateElement({
                    Id = id, Type = "KeyPicker", Text = info.Text,
                    Value = info.Default or "...", Callback = info.Callback,
                    Picking = false, Height = 44, Tooltip = info.Tooltip,
                    Mode = info.Mode or "Hold", Active = false,
                }, KeyPickerMethods)
                table.insert(self.Elements, el); Library.Options[id] = el; return el
            end

            function groupbox:AddColorPicker(id, info)
                local def = info.Default or Library.AccentColor
                local h, s, v = rgb_to_hsv(def)
                local el = CreateElement({
                    Id = id, Type = "ColorPicker", Text = info.Text,
                    Value = def, Open = false, Callback = info.Callback,
                    Height = 28,
                    Hue = h, Saturation = s, ValueHSV = v, Alpha = def.a or 1,
                    EnableAlpha = info.EnableAlpha or false,
                    Tooltip = info.Tooltip, HoverAnim = 0,
                    layout = {
                        pos = vector2(0, 0), size = vector2(0, 0),
                        picker_pos = vector2(0, 0), picker_size = vector2(0, 0),
                    },
                }, ColorPickerMethods)
                table.insert(self.Elements, el); Library.Options[id] = el
                el:InitWithTheme()
                return el
            end

            function groupbox:AddDivider(height)
                local el = { Type = "Divider", Height = height or 14 }
                table.insert(self.Elements, el); return el
            end

            function groupbox:AddLabel(text)
                local el = { Type = "Label", Text = text, Height = 22 }
                table.insert(self.Elements, el); return el
            end

            function groupbox:AddSpotifyToggle()
                return self:AddToggle("spotify_enabled", {
                    Text    = "Mini Player",
                    Default = false,
                    Tooltip = "Show Spotify mini player below watermark",
                    Callback = function(enabled)
                        Spotify.Enabled = enabled
                        if enabled then
                            Spotify:Connect()
                        else
                            Spotify:Disconnect()
                        end
                    end,
                })
            end

            table.insert(self.Groupboxes, groupbox); return groupbox
        end

        table.insert(window.Tabs, tab)
        if not window.ActiveTab then window.ActiveTab = tab end
        return tab
    end

    table.insert(Library.Windows, window)
    return window
end

-- ========== PUBLIC API ==========
function Library:Notify(text, duration)
    table.insert(self.Notifications, {
        Text = text, Duration = duration or 4, StartTime = tonumber(get_unixtime()) or 0,
        Alpha = 0, TargetAlpha = 1, OffsetX = 30, TargetOffsetX = 0,
    })
end
function Library:SetWatermark(text) self.Watermark.Text = text; self.Watermark.Visible = true end
function Library:OpenWindow(window)  window.Visible = true;  window.TargetAlpha = 1 end
function Library:CloseWindow(window) window.TargetAlpha = 0 end

Library.Spotify = Spotify

-- ========== TOOLTIP ==========
local function render_tooltip(alpha)
    if not Library.Tooltip or not Library.Tooltip.Text or alpha <= 0.01 then return end
    local mp  = input.get_mouse_position()
    local ts  = render.get_text_size(Library.Tooltip.Text)
    local tsz = vector2(ts.x + 14, ts.y + 10)
    local tp  = mp:add(vector2(14, 14))
    draw_shadow(tp, tsz, 6, alpha)
    if Library._GlobalGlass then
        glass_panel(tp, tsz, 8, alpha)
    else
        render.add_rect_filled(tp, tp:add(tsz), apply_alpha(Library.MainColor, alpha), 6)
        render.add_rect(tp, tp:add(tsz), apply_alpha(Library.OutlineColor, alpha), 6, 1)
    end
    render.add_text(tp:add(vector2(7, 5)), Library.Tooltip.Text, apply_alpha(Library.FontColor, alpha))
end

-- ========== WATERMARK ==========
local function draw_watermark()
    if not Library.Watermark.Visible then return end
    local ts  = render.get_text_size(Library.Watermark.Text)
    local wsz = vector2(ts.x + 16, 24)
    local pos = Library.Watermark.Pos
    draw_shadow(pos, wsz, 6, 1)
    if Library._GlobalGlass then
        glass_panel(pos, wsz, 8, 1)
    else
        render.add_rect_filled(pos, pos:add(wsz), Library.MainColor, 6)
        render.add_rect(pos, pos:add(wsz), Library.OutlineColor, 6, 1)
    end
    render.add_text(pos:add(vector2(8, 4)), Library.Watermark.Text, Library.FontColor)
end

-- ========== MAIN RENDER HOOK ==========
hook.add("render", "auth_photon_render", function()
    local anim = Library.Animation

    if anim.State == "FadingOut" then
        anim.CurrentAlpha = anim.CurrentAlpha - anim.Speed
        if anim.CurrentAlpha <= 0 then
            anim.CurrentAlpha = 0
            if anim.PendingTab then
                anim.PendingTab.Parent.ActiveTab = anim.PendingTab
                anim.PendingTab = nil
            end
            anim.State = "FadingIn"
        end
    elseif anim.State == "FadingIn" then
        anim.CurrentAlpha = anim.CurrentAlpha + anim.Speed
        if anim.CurrentAlpha >= 1 then anim.CurrentAlpha = 1; anim.State = "Idle" end
    end

    Library.Hue = (Library.Hue + 0.002) % 1
    Library.CurrentRainbowColor = hsv_to_rgb(Library.Hue, 0.8, 1)

    local accent   = Library.AccentColor
    local mp       = input.get_mouse_position()
    local mpressed = input.is_key_pressed(0x01)
    local mdown    = input.key_down(0x01)

    Library.ModalOpen = Library.OpenedDropdown or Library.ActiveColorPicker
        or Library.ActiveKeyPicker or Library.ActiveInput or Library.RightClickMenu

    Library._GlobalGlass = false
    for _, w in ipairs(Library.Windows) do
        if w.Glass then
            Library._GlobalGlass       = true
            Library._GlobalGlassColor  = w.GlassColor
            Library._GlobalBlur        = w.Blur
            Library._GlobalGlassTrans  = w.GlassTransparency
            break
        end
    end

    if mpressed and Library.ModalOpen then
        if Library.OpenedDropdown then
            local dd = Library.OpenedDropdown
            if dd.Layout and not (
                is_mouse_in_rect(dd.Layout.pos, dd.Layout.size) or
                is_mouse_in_rect(dd.Layout.list_pos, dd.Layout.list_size))
            then
                dd.Open = false; Library.OpenedDropdown = nil
            end
        end
        if Library.ActiveColorPicker then
            local acp = Library.ActiveColorPicker
            if not is_mouse_in_rect(acp.layout.picker_pos, acp.layout.picker_size) then
                acp.obj.Open = false; Library.ActiveColorPicker = nil
            end
        end
        if Library.ActiveKeyPicker then
            local akp = Library.ActiveKeyPicker
            if not is_mouse_in_rect(akp.layout.pos, akp.layout.size) then
                akp.obj.Picking = false; Library.ActiveKeyPicker = nil
            end
        end
        if Library.ActiveInput then
            if not is_mouse_in_rect(Library.ActiveInput.layout.pos, Library.ActiveInput.layout.size) then
                Library.ActiveInput = nil
            end
        end
    end

    if mpressed and Library.RightClickMenu then
        local rcm = Library.RightClickMenu
        if not is_mouse_in_rect(rcm.pos, rcm.size) then
            Library.RightClickMenu = nil
        end
    end

    if Library.DraggingWindow then
        if mdown then Library.DraggingWindow.Pos = mp:subtract(Library.DragOffset)
        else Library.DraggingWindow = nil end
    end

    if Library.ActiveSlider then
        if mdown then
            local s, l = Library.ActiveSlider.obj, Library.ActiveSlider.layout
            local r = (math.clamp(mp.x, l.pos.x, l.pos.x + l.size.x) - l.pos.x) / l.size.x
            s:SetValue(s.Min + (s.Max - s.Min) * r)
        else Library.ActiveSlider = nil end
    end

    if Library.ActiveColorPicker and mdown then
        local cp     = Library.ActiveColorPicker.obj
        local layout = Library.ActiveColorPicker.layout
        if is_mouse_in_rect(layout.sv_pos, layout.sv_size) then
            cp.Saturation = math.clamp((mp.x - layout.sv_pos.x) / layout.sv_size.x, 0, 1)
            cp.ValueHSV   = 1 - math.clamp((mp.y - layout.sv_pos.y) / layout.sv_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        elseif layout.hue_pos and is_mouse_in_rect(layout.hue_pos, layout.hue_size) then
            cp.Hue = math.clamp((mp.y - layout.hue_pos.y) / layout.hue_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        elseif cp.EnableAlpha and layout.alpha_pos and is_mouse_in_rect(layout.alpha_pos, layout.alpha_size) then
            cp.Alpha = math.clamp((mp.y - layout.alpha_pos.y) / layout.alpha_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        end
    end

    local wm_ts   = render.get_text_size(Library.Watermark.Text)
    local wm_size = vector2(wm_ts.x + 16, 24)
    if not Library.DraggingWatermark and mpressed
        and is_mouse_in_rect(Library.Watermark.Pos, wm_size)
    then
        Library.DraggingWatermark = true
        Library.DragOffset = mp:subtract(Library.Watermark.Pos)
    end
    if Library.DraggingWatermark then
        if mdown then Library.Watermark.Pos = mp:subtract(Library.DragOffset)
        else Library.DraggingWatermark = false end
    end

    local can_interact = not Library.ModalOpen and anim.State == "Idle"
    Library.Tooltip = nil

    -- ========== RENDER WINDOWS ==========
    for _, window in ipairs(Library.Windows) do
        if window.Visible then
            window.Alpha = window.Alpha + (window.TargetAlpha - window.Alpha) * 0.07
            local wa = window.Alpha
            if wa < 0.01 then goto continue_window end

            local glass = window.Glass
            local title_bar_size = vector2(window.Size.x, 34)
            if not Library.DraggingWindow and mpressed
                and is_mouse_in_rect(window.Pos, title_bar_size) and not Library.ModalOpen
            then
                Library.DraggingWindow = window
                Library.DragOffset = mp:subtract(window.Pos)
            end

            draw_shadow(window.Pos, window.Size, 12, wa)
            if glass then
                glass_panel(window.Pos, window.Size, 12, wa)
            else
                render.add_rect_filled(window.Pos, window.Pos:add(window.Size),
                    apply_alpha(Library.BackgroundColor, wa), 10)
                render.add_rect(window.Pos, window.Pos:add(window.Size),
                    apply_alpha(Library.OutlineColor, wa), 10, 1)
            end
            render.add_text(window.Pos:add(vector2(14, 10)), window.Title, apply_alpha(Library.FontColor, wa))

            local msp = window.Pos:add(vector2(12, 36))
            local mss = vector2(window.Size.x - 24, window.Size.y - 48)
            render.add_rect_filled(msp, msp:add(mss),
                glass and color(0, 0, 0, 0.08 * wa) or apply_alpha(Library.BackgroundColor, wa), 8)

            local tab_area = msp:add(vector2(4, 4))
            local tab_x = 0
            for _, tab in ipairs(window.Tabs) do
                local tw  = render.get_text_size(tab.Name).x + 20
                local tp2 = tab_area:add(vector2(tab_x, 0))
                local ts2 = vector2(tw, 24)
                local is_active = (anim.PendingTab or window.ActiveTab) == tab
                local tab_bg, tab_fg
                if glass then
                    tab_bg = is_active and color(1, 1, 1, 0.18 * wa) or color(1, 1, 1, 0.04 * wa)
                    tab_fg = is_active and apply_alpha(Library.FontColor, wa) or apply_alpha(Library.SecondaryFontColor, wa)
                else
                    tab_bg = is_active and apply_alpha(Library.FontColor, wa) or apply_alpha(color(0.1, 0.1, 0.13, 1), wa)
                    tab_fg = is_active and apply_alpha(Library.BackgroundColor, wa) or apply_alpha(Library.SecondaryFontColor, wa)
                end
                render.add_rect_filled(tp2, tp2:add(ts2), tab_bg, 6)
                if glass and is_active then
                    render.add_rect(tp2, tp2:add(ts2), color(1, 1, 1, 0.22 * wa), 6, 1)
                end
                render.add_text(tp2:add(vector2(10, 4)), tab.Name, tab_fg)
                if not Library.DraggingWindow and mpressed
                    and is_mouse_in_rect(tp2, ts2) and anim.State == "Idle"
                    and window.ActiveTab ~= tab
                then
                    anim.State = "FadingOut"; anim.PendingTab = tab
                end
                tab_x = tab_x + tw + 6
            end

            if window.ActiveTab and anim.CurrentAlpha > 0 then
                local op = anim.CurrentAlpha * wa
                local content_area = msp:add(vector2(4, 40))
                local left_y, right_y = 0, 0

                for _, groupbox in ipairs(window.ActiveTab.Groupboxes) do
                    if groupbox:IsVisible() then
                        local is_left   = groupbox.Side == "Left"
                        local side_off  = is_left and 0 or (window.Size.x / 2 - 14)
                        local y_off     = is_left and left_y or right_y
                        local group_pos = content_area:add(vector2(side_off, y_off))
                        local group_w   = window.Size.x / 2 - 20

                        local content_h = 32
                        for _, e in ipairs(groupbox.Elements) do content_h = content_h + e.Height end
                        local group_size = vector2(group_w, content_h)

                        draw_shadow(group_pos, group_size, 8, op * 0.5)
                        if glass then
                            glass_panel(group_pos, group_size, 10, op)
                        else
                            render.add_rect_filled(group_pos, group_pos:add(group_size),
                                apply_alpha(Library.MainColor, op), 8)
                            render.add_rect(group_pos, group_pos:add(group_size),
                                apply_alpha(Library.OutlineColor, op), 8, 1)
                        end
                        render.add_text(group_pos:add(vector2(10, 8)), groupbox.Name, apply_alpha(Library.FontColor, op))

                        local element_y = 30
                        for _, element in ipairs(groupbox.Elements) do
                            local ep  = group_pos:add(vector2(10, element_y))
                            local efw = vector2(group_w - 20, element.Height)

                            if element.Tooltip and is_mouse_in_rect(ep, efw) then
                                Library.Tooltip = { Text = element.Tooltip, Element = element }
                            end

                            if element.Type == "Toggle" then
                                local target = element.Value and 1 or 0
                                element.SwitchAnim = element.SwitchAnim + (target - element.SwitchAnim) * 0.07
                                local sw_pos  = ep:add(vector2(0, 5))
                                local sw_size = vector2(30, 17)
                                local bk = color(0.08, 0.08, 0.10, 1)
                                local fill = color(
                                    lerp(bk.r, accent.r, element.SwitchAnim),
                                    lerp(bk.g, accent.g, element.SwitchAnim),
                                    lerp(bk.b, accent.b, element.SwitchAnim), 1)
                                render.add_rect_filled(sw_pos, sw_pos:add(sw_size), apply_alpha(fill, op), 9)
                                render.add_rect(sw_pos, sw_pos:add(sw_size), apply_alpha(Library.OutlineColor, op), 9, 1)
                                local kx = lerp(sw_pos.x + 2, sw_pos.x + sw_size.x - 13, element.SwitchAnim)
                                local kc = color(
                                    lerp(0.5, Library.BackgroundColor.r, element.SwitchAnim),
                                    lerp(0.5, Library.BackgroundColor.g, element.SwitchAnim),
                                    lerp(0.55, Library.BackgroundColor.b, element.SwitchAnim), 1)
                                render.add_rect_filled(
                                    vector2(kx, sw_pos.y + 2), vector2(kx + 11, sw_pos.y + 13),
                                    apply_alpha(kc, op), 6)
                                render.add_text(ep:add(vector2(38, 4)), element.Text,
                                    element.Risky and apply_alpha(Library.RiskColor, op) or apply_alpha(Library.FontColor, op))
                                if not Library.DraggingWindow and mpressed
                                    and is_mouse_in_rect(ep, vector2(group_w - 20, 20)) and can_interact
                                then
                                    element:SetValue(not element.Value)
                                end

                            elseif element.Type == "Slider" then
                                local ratio = (element.Value - element.Min) / (element.Max - element.Min)
                                element.ThumbAnim = element.ThumbAnim + (ratio - element.ThumbAnim) * 0.08
                                local s_pos  = ep:add(vector2(0, 22))
                                local s_size = vector2(group_w - 20, 14)
                                local tx     = s_pos.x + s_size.x * element.ThumbAnim
                                local hover  = is_mouse_in_rect(s_pos, s_size)
                                local drag   = Library.ActiveSlider and Library.ActiveSlider.obj == element
                                element.BubbleAlpha = element.BubbleAlpha
                                    + (((hover or drag) and 1 or 0) - element.BubbleAlpha) * 0.08
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                render.add_rect_filled(s_pos, s_pos:add(s_size), apply_alpha(Library.BackgroundColor, op), 7)
                                render.add_rect(s_pos, s_pos:add(s_size), apply_alpha(Library.OutlineColor, op), 7, 1)
                                if element.ThumbAnim > 0.001 then
                                    local fw = math.max(0, s_size.x * element.ThumbAnim - 2)
                                    render.add_rect_filled(s_pos:add(vector2(2, 2)),
                                        s_pos:add(vector2(2 + fw, s_size.y - 2)), apply_alpha(accent, op), 5)
                                end
                                render.add_rect_filled(
                                    vector2(tx - 4, s_pos.y - 2), vector2(tx + 4, s_pos.y + s_size.y + 2),
                                    apply_alpha(Library.FontColor, op), 4)
                                if element.BubbleAlpha > 0.01 then
                                    local vt   = tostring(element.Value) .. element.Suffix
                                    local bw   = render.get_text_size(vt).x + 10
                                    local bp   = vector2(tx - bw / 2, s_pos.y - 22)
                                    local ba   = element.BubbleAlpha * op
                                    render.add_rect_filled(bp, bp:add(vector2(bw, 16)), apply_alpha(Library.MainColor, ba), 4)
                                    render.add_rect(bp, bp:add(vector2(bw, 16)), apply_alpha(Library.OutlineColor, ba), 4, 1)
                                    render.add_text(bp:add(vector2(5, 1)), vt, apply_alpha(Library.FontColor, ba))
                                end
                                if not Library.DraggingWindow and not Library.ActiveSlider
                                    and mpressed and is_mouse_in_rect(s_pos, s_size) and can_interact
                                then
                                    Library.ActiveSlider = { obj = element, layout = { pos = s_pos, size = s_size } }
                                end

                            elseif element.Type == "Button" then
                                local b_pos  = ep
                                local b_size = vector2(group_w - 20, 24)
                                local hov    = is_mouse_in_rect(b_pos, b_size)
                                element.HoverAnim = element.HoverAnim + ((hov and 1 or 0) - element.HoverAnim) * 0.07
                                local ha = element.HoverAnim
                                local bg, fg
                                if glass then
                                    bg = color(1, 1, 1, lerp(0.06, 0.16, ha) * op)
                                    fg = apply_alpha(Library.FontColor, op)
                                else
                                    bg = color(
                                        lerp(Library.BackgroundColor.r, Library.FontColor.r, ha),
                                        lerp(Library.BackgroundColor.g, Library.FontColor.g, ha),
                                        lerp(Library.BackgroundColor.b, Library.FontColor.b, ha), 1)
                                    fg = color(
                                        lerp(Library.FontColor.r, Library.BackgroundColor.r, ha),
                                        lerp(Library.FontColor.g, Library.BackgroundColor.g, ha),
                                        lerp(Library.FontColor.b, Library.BackgroundColor.b, ha), 1)
                                end
                                render.add_rect_filled(b_pos, b_pos:add(b_size), apply_alpha(bg, op), 6)
                                render.add_rect(b_pos, b_pos:add(b_size),
                                    glass and color(1, 1, 1, lerp(0.08, 0.20, ha) * op)
                                          or apply_alpha(Library.OutlineColor, op), 6, 1)
                                local btn_text = element.Text
                                if element.DoubleClick and element.LastClick ~= 0
                                    and get_unixtime() - element.LastClick < 1
                                then btn_text = "Confirm?" end
                                local clip = get_clipped_text(btn_text, b_size.x - 12)
                                render.add_text(
                                    b_pos:add(vector2(b_size.x / 2 - render.get_text_size(clip).x / 2, 4)),
                                    clip, apply_alpha(fg, op))
                                if not Library.DraggingWindow and mpressed
                                    and is_mouse_in_rect(b_pos, b_size) and can_interact
                                then
                                    if element.DoubleClick then
                                        if element.LastClick ~= 0 and get_unixtime() - element.LastClick < 1 then
                                            if element.Func then element.Func() end
                                            element.LastClick = 0
                                        else element.LastClick = get_unixtime() end
                                    else
                                        if element.Func then element.Func() end
                                    end
                                end

                            elseif element.Type == "Dropdown" then
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                local d_pos  = ep:add(vector2(0, 18))
                                local d_size = vector2(group_w - 20, 22)
                                element.Layout = {
                                    pos = d_pos, size = d_size,
                                    list_pos = vector2(0, 0), list_size = vector2(0, 0),
                                }
                                element.HoverAlpha = element.HoverAlpha
                                    + ((is_mouse_in_rect(d_pos, d_size) and 1 or 0) - element.HoverAlpha) * 0.07
                                local bg
                                if glass then
                                    bg = color(1, 1, 1, lerp(0.05, 0.12, element.HoverAlpha) * op)
                                else
                                    bg = color(
                                        lerp(Library.BackgroundColor.r, Library.MainColor.r, element.HoverAlpha),
                                        lerp(Library.BackgroundColor.g, Library.MainColor.g, element.HoverAlpha),
                                        lerp(Library.BackgroundColor.b, Library.MainColor.b, element.HoverAlpha), 1)
                                end
                                render.add_rect_filled(d_pos, d_pos:add(d_size), apply_alpha(bg, op), 6)
                                render.add_rect(d_pos, d_pos:add(d_size),
                                    glass and color(1, 1, 1, 0.12 * op)
                                          or apply_alpha(Library.OutlineColor, op), 6, 1)
                                local disp
                                if element.Multi then
                                    local sel = {}
                                    for k, v in pairs(element.Value) do if v then table.insert(sel, k) end end
                                    disp = #sel > 0 and table.concat(sel, ", ") or "None"
                                else
                                    disp = tostring(element.Value)
                                end
                                render.add_text(d_pos:add(vector2(8, 3)),
                                    get_clipped_text(disp, d_size.x - 24), apply_alpha(Library.FontColor, op))
                                render.add_triangle_filled(
                                    d_pos:add(vector2(d_size.x - 13, 8)),
                                    d_pos:add(vector2(d_size.x - 5,  8)),
                                    d_pos:add(vector2(d_size.x - 9,  15)),
                                    apply_alpha(Library.FontColor, op))
                                if not Library.DraggingWindow and mpressed
                                    and is_mouse_in_rect(d_pos, d_size) and can_interact
                                then
                                    element.Open = not element.Open
                                    Library.OpenedDropdown = element.Open and element or nil
                                end

                            elseif element.Type == "Input" then
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                local i_pos  = ep:add(vector2(0, 18))
                                local i_size = vector2(group_w - 20, 22)
                                element.layout = { pos = i_pos, size = i_size }
                                local active = Library.ActiveInput == element
                                render.add_rect_filled(i_pos, i_pos:add(i_size), apply_alpha(Library.BackgroundColor, op), 6)
                                render.add_rect(i_pos, i_pos:add(i_size),
                                    active and apply_alpha(accent, op) or apply_alpha(Library.OutlineColor, op), 6, 1)
                                local dt = #element.Value > 0 and element.Value or element.Placeholder
                                local tc = #element.Value > 0 and Library.FontColor or color(0.35, 0.35, 0.4, 1)
                                render.add_text(i_pos:add(vector2(8, 3)),
                                    get_clipped_text(dt, i_size.x - 14), apply_alpha(tc, op))
                                if active and (math.floor(get_unixtime() * 2) % 2 == 0) then
                                    local cw = render.get_text_size(get_clipped_text(element.Value, i_size.x - 14)).x
                                    render.add_line(i_pos:add(vector2(8 + cw, 5)),
                                        i_pos:add(vector2(8 + cw, i_size.y - 5)), apply_alpha(Library.FontColor, op), 1)
                                end
                                if not Library.DraggingWindow and mpressed
                                    and is_mouse_in_rect(i_pos, i_size) and can_interact
                                then
                                    Library.ActiveInput = element
                                end

                            elseif element.Type == "KeyPicker" then
                                render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                local k_pos  = ep:add(vector2(0, 18))
                                local k_size = vector2(group_w - 20, 22)
                                element.layout = { pos = k_pos, size = k_size }
                                render.add_rect_filled(k_pos, k_pos:add(k_size), apply_alpha(Library.BackgroundColor, op), 6)
                                render.add_rect(k_pos, k_pos:add(k_size),
                                    element.Picking and apply_alpha(accent, op) or apply_alpha(Library.OutlineColor, op), 6, 1)
                                local mtag = element.Mode == "Hold" and " [H]" or element.Mode == "Toggle" and " [T]" or ""
                                local ktext = element.Picking and "press a key..." or (element.Value .. mtag)
                                render.add_text(
                                    k_pos:add(vector2(k_size.x / 2 - render.get_text_size(ktext).x / 2, 3)),
                                    ktext, apply_alpha(Library.FontColor, op))
                                if not Library.DraggingWindow and mpressed
                                    and is_mouse_in_rect(k_pos, k_size) and can_interact
                                then
                                    element.Picking = true
                                    Library.ActiveKeyPicker = { obj = element, layout = element.layout }
                                end
                                if not Library.DraggingWindow and input.is_key_pressed(0x02)
                                    and is_mouse_in_rect(k_pos, k_size) and can_interact
                                then
                                    local rcm_w = 110; local rcm_h = 3 * 24 + 8
                                    Library.RightClickMenu = {
                                        obj  = element,
                                        pos  = mp,
                                        size = vector2(rcm_w, rcm_h),
                                        Alpha = 0,
                                    }
                                end

                            elseif element.Type == "ColorPicker" then
                                local row_w      = group_w - 20
                                local btn_sz     = vector2(22, 22)
                                local swatch_w   = 20
                                local label_y = ep.y + btn_sz.y / 2 - render.get_text_size(element.Text).y / 2
                                render.add_text(vector2(ep.x, label_y), element.Text,
                                    apply_alpha(Library.SecondaryFontColor, op))
                                local sw_pos  = vector2(ep.x + row_w - swatch_w - 4 - btn_sz.x, ep.y + 2)
                                local sw_size = vector2(swatch_w, btn_sz.y - 4)
                                render.add_rect_filled(sw_pos, sw_pos:add(sw_size),
                                    color(element.Value.r, element.Value.g, element.Value.b, op), 4)
                                render.add_rect(sw_pos, sw_pos:add(sw_size), color(0, 0, 0, 0.35 * op), 4, 1)
                                local ico_pos = vector2(ep.x + row_w - btn_sz.x, ep.y)
                                element.layout.pos  = ico_pos
                                element.layout.size = btn_sz
                                local hov    = is_mouse_in_rect(ico_pos, btn_sz)
                                local is_open = element.Open
                                element.HoverAnim = element.HoverAnim
                                    + (((hov or is_open) and 1 or 0) - element.HoverAnim) * 0.10
                                local btn_bg
                                if glass then
                                    btn_bg = color(1, 1, 1, lerp(0.06, 0.20, element.HoverAnim) * op)
                                else
                                    btn_bg = color(
                                        lerp(0.10, accent.r * 0.4 + 0.08, element.HoverAnim),
                                        lerp(0.10, accent.g * 0.4 + 0.08, element.HoverAnim),
                                        lerp(0.12, accent.b * 0.4 + 0.12, element.HoverAnim), op)
                                end
                                render.add_rect_filled(ico_pos, ico_pos:add(btn_sz), btn_bg, 5)
                                render.add_rect(ico_pos, ico_pos:add(btn_sz),
                                    is_open and apply_alpha(accent, 0.6 * op)
                                            or (glass and color(1, 1, 1, 0.12 * op) or apply_alpha(Library.OutlineColor, op)),
                                    5, 1)
                                if not Library.BrushLoaded then Library:LoadBrushIcon() end
                                if Library.BrushTexture then
                                    local iw, ih = 14, 10
                                    local tx = ico_pos.x + (btn_sz.x - iw) / 2
                                    local ty = ico_pos.y + (btn_sz.y - ih) / 2
                                    render.add_texture(Library.BrushTexture, vector2(tx, ty), vector2(tx + iw, ty + ih), op)
                                else
                                    local cx = ico_pos.x + btn_sz.x / 2
                                    local cy = ico_pos.y + btn_sz.y / 2
                                    render.add_circle_filled(vector2(cx, cy), 5,
                                        color(element.Value.r, element.Value.g, element.Value.b, op))
                                end
                                if not Library.DraggingWindow and mpressed
                                    and is_mouse_in_rect(ico_pos, btn_sz) and can_interact
                                then
                                    element.Open = not element.Open
                                    if element.Open then
                                        local cp_width = 240
                                        local cp_height = element.EnableAlpha and 200 or 170
                                        local cp_x = ico_pos.x + btn_sz.x
                                        local cp_y = ico_pos.y
                                        if cp_x + cp_width > get_screen_size().x then cp_x = ico_pos.x - cp_width end
                                        element.layout.picker_pos = vector2(cp_x, cp_y)
                                        element.layout.picker_size = vector2(cp_width, cp_height)
                                        element.layout.sv_pos = vector2(cp_x + 10, cp_y + 10)
                                        element.layout.sv_size = vector2(180, 120)
                                        element.layout.hue_pos = vector2(cp_x + 200, cp_y + 10)
                                        element.layout.hue_size = vector2(20, 120)
                                        if element.EnableAlpha then
                                            element.layout.alpha_pos = vector2(cp_x + 200, cp_y + 140)
                                            element.layout.alpha_size = vector2(20, 20)
                                        end
                                        Library.ActiveColorPicker = { obj = element, layout = element.layout }
                                    else
                                        Library.ActiveColorPicker = nil
                                    end
                                end
                            end
                            element_y = element_y + element.Height
                        end
                        if is_left then left_y = left_y + content_h + 8
                        else right_y = right_y + content_h + 8 end
                    end
                end
            end
            ::continue_window::
        end
    end

    draw_watermark()
    render_tooltip(Library.TooltipAlpha)

    -- Draw notifications
    for i, notif in ipairs(Library.Notifications) do
        local elapsed = (tonumber(get_unixtime()) or 0) - (notif.StartTime or 0)
        local remain = (notif.Duration or 4) - elapsed
        if remain <= 0 then
            table.remove(Library.Notifications, i)
        else
            local fade = math.min(1, remain * 2, elapsed * 4)
            notif.Alpha = notif.Alpha + ((remain < 0.5 and 0 or 1) - notif.Alpha) * 0.1
            notif.OffsetX = notif.OffsetX + ((remain < 0.5 and 30 or 0) - notif.OffsetX) * 0.1
            local ts = render.get_text_size(notif.Text)
            local nw = ts.x + 24
            local nh = 32
            local nx = get_screen_size().x - nw - 10 - notif.OffsetX
            local ny = 10 + (i - 1) * (nh + 5)
            draw_shadow(vector2(nx, ny), vector2(nw, nh), 8, notif.Alpha)
            if Library._GlobalGlass then
                glass_panel(vector2(nx, ny), vector2(nw, nh), 8, notif.Alpha)
            else
                render.add_rect_filled(vector2(nx, ny), vector2(nx + nw, ny + nh),
                    apply_alpha(Library.MainColor, notif.Alpha), 6)
                render.add_rect(vector2(nx, ny), vector2(nx + nw, ny + nh),
                    apply_alpha(Library.OutlineColor, notif.Alpha), 6, 1)
            end
            render.add_text(vector2(nx + 12, ny + 8), notif.Text, apply_alpha(Library.FontColor, notif.Alpha))
        end
    end

    -- Draw color picker if open
    if Library.ActiveColorPicker then
        local cp = Library.ActiveColorPicker.obj
        local layout = Library.ActiveColorPicker.layout
        render.add_rect_filled(layout.picker_pos, layout.picker_pos:add(layout.picker_size),
            apply_alpha(Library.BackgroundColor, 0.95), 8)
        render.add_rect(layout.picker_pos, layout.picker_pos:add(layout.picker_size),
            apply_alpha(Library.OutlineColor, 1), 8, 1)
        
        -- SV picker
        for x = 0, layout.sv_size.x - 1, 4 do
            for y = 0, layout.sv_size.y - 1, 4 do
                local s = x / layout.sv_size.x
                local v = 1 - (y / layout.sv_size.y)
                local col = hsv_to_rgb(cp.Hue, s, v, 1)
                render.add_rect_filled(
                    layout.sv_pos:add(vector2(x, y)),
                    layout.sv_pos:add(vector2(x + 4, y + 4)),
                    col, 0)
            end
        end
        local sel_x = layout.sv_pos.x + cp.Saturation * layout.sv_size.x
        local sel_y = layout.sv_pos.y + (1 - cp.ValueHSV) * layout.sv_size.y
        render.add_circle(vector2(sel_x, sel_y), 6, color(1, 1, 1, 1), 1)
        render.add_circle(vector2(sel_x, sel_y), 4, color(0, 0, 0, 1), 1)
        
        -- Hue picker
        for y = 0, layout.hue_size.y - 1, 2 do
            local hue = y / layout.hue_size.y
            local col = hsv_to_rgb(hue, 1, 1, 1)
            render.add_rect_filled(
                layout.hue_pos:add(vector2(0, y)),
                layout.hue_pos:add(vector2(layout.hue_size.x, y + 2)),
                col, 0)
        end
        local hue_y = layout.hue_pos.y + cp.Hue * layout.hue_size.y
        render.add_rect_filled(
            vector2(layout.hue_pos.x - 3, hue_y - 2),
            vector2(layout.hue_pos.x + layout.hue_size.x + 3, hue_y + 2),
            color(1, 1, 1, 1), 2)
        
        -- Alpha picker if enabled
        if cp.EnableAlpha then
            draw_checkerboard(layout.alpha_pos, layout.alpha_size, 8)
            local alpha_col = hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha)
            render.add_rect_filled(layout.alpha_pos, layout.alpha_pos:add(layout.alpha_size), alpha_col, 0)
            local alpha_y = layout.alpha_pos.y + cp.Alpha * layout.alpha_size.y
            render.add_rect_filled(
                vector2(layout.alpha_pos.x - 3, alpha_y - 2),
                vector2(layout.alpha_pos.x + layout.alpha_size.x + 3, alpha_y + 2),
                color(1, 1, 1, 1), 2)
        end
    end

    -- Draw right click menu
    if Library.RightClickMenu then
        local rcm = Library.RightClickMenu
        rcm.Alpha = math.min(1, (rcm.Alpha or 0) + 0.1)
        draw_shadow(rcm.pos, rcm.size, 6, rcm.Alpha)
        render.add_rect_filled(rcm.pos, rcm.pos:add(rcm.size),
            apply_alpha(Library.MainColor, rcm.Alpha), 6)
        render.add_rect(rcm.pos, rcm.pos:add(rcm.size),
            apply_alpha(Library.OutlineColor, rcm.Alpha), 6, 1)
        
        local y = 0
        local options = {
            { text = "Hold Mode", func = function() if rcm.obj then rcm.obj.Mode = "Hold"; rcm.obj:SetValue(rcm.obj.Value) end end },
            { text = "Toggle Mode", func = function() if rcm.obj then rcm.obj.Mode = "Toggle"; rcm.obj.Active = false; rcm.obj:SetValue(rcm.obj.Value) end end },
            { text = "Clear Key", func = function() if rcm.obj then rcm.obj:SetValue("...") end end },
        }
        for _, opt in ipairs(options) do
            local opt_pos = rcm.pos:add(vector2(4, y))
            local opt_size = vector2(rcm.size.x - 8, 24)
            if is_mouse_in_rect(opt_pos, opt_size) then
                render.add_rect_filled(opt_pos, opt_pos:add(opt_size),
                    apply_alpha(Library.AccentColor, 0.2 * rcm.Alpha), 4)
                if mpressed then
                    opt.func()
                    Library.RightClickMenu = nil
                end
            end
            render.add_text(opt_pos:add(vector2(8, 4)), opt.text,
                apply_alpha(Library.FontColor, rcm.Alpha))
            y = y + 24
        end
    end

    -- Handle key picking
    if Library.ActiveKeyPicker then
        local kp = Library.ActiveKeyPicker.obj
        for vk, name in pairs(KEY_NAMES) do
            if input.is_key_pressed(vk) then
                kp:SetValue(name)
                kp.Picking = false
                Library.ActiveKeyPicker = nil
                break
            end
        end
    end

    -- Handle input
    if Library.ActiveInput then
        local input_field = Library.ActiveInput
        for i = 0x30, 0x5A do
            if input.is_key_pressed(i) then
                local c = input.is_key_down(0x10) and (CHAR_MAP_SHIFT[i] or CHAR_MAP_NORMAL[i]) or CHAR_MAP_NORMAL[i]
                if c then input_field.Value = input_field.Value .. c end
                if input_field.Callback then input_field.Callback(input_field.Value) end
            end
        end
        if input.is_key_pressed(0x08) then
            input_field.Value = string.sub(input_field.Value, 1, -2)
            if input_field.Callback then input_field.Callback(input_field.Value) end
        end
        if input.is_key_pressed(0x20) then
            input_field.Value = input_field.Value .. " "
            if input_field.Callback then input_field.Callback(input_field.Value) end
        end
        if input.is_key_pressed(0x0D) then
            Library.ActiveInput = nil
        end
    end
end)

-- Return the library
return Library
