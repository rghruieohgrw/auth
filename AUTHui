local EM={}; function EM:OnChanged(f) self.OnChangedFunc=f; return self end
local function CE(base,mt) if mt then for k,v in pairs(mt) do base[k]=v end end; return setmetatable(base,{__index=EM}) end

local TM={}
function TM:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end

local SM={}
function SM:SetValue(v)
    local rv=tonumber(string.format("%."..( self.Rounding or 0).."f",v))
    self.Value=math.clamp(rv,self.Min,self.Max)
    if self.Callback then self.Callback(self.Value) end; if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local DM={}
function DM:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end
function DM:SetValues(nv) self.Values=nv; if not self.Multi and #nv>0 then self:SetValue(nv[1]) end end

local IM={}
function IM:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end

local KM={}
function KM:IsActive()
    if not self.Value or self.Value=="..." then return false end
    local vk; for c,n in pairs(KEY_NAMES) do if n==self.Value then vk=c;break end end
    if not vk then return false end
    if self.Mode=="Hold" then return input.key_down(vk) elseif self.Mode=="Toggle" then return self.Active or false end
    return input.key_down(vk)
end
function KM:SetValue(v) self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end end

local CM={}
function CM:SetValue(v)
    self.Value=v; if self.Callback then self.Callback(v) end; if self.OnChangedFunc then self.OnChangedFunc(v) end
    local h,s,val=rgb2hsv(v); self.Hue,self.Saturation,self.ValueHSV=h,s,val; self.Alpha=v.a or 1
end

