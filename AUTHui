hook.add("render", "key_picker_handler", function()
    -- Key picker capture
    for id, opt in pairs(Library.Options) do
        if opt.Type == "KeyPicker" and opt.Picking then
            for vk, name in pairs(KEY_NAMES) do
                if input.is_key_pressed(vk) then
                    opt:SetValue(name)
                    opt.Picking = false
                    Library:Notify("Key bound to: " .. name, 2)
                    break
                end
            end
        end
    end
    
    -- Text input
    if Library.ActiveInput then
        for vk, char in pairs(CHAR_MAP_NORMAL) do
            if input.is_key_pressed(vk) then
                if vk == 0x08 then -- Backspace
                    local v = Library.ActiveInput.Value
                    if #v > 0 then
                        Library.ActiveInput:SetValue(string.sub(v, 1, -2))
                    end
                elseif vk == 0x0D or vk == 0x1B then -- Enter or Escape
                    Library.ActiveInput = nil
                else
                    Library.ActiveInput:SetValue(Library.ActiveInput.Value .. char)
                end
                break
            end
        end
    end
end)

-- Menu toggle key
hook.add("init", "menu_key_init", function()
    local last_press = 0
    hook.add("render", "menu_key_handler", function()
        local menu_key_opt = Library.Options.menu_key
        if menu_key_opt and menu_key_opt.Value and menu_key_opt.Value ~= "..." then
            local vk = nil
            for code, name in pairs(KEY_NAMES) do
                if name == menu_key_opt.Value then
                    vk = code
                    break
                end
            end
            if vk and input.is_key_pressed(vk) then
                local now = get_tickcount()
                if now - last_press > 200 then
                    for _, w in ipairs(Library.Windows) do
                        if w.TargetAlpha > 0.5 then
                            w.TargetAlpha = 0
                            w.Visible = false
                        else
                            w.Visible = true
                            w.TargetAlpha = 1
                        end
                    end
                    last_press = now
                end
            end
        end
    end)
end)

-- Helper function for clipped text
function get_clipped_text(text, max_width)
    if render.get_text_size(text).x <= max_width then
        return text
    end
    local t = text
    while render.get_text_size(t .. "...").x > max_width and #t > 0 do
        t = string.sub(t, 1, -2)
    end
    return t .. "..."
end

-- Add rainbow color helper
function color_rainbow(speed)
    local hue = (get_unixtime() * (speed or 0.5)) % 1
    return color():hsv(hue, 1, 1)
end

