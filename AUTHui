function Library:CreateWindow(config)
    local window = {
        Title = config.Title or "Window",
        Pos = config.Center and vector2(get_screen_size().x / 2 - (config.Size.x / 2), get_screen_size().y / 2 - (config.Size.y / 2)) or vector2(175, 50),
        Size = config.Size or vector2(580, 620),
        Visible = config.AutoShow or false,
        Tabs = {},
        ActiveTab = nil,
        Alpha = config.AutoShow and 1 or 0,
        TargetAlpha = config.AutoShow and 1 or 0,
        ScrollData = {}
    }

    function window:AddTab(name)
        local tab = {
            Name = name,
            Parent = window,
            Groupboxes = {},
            ScrollOffset = 0,
            ContentHeight = 0,
            ViewportHeight = 0
        }

        function tab:AddLeftGroupbox(name, info)
            return self:AddGroupbox({ Name = name, Side = "Left", Dependencies = info and info.Dependencies or nil })
        end

        function tab:AddRightGroupbox(name, info)
            return self:AddGroupbox({ Name = name, Side = "Right", Dependencies = info and info.Dependencies or nil })
        end

        function tab:AddGroupbox(info)
            local groupbox = {
                Name = info.Name,
                Side = info.Side or "Left",
                Parent = tab,
                Elements = {},
                Dependencies = info.Dependencies,
                ContentHeight = 0
            }

            function groupbox:IsVisible()
                if not self.Dependencies then return true end
                for _, dep in ipairs(self.Dependencies) do
                    if dep[1] and dep[1].Value ~= dep[2] then
                        return false
                    end
                end
                return true
            end

            function groupbox:AddToggle(id, info)
                local el = CreateElement({
                    Id = id, Type = "Toggle", Text = info.Text,
                    Value = info.Default or false,
                    Callback = info.Callback,
                    Height = 28,
                    Tooltip = info.Tooltip,
                    Risky = info.Risky,
                    SwitchAnim = info.Default and 1 or 0
                }, ToggleMethods)
                table.insert(self.Elements, el)
                Library.Toggles[id] = el
                return el
            end

            function groupbox:AddSlider(id, info)
                local el = CreateElement({
                    Id = id, Type = "Slider", Text = info.Text,
                    Value = info.Default or 0,
                    Min = info.Min or 0, Max = info.Max or 100,
                    Rounding = info.Rounding or 0,
                    Suffix = info.Suffix or "",
                    Callback = info.Callback,
                    Height = 50,
                    Tooltip = info.Tooltip,
                    ThumbAnim = info.Default and (info.Default - (info.Min or 0)) / ((info.Max or 100) - (info.Min or 0)) or 0,
                    BubbleAlpha = 0
                }, SliderMethods)
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end

            function groupbox:AddButton(info)
                local el = {
                    Type = "Button", Text = info.Text,
                    Func = info.Func,
                    Height = 30,
                    DoubleClick = info.DoubleClick,
                    LastClick = 0,
                    Tooltip = info.Tooltip,
                    HoverAnim = 0
                }
                table.insert(self.Elements, el)
                return el
            end

            function groupbox:AddDropdown(id, info)
                local el = CreateElement({
                    Id = id, Type = "Dropdown", Text = info.Text,
                    Value = info.Default and info.Values[info.Default] or info.Values[1],
                    Values = info.Values,
                    Open = false,
                    Callback = info.Callback,
                    Height = 44,
                    Multi = info.Multi,
                    Tooltip = info.Tooltip,
                    HoverAlpha = 0
                }, DropdownMethods)
                if info.Multi then el.Value = info.Default or {} end
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end

            function groupbox:AddInput(id, info)
                local el = CreateElement({
                    Id = id, Type = "Input", Text = info.Text,
                    Value = info.Default or "",
                    Placeholder = info.Placeholder or "",
                    Callback = info.Callback,
                    Height = 44,
                    Tooltip = info.Tooltip
                }, InputMethods)
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end

            function groupbox:AddKeyPicker(id, info)
                local el = CreateElement({
                    Id = id, Type = "KeyPicker", Text = info.Text,
                    Value = info.Default or "...",
                    Callback = info.Callback,
                    Picking = false,
                    Height = 44,
                    Tooltip = info.Tooltip,
                    Mode = info.Mode or "Hold",
                    Active = false
                }, KeyPickerMethods)
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end

            function groupbox:AddColorPicker(id, info)
                local val = info.Default or color(1, 1, 1, 1)
                local h, s, v = rgb_to_hsv(val)
                local el = CreateElement({
                    Id = id, Type = "ColorPicker", Text = info.Text,
                    Value = val,
                    Open = false,
                    Callback = info.Callback,
                    Height = 24,
                    Hue = h, Saturation = s, ValueHSV = v,
                    Alpha = val.a,
                    EnableAlpha = info.EnableAlpha,
                    Tooltip = info.Tooltip
                }, ColorPickerMethods)
                table.insert(self.Elements, el)
                Library.Options[id] = el
                return el
            end

            function groupbox:AddDivider(height)
                local el = { Type = "Divider", Height = height or 14 }
                table.insert(self.Elements, el)
                return el
            end

            function groupbox:AddLabel(text)
                local el = { Type = "Label", Text = text, Height = 22 }
                table.insert(self.Elements, el)
                return el
            end

            table.insert(self.Groupboxes, groupbox)
            return groupbox
        end

        table.insert(window.Tabs, tab)
        if #window.Tabs == 1 then window.ActiveTab = tab end
        return tab
    end

    table.insert(self.Windows, window)
    return window
end

-- ============================================================================
-- GLOBAL RENDER HOOK
-- ============================================================================
local drawn_windows = {}

hook.add("render", "PhotonUI_Render", function()
    -- Draw notifications
    local now = get_tickcount()
    local start_y = 60
    for i = #Library.Notifications, 1, -1 do
        local n = Library.Notifications[i]
        if n.time + 3000 < now then
            table.remove(Library.Notifications, i)
        else
            local text_w = render.get_text_size(n.text).x
            local pos = vector2(get_screen_size().x - text_w - 20, start_y + n.y_offset)
            n.y_offset = n.y_offset - (n.y_offset) * 0.2
            render.add_rect_filled(pos, pos + vector2(text_w + 16, 28), color(0.12, 0.12, 0.15, n.alpha), 6)
            render.add_text(pos + vector2(8, 6), n.text, n.colour, 13)
            n.alpha = n.alpha - 0.02
        end
    end

    -- Draw watermark
    if Library.Watermark.Visible then
        local text_w = render.get_text_size(Library.Watermark.Text).x
        local bg_pos = Library.Watermark.Pos
        render.add_rect_filled(bg_pos, bg_pos + vector2(text_w + 24, 26), Library.MainColor, 8)
        render.add_rect(bg_pos, bg_pos + vector2(text_w + 24, 26), Library.AccentColor, 8, 1)
        render.add_text(bg_pos + vector2(12, 6), Library.Watermark.Text, Library.FontColor, 13)
    end

    -- Draw windows
    for _, win in ipairs(Library.Windows) do
        if win.Visible then
            if win.Alpha < win.TargetAlpha then
                win.Alpha = math.min(win.Alpha + Library.WindowAlphaSpeed, win.TargetAlpha)
            elseif win.Alpha > win.TargetAlpha then
                win.Alpha = math.max(win.Alpha - Library.WindowAlphaSpeed, win.TargetAlpha)
            end

            if win.Alpha > 0 then
                local alpha = win.Alpha
                render.add_rect_filled(win.Pos, win.Pos + win.Size, Library.BackgroundColor, 12)
                render.add_rect(win.Pos, win.Pos + win.Size, Library.AccentColor, 12, 1.5)

                -- Title bar
                local title_bar = win.Pos + vector2(0, 0)
                render.add_rect_filled(title_bar, title_bar + vector2(win.Size.x, 32), Library.MainColor, 12, true, true, false, false)
                render.add_text(title_bar + vector2(12, 8), win.Title, Library.FontColor, 14)

                -- Draw tabs
                local tabs = win.Tabs
                local tab_w = 100
                local tab_h = 28
                local tab_y = win.Pos.y + 32
                local tab_start_x = win.Pos.x + 12

                for i, tab in ipairs(tabs) do
                    local tab_x = tab_start_x + (i - 1) * (tab_w + 4)
                    local tab_bg = win.ActiveTab == tab and Library.AccentColor or Library.MainColor
                    render.add_rect_filled(vector2(tab_x, tab_y), vector2(tab_x + tab_w, tab_y + tab_h), tab_bg, 6)
                    render.add_text(vector2(tab_x + tab_w / 2 - render.get_text_size(tab.Name).x / 2, tab_y + 7), tab.Name, Library.FontColor, 12)

                    if is_mouse_in_rect(vector2(tab_x, tab_y), vector2(tab_w, tab_h)) and input.is_key_pressed(0x01) then
                        win.ActiveTab = tab
                    end
                end

                -- Draw active tab content
                if win.ActiveTab then
                    local content_y = tab_y + tab_h + 8
                    local left_x = win.Pos.x + 12
                    local right_x = win.Pos.x + win.Size.x / 2 + 6
                    local col_w = (win.Size.x - 36) / 2

                    for _, gb in ipairs(win.ActiveTab.Groupboxes) do
                        if gb:IsVisible() then
                            local base_x = gb.Side == "Left" and left_x or right_x
                            local elem_y = content_y + 32

                            -- Groupbox background
                            render.add_rect_filled(vector2(base_x, content_y), vector2(base_x + col_w, content_y + (gb.ContentHeight or 0)), Library.MainColor, 8)
                            render.add_text(vector2(base_x + 12, content_y + 8), gb.Name, Library.FontColor, 13)

                            -- Draw elements
                            for _, el in ipairs(gb.Elements) do
                                if el.Type == "Divider" then
                                    elem_y = elem_y + (el.Height or 14)
                                elseif el.Type == "Label" then
                                    render.add_text(vector2(base_x + 12, elem_y + 8), el.Text, Library.SecondaryFontColor, 12)
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "Toggle" then
                                    local toggle_x = base_x + 12
                                    local toggle_y = elem_y + 6
                                    local toggle_w = 32
                                    local toggle_h = 16
                                    local bg_col = el.Value and Library.AccentColor or color(0.3, 0.3, 0.35, 1)
                                    render.add_rect_filled(vector2(toggle_x, toggle_y), vector2(toggle_x + toggle_w, toggle_y + toggle_h), bg_col, toggle_h / 2)
                                    local knob_x = el.Value and toggle_x + toggle_w - toggle_h or toggle_x
                                    render.add_rect_filled(vector2(knob_x, toggle_y), vector2(knob_x + toggle_h, toggle_y + toggle_h), color(1, 1, 1, 1), toggle_h / 2)
                                    render.add_text(vector2(toggle_x + toggle_w + 12, toggle_y - 2), el.Text, el.Risky and Library.RiskColor or Library.FontColor, 12)

                                    if is_mouse_in_rect(vector2(base_x + 12, elem_y), vector2(col_w - 24, el.Height)) and input.is_key_pressed(0x01) then
                                        el:SetValue(not el.Value)
                                    end
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "Slider" then
                                    render.add_text(vector2(base_x + 12, elem_y + 4), el.Text, Library.FontColor, 12)
                                    local val_x = base_x + 12
                                    local val_y = elem_y + 22
                                    local val_w = col_w - 72
                                    local val_h = 4
                                    render.add_rect_filled(vector2(val_x, val_y), vector2(val_x + val_w, val_y + val_h), color(0.2, 0.2, 0.25, 1), 2)

                                    local percent = (el.Value - el.Min) / (el.Max - el.Min)
                                    local thumb_x = val_x + (val_w * percent)
                                    render.add_rect_filled(vector2(val_x, val_y), vector2(thumb_x, val_y + val_h), Library.AccentColor, 2)
                                    render.add_rect_filled(vector2(thumb_x - 4, val_y - 4), vector2(thumb_x + 4, val_y + val_h + 4), Library.AccentColor, 6)

                                    local value_text = tostring(el.Value) .. (el.Suffix or "")
                                    render.add_text(vector2(val_x + val_w + 8, elem_y + 18), value_text, Library.FontColor, 11)

                                    if is_mouse_in_rect(vector2(val_x, val_y - 6), vector2(val_w, 18)) and input.key_down(0x01) then
                                        local m = input.get_mouse_position()
                                        local new_percent = math.max(0, math.min(1, (m.x - val_x) / val_w))
                                        el:SetValue(el.Min + (el.Max - el.Min) * new_percent)
                                    end
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "Button" then
                                    local btn_y = elem_y + 4
                                    render.add_rect_filled(vector2(base_x + 12, btn_y), vector2(base_x + col_w - 12, btn_y + 26), color(0.2, 0.2, 0.25, 1), 6)
                                    render.add_text(vector2(base_x + col_w / 2 - render.get_text_size(el.Text).x / 2, btn_y + 7), el.Text, Library.FontColor, 12)

                                    if is_mouse_in_rect(vector2(base_x + 12, btn_y), vector2(col_w - 24, 26)) and input.is_key_pressed(0x01) then
                                        if el.Func then el.Func() end
                                    end
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "Dropdown" then
                                    render.add_text(vector2(base_x + 12, elem_y + 4), el.Text, Library.FontColor, 12)
                                    local dd_y = elem_y + 22
                                    render.add_rect_filled(vector2(base_x + 12, dd_y), vector2(base_x + col_w - 12, dd_y + 22), color(0.2, 0.2, 0.25, 1), 6)
                                    render.add_text(vector2(base_x + 18, dd_y + 6), el.Value, Library.FontColor, 11)

                                    if is_mouse_in_rect(vector2(base_x + 12, dd_y), vector2(col_w - 24, 22)) and input.is_key_pressed(0x01) then
                                        el.Open = not el.Open
                                    end

                                    if el.Open and el.Values then
                                        local dd_y_offset = dd_y + 22
                                        for i, opt in ipairs(el.Values) do
                                            render.add_rect_filled(vector2(base_x + 12, dd_y_offset), vector2(base_x + col_w - 12, dd_y_offset + 22), color(0.12, 0.12, 0.15, 1), 6)
                                            render.add_text(vector2(base_x + 18, dd_y_offset + 6), opt, Library.FontColor, 11)

                                            if is_mouse_in_rect(vector2(base_x + 12, dd_y_offset), vector2(col_w - 24, 22)) and input.is_key_pressed(0x01) then
                                                el:SetValue(opt)
                                                el.Open = false
                                            end
                                            dd_y_offset = dd_y_offset + 22
                                        end
                                    end
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "Input" then
                                    render.add_text(vector2(base_x + 12, elem_y + 4), el.Text, Library.FontColor, 12)
                                    local in_y = elem_y + 22
                                    local is_active = Library.ActiveInput == el
                                    render.add_rect_filled(vector2(base_x + 12, in_y), vector2(base_x + col_w - 12, in_y + 26), color(0.2, 0.2, 0.25, 1), 6)
                                    if is_active then
                                        render.add_rect(vector2(base_x + 12, in_y), vector2(base_x + col_w - 12, in_y + 26), Library.AccentColor, 6, 1)
                                    end
                                    local display_text = el.Value
                                    if display_text == "" then display_text = el.Placeholder or "Enter..." end
                                    render.add_text(vector2(base_x + 18, in_y + 7), display_text, display_text == (el.Placeholder or "Enter...") and Library.SecondaryFontColor or Library.FontColor, 12)

                                    if is_mouse_in_rect(vector2(base_x + 12, in_y), vector2(col_w - 24, 26)) and input.is_key_pressed(0x01) then
                                        Library.ActiveInput = el
                                    end
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "KeyPicker" then
                                    render.add_text(vector2(base_x + 12, elem_y + 4), el.Text, Library.FontColor, 12)
                                    local kp_y = elem_y + 22
                                    local is_picking = Library.ActiveKeyPicker == el
                                    render.add_rect_filled(vector2(base_x + 12, kp_y), vector2(base_x + col_w - 12, kp_y + 26), color(0.2, 0.2, 0.25, 1), 6)
                                    if is_picking then
                                        render.add_rect(vector2(base_x + 12, kp_y), vector2(base_x + col_w - 12, kp_y + 26), Library.AccentColor, 6, 1)
                                    end
                                    render.add_text(vector2(base_x + 18, kp_y + 7), is_picking and "Press any key..." or el.Value, Library.FontColor, 12)

                                    if is_mouse_in_rect(vector2(base_x + 12, kp_y), vector2(col_w - 24, 26)) and input.is_key_pressed(0x01) then
                                        Library.ActiveKeyPicker = is_picking and nil or el
                                    end
                                    elem_y = elem_y + el.Height
                                elseif el.Type == "ColorPicker" then
                                    render.add_text(vector2(base_x + 12, elem_y + 4), el.Text, Library.FontColor, 12)
                                    local preview_pos = vector2(base_x + col_w - 40, elem_y + 8)
                                    render.add_rect_filled(preview_pos, preview_pos + vector2(28, 16), el.Value, 4)
                                    render.add_rect(preview_pos, preview_pos + vector2(28, 16), color(1, 1, 1, 0.3), 4, 1)

                                    if is_mouse_in_rect(vector2(base_x + 12, elem_y), vector2(col_w - 24, el.Height)) and input.is_key_pressed(0x01) then
                                        Library:ToggleColourPicker(preview_pos, vector2(28, 16), el.Value)
                                    end
                                    elem_y = elem_y + el.Height
                                end
                            end
                            gb.ContentHeight = elem_y - content_y
                        end
                    end
                end

                table.insert(drawn_windows, win)
            end
        end
    end

    -- Draw brush button and colour picker
    if Library.Icons.loaded then
        Library:DrawBrushButton()
        Library:DrawColourPicker()
    end

    -- Draw tooltip
    Library:DrawTooltip()

    -- Window dragging
    for _, win in ipairs(drawn_windows) do
        if win.Alpha > 0 then
            local title_bar = win.Pos + vector2(0, 0)
            local title_size = vector2(win.Size.x, 32)
            if is_mouse_in_rect(title_bar, title_size) and input.is_key_pressed(0x01) then
                Library.DraggingWindow = win
                Library.DragOffset = input.get_mouse_position() - win.Pos
            end
        end
    end

    if Library.DraggingWindow then
        if input.key_down(0x01) then
            Library.DraggingWindow.Pos = input.get_mouse_position() - Library.DragOffset
        else
            Library.DraggingWindow = nil
        end
    end

    drawn_windows = {}
end)

