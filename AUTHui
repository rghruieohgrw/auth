-- ═══════════════════════════════════════════════════
--  MATH / COLOUR HELPERS
-- ═══════════════════════════════════════════════════
local function lerp(a,b,t) return a+(b-a)*t end
local function aa(c,m) return color(c.r,c.g,c.b,(c.a or 1)*m) end -- apply_alpha

local function rgb2hsv(c)
    local r,g,b=c.r,c.g,c.b
    local mx=math.max(r,g,b); local mn=math.min(r,g,b)
    local h,s,v=0,0,mx; local d=mx-mn
    if mx~=0 then s=d/mx else return 0,0,0 end
    if d>1e-5 then
        if mx==r then h=(g-b)/d elseif mx==g then h=2+(b-r)/d else h=4+(r-g)/d end
        h=h/6; if h<0 then h=h+1 end
    end
    return h,s,v
end
local function hsv2rgb(h,s,v,a)
    local i=math.floor(h*6); local f=h*6-i
    local p=v*(1-s); local q=v*(1-f*s); local t2=v*(1-(1-f)*s)
    i=i%6
    local r,g,b
    if i==0 then r,g,b=v,t2,p elseif i==1 then r,g,b=q,v,p
    elseif i==2 then r,g,b=p,v,t2 elseif i==3 then r,g,b=p,q,v
    elseif i==4 then r,g,b=t2,p,v else r,g,b=v,p,q end
    return color(r,g,b,a or 1)
end

local function inrect(pos,sz)
    if not pos or not sz then return false end
    local m=input.get_mouse_position()
    return m.x>=pos.x and m.x<=pos.x+sz.x and m.y>=pos.y and m.y<=pos.y+sz.y
end

local function cliptext(t,w)
    if render.get_text_size(t).x<=w then return t end
    while render.get_text_size(t.."…").x>w and #t>0 do t=t:sub(1,-2) end
    return t.."…"
end

local function checker(pos,sz,sq)
    local c1=color(0.2,0.2,0.2,1); local c2=color(0.1,0.1,0.1,1)
    for y=0,math.ceil(sz.y/sq)-1 do for x=0,math.ceil(sz.x/sq)-1 do
        local p=pos:add(vector2(x*sq,y*sq))
        local s=vector2(math.min(sq,sz.x-x*sq),math.min(sq,sz.y-y*sq))
        render.add_rect_filled(p,p:add(s),(x+y)%2==0 and c1 or c2,0)
    end end
end

local function shadow(pos,sz,r,am)
    if L.ShadowStrength<=0 then return end
    local str=L.ShadowStrength*(am or 1)
    for i=1,10 do
        local sp2=i*3
        local a=(1-i/10)^1.4*0.22*str
        local p=pos:add(vector2(-sp2,-sp2+sp2*0.4))
        local s=sz:add(vector2(sp2*2,sp2*2))
        render.add_rect_filled(p,p:add(s),color(0,0,0,a),r+i)
    end
end

