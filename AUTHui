-- ────────────────────────────────────────────
--  CORE HELPERS
-- ────────────────────────────────────────────
local function lerp(a, b, t) return a + (b - a) * t end
local function clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end

local function aa(col, m)   -- apply alpha, hot path
    return color(col.r, col.g, col.b, (col.a or 1) * m)
end

local _mp_cache = vector2(0, 0)   -- refreshed once per frame
local function imr(pos, size)      -- is_mouse_in_rect
    if not pos or not size then return false end
    local m = _mp_cache
    return m.x >= pos.x and m.x <= pos.x + size.x
       and m.y >= pos.y and m.y <= pos.y + size.y
end

local function clip_text(text, max_w)
    if render.get_text_size(text).x <= max_w then return text end
    local t = text
    while #t > 0 and render.get_text_size(t .. "…").x > max_w do
        t = string.sub(t, 1, -2)
    end
    return t .. "…"
end

local function draw_checkerboard(pos, size, sq)
    local c1, c2 = color(0.20, 0.20, 0.20, 1), color(0.10, 0.10, 0.10, 1)
    for y = 0, math.ceil(size.y / sq) - 1 do
        for x = 0, math.ceil(size.x / sq) - 1 do
            local p = pos:add(vector2(x * sq, y * sq))
            local s = vector2(math.min(sq, size.x - x * sq), math.min(sq, size.y - y * sq))
            render.add_rect_filled(p, p:add(s), (x + y) % 2 == 0 and c1 or c2, 0)
        end
    end
end

-- shadow: 6 layers, inward gradient
local function draw_shadow(pos, size, r, am)
    am = am or 1
    for i = 1, 6 do
        local sp = i * 2.5
        local a  = (1 - i / 6) * 0.20 * am
        local pp = pos:add(vector2(-sp, -sp * 0.6))
        local ss = size:add(vector2(sp * 2, sp * 2))
        render.add_rect_filled(pp, pp:add(ss), color(0, 0, 0, a), r + i)
    end
end

local function rgb_to_hsv(c)
    local r, g, b  = c.r, c.g, c.b
    local mx       = math.max(r, g, b)
    local diff     = mx - math.min(r, g, b)
    if mx == 0 then return 0, 0, 0 end
    local s = diff / mx
    local h = 0
    if diff > 1e-5 then
        if mx == r then h = (g - b) / diff
        elseif mx == g then h = 2 + (b - r) / diff
        else h = 4 + (r - g) / diff end
        h = h / 6; if h < 0 then h = h + 1 end
    end
    return h, s, mx
end

local function hsv_to_rgb(h, s, v, a)
    local i = math.floor(h * 6) % 6
    local f = h * 6 - math.floor(h * 6)
    local p = v * (1 - s); local q = v * (1 - f * s); local t = v * (1 - (1 - f) * s)
    local r, g, b
    if i==0 then r,g,b=v,t,p elseif i==1 then r,g,b=q,v,p
    elseif i==2 then r,g,b=p,v,t elseif i==3 then r,g,b=p,q,v
    elseif i==4 then r,g,b=t,p,v else r,g,b=v,p,q end
    return color(r, g, b, a or 1)
end

-- ────────────────────────────────────────────
--  PANEL DRAWING  (glass + solid unified)
--
--  glass = false  →  solid dark panel (MainColor tinted by window.Color)
--  glass = true   →  frosted layers + optional simulated blur
--
--  Blur is faked by drawing 4 extra slightly-offset translucent rects
--  behind the panel (Photon has no render.blur_rect).
-- ────────────────────────────────────────────
local function draw_panel(pos, size, radius, alpha, is_glass)
    local g   = Library._G
    local a   = alpha or 1
    local gc  = g.color        -- window Color param
    local tr  = g.trans        -- Transparency (0=opaque,1=invisible)
    local bl  = g.blur         -- Blur 0..1

    if is_glass then
        -- ── simulated blur: offset ghost rects ──
        if bl > 0 then
            local bstr = bl * 6   -- max pixel spread
            local ba   = bl * 0.08 * a
            local offsets = { vector2(bstr, 0), vector2(-bstr, 0),
                              vector2(0, bstr), vector2(0, -bstr) }
            for _, off in ipairs(offsets) do
                render.add_rect_filled(pos:add(off), pos:add(off):add(size),
                    color(gc.r * 0.08, gc.g * 0.08, gc.b * 0.12, ba), radius)
            end
        end

        -- ── base fill ──
        -- tr=0 → nearly opaque, tr=1 → nearly invisible
        local fill_a = (1 - clamp(tr, 0, 1)) * 0.88 * a
        render.add_rect_filled(pos, pos:add(size),
            color(gc.r * 0.10 + 0.02, gc.g * 0.10 + 0.02, gc.b * 0.13 + 0.02, fill_a), radius)

        -- ── tint overlay (adds the glass color) ──
        render.add_rect_filled(pos, pos:add(size),
            color(gc.r, gc.g, gc.b, 0.07 * a), radius)

        -- ── top specular shimmer ──
        local sh = math.min(size.y, 18)
        render.add_rect_filled(pos, pos:add(vector2(size.x, sh)),
            color(1, 1, 1, 0.05 * a), radius)

        -- ── bright inner border ──
        render.add_rect(pos, pos:add(size), color(1, 1, 1, 0.13 * a), radius, 1)

        -- ── faint outer rim ──
        render.add_rect(pos:add(vector2(1, 1)), pos:add(size):add(vector2(-1, -1)),
            color(gc.r * 0.4, gc.g * 0.45, gc.b * 0.85, 0.22 * a), math.max(radius - 1, 0), 1)

    else
        -- ── solid mode ──
        -- gc tints the MainColor slightly
        local mc = Library.MainColor
        local fc = color(
            lerp(mc.r, gc.r, 0.08),
            lerp(mc.g, gc.g, 0.08),
            lerp(mc.b, gc.b, 0.10),
            1)
        -- tr adjusts how dark the panel is (0=default, 1=more transparent)
        local solid_a = (1 - clamp(tr, 0, 0.8)) * a
        render.add_rect_filled(pos, pos:add(size), aa(fc, solid_a), radius)
        render.add_rect(pos, pos:add(size), aa(Library.OutlineColor, a), radius, 1)
    end
end

-- lighter variant for inline elements (dropdowns, inputs, keypickers)
local function draw_inset(pos, size, radius, alpha, is_glass, highlighted)
    local a = alpha or 1
    if is_glass then
        local fill_a = highlighted and 0.14 or 0.07
        render.add_rect_filled(pos, pos:add(size), color(1, 1, 1, fill_a * a), radius)
        render.add_rect(pos, pos:add(size),
            highlighted and aa(Library.AccentColor, 0.5 * a) or color(1, 1, 1, 0.10 * a), radius, 1)
    else
        render.add_rect_filled(pos, pos:add(size), aa(Library.BackgroundColor, a), radius)
        render.add_rect(pos, pos:add(size),
            highlighted and aa(Library.AccentColor, a) or aa(Library.OutlineColor, a), radius, 1)
    end
end

-- ────────────────────────────────────────────
--  CONFIG SYSTEM  (uses file.list_folder / file.delete_file)
-- ────────────────────────────────────────────
function Library:GetConfigList()
    local out = {}
    if not file.exists(self.ConfigFolder) then self.ConfigList = out; return out end
    local files = file.list_folder(self.ConfigFolder)
    if files then
        for _, name in ipairs(files) do
            if type(name) == "string" then
                local cn = name:match("^(.+)%.json$")
                if cn then table.insert(out, cn) end
            end
        end
    end
    table.sort(out)
    self.ConfigList = out
    return out
end

function Library:UpdateManifest()   self.ConfigList = self:GetConfigList() end
function Library:RemoveFromManifest() self.ConfigList = self:GetConfigList() end

function Library:SaveConfig(name)
    if not file.exists(self.ConfigFolder) then file.write(self.ConfigFolder .. ".keep", "") end
    local cfg = { toggles={}, options={}, version=3, saved_at=get_unixtime(), game=get_placeid() }
    for id, t in pairs(self.Toggles) do cfg.toggles[id] = t.Value end
    for id, o in pairs(self.Options) do
        if o.Type=="Slider" then
            cfg.options[id]={ type="Slider", value=o.Value }
        elseif o.Type=="Dropdown" then
            cfg.options[id]={ type="Dropdown", value=o.Value, multi=o.Multi or false }
        elseif o.Type=="Input" then
            cfg.options[id]={ type="Input", value=o.Value }
        elseif o.Type=="KeyPicker" then
            cfg.options[id]={ type="KeyPicker", value=o.Value, mode=o.Mode or "Hold" }
        elseif o.Type=="ColorPicker" then
            local c=o.Value; cfg.options[id]={ type="ColorPicker", value={r=c.r,g=c.g,b=c.b,a=c.a} }
        end
    end
    cfg.windows={}
    for i, w in ipairs(self.Windows) do cfg.windows[i]={pos={x=w.Pos.x,y=w.Pos.y}} end
    cfg.watermark={x=self.Watermark.Pos.x, y=self.Watermark.Pos.y}
    file.write(self.ConfigFolder..name..".json", self:TableToJSON(cfg))
    self.CurrentConfig=name
    self:Notify("Saved: "..name, 2)
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue(name)
    end
    return true
end

function Library:LoadConfig(name)
    local fn = self.ConfigFolder..name..".json"
    if not file.exists(fn) then self:Notify("Not found: "..name, 3); return false end
    local raw = file.read(fn)
    if not raw or raw=="" then self:Notify("Empty config: "..name, 3); return false end
    local cfg = self:JSONToTable(raw)
    if not cfg then self:Notify("Parse error: "..name, 3); return false end
    for id, v in pairs(cfg.toggles or {}) do
        if self.Toggles[id] then self.Toggles[id]:SetValue(v) end
    end
    for id, d in pairs(cfg.options or {}) do
        local o = self.Options[id]
        if o then
            if d.type=="Slider" then o:SetValue(d.value)
            elseif d.type=="Dropdown" then o:SetValue(d.value)
            elseif d.type=="Input" then o:SetValue(d.value)
            elseif d.type=="KeyPicker" then o:SetValue(d.value); if d.mode then o.Mode=d.mode end
            elseif d.type=="ColorPicker" then
                local c=d.value; o:SetValue(color(c.r,c.g,c.b,c.a))
            end
        end
    end
    for i, wd in ipairs(cfg.windows or {}) do
        if self.Windows[i] then self.Windows[i].Pos=vector2(wd.pos.x, wd.pos.y) end
    end
    if cfg.watermark then self.Watermark.Pos=vector2(cfg.watermark.x, cfg.watermark.y) end
    self.ConfigLoaded=true; self.CurrentConfig=name
    self:Notify("Loaded: "..name, 2)
    if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
    return true
end

function Library:DeleteConfig(name)
    local fn = self.ConfigFolder..name..".json"
    if not file.exists(fn) then return false end
    if file.delete_file then file.delete_file(fn) else file.write(fn,"") end
    self:Notify("Deleted: "..name, 2)
    if self.CurrentConfig==name then self.CurrentConfig="" end
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue("")
    end
    return true
end

function Library:ResetAll()
    for _, t in pairs(self.Toggles) do t:SetValue(false) end
    for _, o in pairs(self.Options) do
        if o.Type=="Slider" then o:SetValue((o.Min+o.Max)/2)
        elseif o.Type=="Dropdown" and not o.Multi then o:SetValue(o.Values[1])
        elseif o.Type=="Input" then o:SetValue("")
        elseif o.Type=="KeyPicker" then o:SetValue("...")
        elseif o.Type=="ColorPicker" then o:SetValue(self.AccentColor) end
    end
    self.CurrentConfig=""
    if self.ConfigDropdown then self.ConfigDropdown:SetValue("") end
    self:Notify("Reset to defaults", 2)
end

function Library:TableToJSON(tbl)
    local function s(v)
        local t = type(v)
        if t=="string" then return '"'..v:gsub('\\','\\\\'):gsub('"','\\"')..'"'
        elseif t=="number" then return tostring(v)
        elseif t=="boolean" then return v and "true" or "false"
        elseif t=="table" then
            local mi, ia = 0, true
            for k in pairs(v) do
                if type(k)~="number" or k~=math.floor(k) or k<=0 then ia=false; break end
                if k>mi then mi=k end
            end
            local items={}
            if ia and mi>0 then
                for i=1,mi do items[i]=s(v[i]) end
                return "["..table.concat(items,",").."]"
            else
                for k,val in pairs(v) do table.insert(items, s(tostring(k))..":"..s(val)) end
                return "{"..table.concat(items,",").."}"
            end
        end
        return "null"
    end
    return s(tbl)
end

function Library:JSONToTable(str)
    local fn = load("return "..str, "json", "t")
    if fn then local ok, r = pcall(fn); if ok then return r end end
    return nil
end

function Library:CreateConfigSection(gb)
    local configs = self:GetConfigList()
    local dd = gb:AddDropdown("config_dropdown", {
        Text="Config", Default=1, Values=configs, Tooltip="Select config to load"
    })
    self.ConfigDropdown = dd
    gb:AddButton({ Text="Save New", Tooltip="Save current settings as new config",
        Func=function() self:Notify("Type config name in console",3); print("Config name:") end })
    gb:AddButton({ Text="Overwrite", Tooltip="Overwrite loaded config",
        Func=function()
            if self.CurrentConfig~="" then self:SaveConfig(self.CurrentConfig)
            else self:Notify("No config loaded",3) end
        end })
    gb:AddDivider()
    gb:AddButton({ Text="Delete", DoubleClick=true, Tooltip="Double-click to delete",
        Func=function()
            local c=dd.Value
            if c and c~="" then self:DeleteConfig(c) else self:Notify("None selected",3) end
        end })
    gb:AddButton({ Text="Reset All", DoubleClick=true, Tooltip="Double-click to reset",
        Func=function() self:ResetAll() end })
    gb:AddButton({ Text="Refresh List", Tooltip="Refresh config list",
        Func=function() dd:SetValues(self:GetConfigList()); self:Notify("Refreshed",2) end })
    dd:OnChanged(function(v) if v and v~="" then self:LoadConfig(v) end end)
    return dd
end

