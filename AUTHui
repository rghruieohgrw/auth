            Tooltip = "Save current settings as a new config"
        })
        groupbox:AddButton({
            Text = "Overwrite Current",
            Func = function()
                if self.CurrentConfig and self.CurrentConfig ~= "" then
                    self:SaveConfig(self.CurrentConfig)
                else
                    self:Notify("No config loaded to overwrite", 3)
                end
