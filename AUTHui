-- Photon UI Library - Clean Version (No Config System)
-- Modern design with better spacing and rounded corners

local _players = game:get_service("Players")
local _localname = _players and _players.local_player and _players.local_player.name or "unknown"

local Library = {
    Windows = {},
    Toggles = {},
    Options = {},
    FontColor = color():int(220, 220, 230, 255),
    SecondaryFontColor = color(0.65, 0.65, 0.75, 1),
    MainColor = color():int(25, 28, 32, 255),
    BackgroundColor = color():int(18, 20, 24, 255),
    AccentColor = color():int(88, 101, 242, 255),
    OutlineColor = color(0, 0, 0, 0),
    RiskColor = color(1, 0.35, 0.35, 1),
    Notifications = {},
    Watermark = { Text = "Menu", Pos = vector2(15, 15), Visible = true },
    ActiveSlider = nil,
    DraggingWindow = nil,
    DragOffset = vector2(0, 0),
    DraggingWatermark = false,
    OpenedDropdown = nil,
    ActiveColorPicker = nil,
    ActiveKeyPicker = nil,
    RightClickMenu = nil,
    ActiveInput = nil,
    Tooltip = nil,
    ModalOpen = false,
    NotificationPosition = "Top Right",
    
    Notify = function(self, text, duration)
        table.insert(self.Notifications, {
            Text = text, Duration = duration or 3, StartTime = get_unixtime(),
            Alpha = 0, TargetAlpha = 1, OffsetX = 30, TargetOffsetX = 0
        })
    end,
    
    SetWatermark = function(self, text)
        self.Watermark.Text = text
        self.Watermark.Visible = true
    end,
    
    CreateWindow = function(self, config)
        local window = {
            Title = config.Title or "Window",
            Pos = config.Center and vector2(get_screen_size().x/2 - config.Size.x/2, get_screen_size().y/2 - config.Size.y/2) or vector2(150, 100),
            Size = config.Size or vector2(600, 500),
            Visible = config.AutoShow or false,
            Tabs = {},
            ActiveTab = nil,
            Alpha = config.AutoShow and 1 or 0,
            TargetAlpha = config.AutoShow and 1 or 0,
        }
        
        function window:AddTab(name)
            local tab = { Name = name, Parent = window, Groupboxes = {} }
            
            function tab:AddLeftGroupbox(name)
                return self:AddGroupbox(name, "Left")
            end
            
            function tab:AddRightGroupbox(name)
                return self:AddGroupbox(name, "Right")
            end
            
            function tab:AddGroupbox(name, side)
                local groupbox = { Name = name, Side = side or "Left", Parent = tab, Elements = {} }
                
                function groupbox:AddToggle(id, info)
                    local el = {
                        Type = "Toggle", Id = id, Text = info.Text, Value = info.Default or false,
                        Tooltip = info.Tooltip, Risky = info.Risky or false, Height = 32,
                        SwitchAnim = info.Default and 1 or 0
                    }
                    function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                    function el:OnChanged(f) self.OnChange = f; return self end
                    table.insert(self.Elements, el)
                    Library.Toggles[id] = el
                    return el
                end
                
                function groupbox:AddSlider(id, info)
                    local el = {
                        Type = "Slider", Id = id, Text = info.Text, Value = info.Default or 0,
                        Min = info.Min or 0, Max = info.Max or 100, Suffix = info.Suffix or "",
                        Rounding = info.Rounding or 0, Height = 55, Tooltip = info.Tooltip,
                        ThumbAnim = (info.Default or 0) / (info.Max or 100)
                    }
                    function el:SetValue(v) self.Value = math.clamp(v, self.Min, self.Max); if self.OnChange then self.OnChange(self.Value) end end
                    function el:OnChanged(f) self.OnChange = f; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end
                
                function groupbox:AddButton(info)
                    local el = {
                        Type = "Button", Text = info.Text, Func = info.Func,
                        Height = 34, DoubleClick = info.DoubleClick or false, LastClick = 0,
                        Tooltip = info.Tooltip, HoverAnim = 0
                    }
                    table.insert(self.Elements, el)
                    return el
                end
                
                function groupbox:AddDropdown(id, info)
                    local el = {
                        Type = "Dropdown", Id = id, Text = info.Text,
                        Value = info.Values[1], Values = info.Values, Multi = info.Multi or false,
                        Height = 48, Tooltip = info.Tooltip, Open = false, Layout = nil
                    }
                    if info.Default then el.Value = info.Values[info.Default] end
                    function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                    function el:SetValues(v) self.Values = v; if #v > 0 then self:SetValue(v[1]) end end
                    function el:OnChanged(f) self.OnChange = f; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end
                
                function groupbox:AddInput(id, info)
                    local el = {
                        Type = "Input", Id = id, Text = info.Text, Value = info.Default or "",
                        Placeholder = info.Placeholder or "", Height = 48, Tooltip = info.Tooltip, layout = nil
                    }
                    function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                    function el:OnChanged(f) self.OnChange = f; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end
                
                function groupbox:AddKeyPicker(id, info)
                    local KEY_NAMES = {
                        [0x01]="LMB",[0x02]="RMB",[0x08]="Backspace",[0x09]="Tab",[0x0D]="Enter",
                        [0x10]="Shift",[0x11]="Ctrl",[0x12]="Alt",[0x1B]="Esc",[0x20]="Space",
                        [0x21]="PgUp",[0x22]="PgDn",[0x23]="End",[0x24]="Home",
                        [0x25]="Left",[0x26]="Up",[0x27]="Right",[0x28]="Down",
                        [0x2D]="Ins",[0x2E]="Del",[0x30]="0",[0x31]="1",[0x32]="2",[0x33]="3",
                        [0x34]="4",[0x35]="5",[0x36]="6",[0x37]="7",[0x38]="8",[0x39]="9",
                        [0x41]="A",[0x42]="B",[0x43]="C",[0x44]="D",[0x45]="E",[0x46]="F",
                        [0x47]="G",[0x48]="H",[0x49]="I",[0x4A]="J",[0x4B]="K",[0x4C]="L",
                        [0x4D]="M",[0x4E]="N",[0x4F]="O",[0x50]="P",[0x51]="Q",[0x52]="R",
                        [0x53]="S",[0x54]="T",[0x55]="U",[0x56]="V",[0x57]="W",[0x58]="X",
                        [0x59]="Y",[0x5A]="Z",[0x70]="F1",[0x71]="F2",[0x72]="F3",[0x73]="F4",
                        [0x74]="F5",[0x75]="F6",[0x76]="F7",[0x77]="F8",[0x78]="F9",[0x79]="F10",
                        [0x7A]="F11",[0x7B]="F12"
                    }
                    local el = {
                        Type = "KeyPicker", Id = id, Text = info.Text, Value = info.Default or "...",
                        Mode = info.Mode or "Hold", Height = 48, Tooltip = info.Tooltip,
                        Picking = false, Active = false, layout = nil
                    }
                    function el:IsActive()
                        if not self.Value or self.Value == "..." then return false end
                        local vk = nil
                        for code, name in pairs(KEY_NAMES) do if name == self.Value then vk = code; break end end
                        if not vk then return false end
                        if self.Mode == "Hold" then return input.key_down(vk)
                        elseif self.Mode == "Toggle" then return self.Active or false
                        end
                        return input.key_down(vk)
                    end
                    function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                    function el:OnChanged(f) self.OnChange = f; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end
                
                function groupbox:AddColorPicker(id, info)
                    local val = info.Default or color(1, 1, 1, 1)
                    local el = {
                        Type = "ColorPicker", Id = id, Text = info.Text, Value = val,
                        EnableAlpha = info.EnableAlpha or false, Height = 28, Tooltip = info.Tooltip,
                        Open = false, layout = { pos = vector2(0,0), size = vector2(0,0) }
                    }
                    function el:SetValue(v) self.Value = v; if self.OnChange then self.OnChange(v) end end
                    function el:OnChanged(f) self.OnChange = f; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end
                
                function groupbox:AddDivider()
                    table.insert(self.Elements, { Type = "Divider", Height = 12 })
                    return self
                end
                
                function groupbox:AddLabel(text)
                    table.insert(self.Elements, { Type = "Label", Text = text, Height = 24 })
                    return self
                end
                
                table.insert(self.Groupboxes, groupbox)
                return groupbox
            end
            
            table.insert(window.Tabs, tab)
            if not window.ActiveTab then window.ActiveTab = tab end
            return tab
        end
        
        table.insert(self.Windows, window)
        return window
    end
}

-- Helper functions
local function apply_alpha(col, mult)
    return color(col.r, col.g, col.b, (col.a or 1) * mult)
end

local function is_mouse_in_rect(pos, size)
    if not pos or not size then return false end
    local m = input.get_mouse_position()
    return m.x >= pos.x and m.x <= pos.x + size.x and m.y >= pos.y and m.y <= pos.y + size.y
end

local function draw_shadow(pos, size, radius, alpha_mult)
    for i = 1, 5 do
        local spread = i * 2
        local a = (1 - i / 5) * 0.08 * (alpha_mult or 1)
        local sp = pos:add(vector2(-spread, -spread + spread * 0.5))
        local ss = size:add(vector2(spread * 2, spread * 2))
        render.add_rect_filled(sp, sp:add(ss), color(0, 0, 0, a), radius + i)
    end
end

local function get_clipped_text(text, max_width)
    if render.get_text_size(text).x <= max_width then return text end
    local t = text
    while render.get_text_size(t.."...").x > max_width and #t > 0 do t = string.sub(t, 1, -2) end
    return t.."..."
end

