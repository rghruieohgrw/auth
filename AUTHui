hook.add("render", "key_picker_handler", function()
    if Library.ActiveKeyPicker then
        for vk, name in pairs(KEY_NAMES) do
            if input.is_key_pressed(vk) then
                Library.ActiveKeyPicker:SetValue(name)
                Library.ActiveKeyPicker.Picking = false
                Library.ActiveKeyPicker = nil
                break
            end
        end
    end
end)

