-- ========== HELPERS ==========
local function lerp(a, b, t) return a + (b - a) * t end

local function apply_alpha(col, mult)
    return color(col.r, col.g, col.b, (col.a or 1) * mult)
end

local function is_mouse_in_rect(pos, size)
    if not pos or not size then return false end
    local m = input.get_mouse_position()
    return m.x >= pos.x and m.x <= pos.x + size.x
       and m.y >= pos.y and m.y <= pos.y + size.y
end

local function get_clipped_text(text, max_width)
    if render.get_text_size(text).x <= max_width then return text end
    local t = text
    while #t > 0 and render.get_text_size(t .. "...").x > max_width do
        t = string.sub(t, 1, -2)
    end
    return t .. "..."
end

local function draw_checkerboard(pos, size, sq)
    local c1 = color(0.2, 0.2, 0.2, 1)
    local c2 = color(0.1, 0.1, 0.1, 1)
    for y = 0, math.ceil(size.y / sq) - 1 do
        for x = 0, math.ceil(size.x / sq) - 1 do
            local p = pos:add(vector2(x * sq, y * sq))
            local s = vector2(math.min(sq, size.x - x * sq), math.min(sq, size.y - y * sq))
            render.add_rect_filled(p, p:add(s), (x + y) % 2 == 0 and c1 or c2, 0)
        end
    end
end

local function draw_shadow(pos, size, radius, alpha_mult)
    for i = 1, 8 do
        local spread = i * 3
        local a = (1 - i / 8) * 0.18 * (alpha_mult or 1)
        local sp = pos:add(vector2(-spread, -spread + spread * 0.5))
        local ss = size:add(vector2(spread * 2, spread * 2))
        render.add_rect_filled(sp, sp:add(ss), color(0, 0, 0, a), radius + i)
    end
end

local function rgb_to_hsv(c)
    local r, g, b = c.r, c.g, c.b
    local maxc = math.max(r, g, b)
    local diff = maxc - math.min(r, g, b)
    local h, s = 0, 0
    if maxc ~= 0 then s = diff / maxc else return 0, 0, 0 end
    if diff > 1e-5 then
        if maxc == r then h = (g - b) / diff
        elseif maxc == g then h = 2 + (b - r) / diff
        else h = 4 + (r - g) / diff end
        h = h / 6
        if h < 0 then h = h + 1 end
    end
    return h, s, maxc
end

local function hsv_to_rgb(h, s, v, a)
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    local r, g, b
    i = i % 6
    if i == 0 then r,g,b = v,t,p
    elseif i == 1 then r,g,b = q,v,p
    elseif i == 2 then r,g,b = p,v,t
    elseif i == 3 then r,g,b = p,q,v
    elseif i == 4 then r,g,b = t,p,v
    else r,g,b = v,p,q end
    return color(r, g, b, a or 1)
end

-- ========== GLASS PANEL ==========
local function glass_panel(pos, size, radius, alpha)
    local a      = (alpha or 1)
    local gc     = Library._GlobalGlassColor
    local trans  = Library._GlobalGlassTrans
    local blur   = Library._GlobalBlur
    if blur > 0 and render.blur_rect then
        render.blur_rect(pos, pos:add(size), blur, radius)
    end
    render.add_rect_filled(pos, pos:add(size),
        color(gc.r * 0.12, gc.g * 0.12, gc.b * 0.14, trans * a), radius)
    local shimmer_h = math.min(size.y, 20)
    render.add_rect_filled(pos, pos:add(vector2(size.x, shimmer_h)),
        color(gc.r, gc.g, gc.b, 0.06 * a), radius)
    render.add_rect_filled(pos, pos:add(size),
        color(gc.r * 0.6, gc.g * 0.65, gc.b * 0.95, 0.05 * a), radius)
    render.add_rect(pos, pos:add(size),
        color(gc.r, gc.g, gc.b, 0.12 * a), radius, 1)
    render.add_rect(
        pos:add(vector2(1, 1)),
        pos:add(size):add(vector2(-1, -1)),
        color(gc.r * 0.5, gc.g * 0.55, gc.b * 0.85, 0.20 * a),
        math.max(radius - 1, 0), 1)
end

-- ========== SPOTIFY MODULE (FIXED) ==========

local Spotify = {
    Enabled      = false,
    WS           = nil,
    Track        = {
        name       = "",
        artist     = "",
        progress   = 0,
        duration   = 1,
        is_playing = false,
        idle       = true,
    },
    AlbumTexture  = nil,
    LastArtUrl    = "",
    WORKER_URL    = "wss://photon.photon-player.workers.dev/ws",
    AUTH_URL      = "https://photon.photon-player.workers.dev/auth",
    ART_PATH      = "photon_configs/spotify_art.jpg",
    _last_poll_ms = 0,
    _rendered_progress = 0,
}

function Spotify:FetchArt(url)
    if url == "" or url == self.LastArtUrl then return end
    self.LastArtUrl = url
    http.get(url, function(body, code)
        if code == 200 then
            if not file.exists("photon_configs/") then
                file.write("photon_configs/.keep", "")
            end
            file.overwrite(self.ART_PATH, body, "binary")
            local tex = render.load_texture(self.ART_PATH)
            if tex then self.AlbumTexture = tex.id end
        end
    end)
end

function Spotify:Connect()
    local hwid = get_hwid()
    local ws = websocket.connect(self.WORKER_URL .. "?hwid=" .. hwid)
    if not ws then
        Library:Notify("Spotify: failed to connect", "warning")
        return
    end
    self.WS = ws
    Library:Notify("Spotify connected!", 3)

    spawn(function()
        while self.Enabled and self.WS and self.WS:is_connected() do
            local msg = self.WS:recv()
            if msg then
                local ok, data = pcall(JSON_to_table, msg)
                if ok and data then
                    if data.type == "error" and data.message == "not_authed" then
                        local link = self.AUTH_URL .. "?hwid=" .. hwid
                        input.setclipboard(link)
                        Library:Notify("Spotify: auth URL copied! Paste in browser.", 6)

                    elseif data.type == "idle" then
                        self.Track.idle       = true
                        self.Track.is_playing = false

                    elseif data.type == "track" then
                        -- FIXED: Convert all values to proper types
                        self.Track.name       = tostring(data.name or "")
                        self.Track.artist     = tostring(data.artist or "")
                        self.Track.progress   = tonumber(data.progress) or 0
                        self.Track.duration   = tonumber(data.duration) or 1
                        self.Track.is_playing = data.is_playing == true
                        self.Track.idle       = false
                        
                        -- Safe division
                        local duration = self.Track.duration
                        if duration and duration > 0 then
                            self._rendered_progress = (self.Track.progress or 0) / duration
                        else
                            self._rendered_progress = 0
                        end
                        self._last_poll_ms    = get_tickcount()
                        if data.changed then
                            self.AlbumTexture = nil
                            self:FetchArt(data.art_url or "")
                        end
                    end
                end
            end
            wait(50)
        end

        if self.Enabled then
            self.WS = nil
            wait(2000)
            self:Connect()
        end
    end)
end

function Spotify:Disconnect()
    self.Enabled = false
    if self.WS then
        self.WS:close()
        self.WS = nil
    end
    Library:Notify("Spotify disconnected", 2)
end

function Spotify:TickProgress()
    if not self.Track.is_playing or self.Track.idle then return end
    
    -- FIXED: Convert to numbers safely
    local progress = tonumber(self.Track.progress) or 0
    local duration = tonumber(self.Track.duration) or 1
    local last_poll = tonumber(self._last_poll_ms) or 0
    local elapsed = get_tickcount() - last_poll
    
    if duration <= 0 then duration = 1 end
    
    self._rendered_progress = math.min((progress + elapsed) / duration, 1)
end

local function spotify_format_ms(ms)
    local num_ms = tonumber(ms) or 0
    local s = math.floor(num_ms / 1000)
    return string.format("%d:%02d", math.floor(s / 60), s % 60)
end

