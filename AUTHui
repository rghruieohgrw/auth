                                local b_size = vector2(group_size.x - 20, 24)
                                local is_hover = is_mouse_in_rect(b_pos, b_size)
                                element.HoverAnim = element.HoverAnim + ((is_hover and 1 or 0) - element.HoverAnim) * 0.07
                                local ha = element.HoverAnim
                                local bg = color(
                                    Library.BackgroundColor.r + (Library.FontColor.r - Library.BackgroundColor.r) * ha,
                                    Library.BackgroundColor.g + (Library.FontColor.g - Library.BackgroundColor.g) * ha,
                                    Library.BackgroundColor.b + (Library.FontColor.b - Library.BackgroundColor.b) * ha, 1)
                                local fg = color(
                                    Library.FontColor.r + (Library.BackgroundColor.r - Library.FontColor.r) * ha,
                                    Library.FontColor.g + (Library.BackgroundColor.g - Library.FontColor.g) * ha,
                                    Library.FontColor.b + (Library.BackgroundColor.b - Library.FontColor.b) * ha, 1)
                                render.add_rect_filled(b_pos, b_pos:add(b_size), apply_alpha(bg, wa), 6)
                                render.add_rect(b_pos, b_pos:add(b_size), apply_alpha(Library.OutlineColor, wa), 6, 1)
                                render.add_text(b_pos:add(vector2(b_size.x / 2 - render.get_text_size(element.Text).x / 2, 4)), element.Text, apply_alpha(fg, wa))
