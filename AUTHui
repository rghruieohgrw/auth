-- ═══════════════════════════════════════════════════
--  JSON helpers (compact, no deps)
-- ═══════════════════════════════════════════════════
local function tojson(v)
    local t=type(v)
    if t=="string" then return'"'..v:gsub('"','\\"')..'"'
    elseif t=="number" or t=="boolean" then return tostring(v)
    elseif t=="table" then
        local arr,max={},0
        for k in pairs(v) do
            if type(k)~="number" or k~=math.floor(k) or k<=0 then arr=nil;break end
            if k>max then max=k end
        end
        local items={}
        if arr~=nil and max>0 then
            for i=1,max do items[i]=tojson(v[i]) end
            return"["..table.concat(items,",").."]"
        else
            for k,val in pairs(v) do items[#items+1]=tojson(k)..":"..tojson(val) end
            return"{"..table.concat(items,",").."}"
        end
    end
    return"null"
end
local function fromjson(s)
    local f=load("return "..s,"j"); if not f then return nil end
    local ok,r=pcall(f); return ok and r or nil
end

-- ═══════════════════════════════════════════════════
--  CONFIG SYSTEM  (uses file.list when available)
-- ═══════════════════════════════════════════════════
function L:GetConfigList()
    -- Try file.list first (no manifest needed)
    if file.list then
        local list={}
        for _,f in ipairs(file.list(self.ConfigFolder) or {}) do
            local n=f:match("^(.+)%.json$")
            if n and n~="manifest" then list[#list+1]=n end
        end
        self.ConfigList=list
        return list
    end
    -- Fallback: manifest
    local mf=self.ConfigFolder.."manifest.json"
    if file.exists(mf) then
        local d=fromjson(file.read(mf))
        if d and d.configs then self.ConfigList=d.configs; return d.configs end
    end
    return {}
end

local function ensure_folder(L)
    if not file.exists(L.ConfigFolder) then file.write(L.ConfigFolder..".keep","") end
end

local function manifest_add(L,name)
    if file.list then return end -- not needed with file.list
    local list=L:GetConfigList()
    local found=false
    for _,n in ipairs(list) do if n==name then found=true;break end end
    if not found then list[#list+1]=name end
    file.write(L.ConfigFolder.."manifest.json",tojson({configs=list,ts=get_unixtime()}))
    L.ConfigList=list
end

local function manifest_remove(L,name)
    if file.list then return end
    local old=L:GetConfigList(); local new={}
    for _,n in ipairs(old) do if n~=name then new[#new+1]=n end end
    file.write(L.ConfigFolder.."manifest.json",tojson({configs=new,ts=get_unixtime()}))
    L.ConfigList=new
end

function L:SaveConfig(name)
    ensure_folder(self)
    local cfg={toggles={},options={},windows={},v=2,t=get_unixtime(),g=get_placeid()}
    for id,tg in pairs(self.Toggles) do cfg.toggles[id]=tg.Value end
    for id,op in pairs(self.Options) do
        local t=op.Type
        if     t=="Slider"      then cfg.options[id]={t="S",v=op.Value}
        elseif t=="Dropdown"    then cfg.options[id]={t="D",v=op.Value,m=op.Multi}
        elseif t=="Input"       then cfg.options[id]={t="I",v=op.Value}
        elseif t=="KeyPicker"   then cfg.options[id]={t="K",v=op.Value,mode=op.Mode}
        elseif t=="ColorPicker" then
            local c=op.Value; cfg.options[id]={t="C",r=c.r,g=c.g,b=c.b,a=c.a}
        end
    end
    for i,w in ipairs(self.Windows) do cfg.windows[i]={x=w.Pos.x,y=w.Pos.y} end
    cfg.wm={x=self.Watermark.Pos.x,y=self.Watermark.Pos.y}
    file.write(self.ConfigFolder..name..".json",tojson(cfg))
    manifest_add(self,name)
    self.CurrentConfig=name
    self:Notify("Saved: "..name,3)
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue(name)
    end
end

function L:LoadConfig(name)
    local path=self.ConfigFolder..name..".json"
    if not file.exists(path) then self:Notify("Not found: "..name,3);return end
    local cfg=fromjson(file.read(path)); if not cfg then self:Notify("Bad config",3);return end
    for id,v in pairs(cfg.toggles or {}) do
        if self.Toggles[id] then self.Toggles[id]:SetValue(v) end
    end
    for id,d in pairs(cfg.options or {}) do
        local op=self.Options[id]; if not op then goto cont end
        local t=d.t
        if     t=="S" then op:SetValue(d.v)
        elseif t=="D" then op:SetValue(d.v)
        elseif t=="I" then op:SetValue(d.v)
        elseif t=="K" then op:SetValue(d.v); if d.mode then op.Mode=d.mode end
        elseif t=="C" then op:SetValue(color(d.r,d.g,d.b,d.a)) end
        ::cont::
    end
    for i,wd in ipairs(cfg.windows or {}) do
        if self.Windows[i] then self.Windows[i].Pos=vector2(wd.x,wd.y) end
    end
    if cfg.wm then self.Watermark.Pos=vector2(cfg.wm.x,cfg.wm.y) end
    self.CurrentConfig=name
    self:Notify("Loaded: "..name,3)
    if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
end

function L:DeleteConfig(name)
    local path=self.ConfigFolder..name..".json"
    if file.exists(path) then file.write(path,"") end
    manifest_remove(self,name)
    if self.CurrentConfig==name then self.CurrentConfig="" end
    self:Notify("Deleted: "..name,3)
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue("")
    end
end

function L:ResetAll()
    for _,tg in pairs(self.Toggles) do tg:SetValue(false) end
    for _,op in pairs(self.Options) do
        local t=op.Type
        if     t=="Slider"    then op:SetValue((op.Min+op.Max)/2)
        elseif t=="Dropdown"  then if not op.Multi and op.Values[1] then op:SetValue(op.Values[1]) end
        elseif t=="Input"     then op:SetValue("")
        elseif t=="KeyPicker" then op:SetValue("...")
        elseif t=="ColorPicker" then op:SetValue(self.AccentColor) end
    end
    self.CurrentConfig=""
    if self.ConfigDropdown then self.ConfigDropdown:SetValue("") end
    self:Notify("Reset complete",3)
end

-- Config section builder  (uses name-input modal for Save As)
function L:CreateConfigSection(groupbox)
    local dd=groupbox:AddDropdown("cfg_dd",{
        Text="Config",Default=1,Values=self:GetConfigList(),Tooltip="Select config"})
    self.ConfigDropdown=dd
    groupbox:AddButton({Text="Save As…",Tooltip="Name and save a new config",Func=function()
        self.CfgModal.Active=true; self.CfgModal.Value=""; self.CfgModal.Alpha=0
    end})
    groupbox:AddButton({Text="Overwrite",Tooltip="Overwrite currently loaded config",Func=function()
        if self.CurrentConfig~="" then self:SaveConfig(self.CurrentConfig)
        else self:Notify("No config loaded",3) end
    end})
    groupbox:AddDivider()
    groupbox:AddButton({Text="Delete",DoubleClick=true,Tooltip="Double-click to delete",Func=function()
        if dd.Value and dd.Value~="" then self:DeleteConfig(dd.Value)
        else self:Notify("Nothing selected",3) end
    end})
    groupbox:AddButton({Text="Reset Defaults",DoubleClick=true,Tooltip="Double-click to reset all",Func=function()
        self:ResetAll()
    end})
    groupbox:AddButton({Text="Refresh",Func=function()
        dd:SetValues(self:GetConfigList()); self:Notify("Refreshed",2)
    end})
    dd:OnChanged(function(v) if v and v~="" then self:LoadConfig(v) end end)
    return dd
end

