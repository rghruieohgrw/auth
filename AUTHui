function L:LoadBrush()
    if self.BrushLoaded then return end
    self.BrushLoaded=true
    local path="icons/brush.png"
    local function lt() local tx=render.load_texture(path); if tx then self.BrushTexture=tx.id end end
    if file.exists(path) then lt()
    else
        http.get("https://raw.githubusercontent.com/rghruieohgrw/visuals/refs/heads/main/color.png",function(b,st)
            if st==200 then
                if not file.exists("icons/") then file.write("icons/.keep","") end
                file.write(path,b,"binary"); lt()
            end
        end)
    end
end

function L:LoadPfp()
    if self.PfpLoaded then return end
    self.PfpLoaded=true
    local path="icons/pfp_".._userid..".png"
    local function lt() local tx=render.load_texture(path); if tx then self.PfpTexture=tx.id end end
    if file.exists(path) then lt()
    else
        local api="https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=".._userid.."&size=48x48&format=Png"
        http.get(api,function(body,st)
            if st~=200 then return end
            local url=body:match('"imageUrl"%s*:%s*"([^"]+)"')
            if not url then return end
            http.get(url,function(img,ist)
                if ist~=200 then return end
                if not file.exists("icons/") then file.write("icons/.keep","") end
                file.write(path,img,"binary"); lt()
            end)
        end)
    end
end

