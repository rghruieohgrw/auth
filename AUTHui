-- ============================================================================
function Library:Notify(message, style)
    local styles = {
        [1] = { name = "Info", colour = color(0.3, 0.6, 1, 1) },
        [2] = { name = "Success", colour = color(0.3, 0.9, 0.4, 1) },
        [3] = { name = "Warning", colour = color(1, 0.7, 0.2, 1) },
        [4] = { name = "Error", colour = color(1, 0.3, 0.3, 1) }
    }
    local s = styles[style] or styles[1]
    table.insert(self.Notifications, {
        text = message,
        colour = s.colour,
        alpha = 1,
        y_offset = 0,
        time = get_tickcount()
    })
    print(string.format("[%s] %s", s.name, message))
end

-- ============================================================================
-- TOOLTIP SYSTEM
-- ============================================================================
function Library:DrawTooltip()
    if not self.Tooltip or self.TooltipAlpha <= 0 then return end
    local mouse = input.get_mouse_position()
    local padding = 8
    local text_size = render.get_text_size(self.Tooltip)
    local bg_pos = mouse + vector2(15, 15)
    local bg_size = vector2(text_size.x + padding * 2, text_size.y + padding)
    render.add_rect_filled(bg_pos, bg_pos + bg_size, color(0.1, 0.1, 0.12, self.TooltipAlpha), 6)
    render.add_text(bg_pos + vector2(padding, padding), self.Tooltip, color(1, 1, 1, self.TooltipAlpha), 12)
    self.TooltipAlpha = math.max(0, self.TooltipAlpha - 0.05)
end

-- ============================================================================
-- CONFIGURATION SYSTEM
-- ============================================================================
function Library:GetConfigList()
    local configs = {}
    if not file.exists(self.ConfigFolder) then
        file.write(self.ConfigFolder .. ".keep", "")
    end
    local files = file.list_folder(self.ConfigFolder)
    if files then
        for _, name in ipairs(files) do
            local stem = name:match("^(.+)%.json$")
            if stem and stem ~= "manifest" then
                table.insert(configs, stem)
            end
        end
    end
    table.sort(configs)
    return configs
end

function Library:SaveConfig(name)
    if not file.exists(self.ConfigFolder) then
        file.write(self.ConfigFolder .. ".keep", "")
    end

    local config = {
        toggles = {},
        options = {},
        version = 2,
        saved_at = get_unixtime(),
        game = get_placeid()
    }

    for id, toggle in pairs(self.Toggles) do
        config.toggles[id] = toggle.Value
    end

    for id, opt in pairs(self.Options) do
        if opt.Type == "Slider" then
            config.options[id] = { type = "Slider", value = opt.Value }
        elseif opt.Type == "Dropdown" then
            config.options[id] = { type = "Dropdown", value = opt.Value, multi = opt.Multi or false }
        elseif opt.Type == "Input" then
            config.options[id] = { type = "Input", value = opt.Value }
        elseif opt.Type == "KeyPicker" then
            config.options[id] = { type = "KeyPicker", value = opt.Value, mode = opt.Mode or "Hold" }
        elseif opt.Type == "ColorPicker" then
            local c = opt.Value
            config.options[id] = { type = "ColorPicker", value = { r = c.r, g = c.g, b = c.b, a = c.a } }
        end
    end

    config.windows = {}
    for i, win in ipairs(self.Windows) do
        config.windows[i] = { pos = { x = win.Pos.x, y = win.Pos.y } }
    end
    config.watermark = { x = self.Watermark.Pos.x, y = self.Watermark.Pos.y }

    local json_str = self:TableToJSON(config)
    file.write(self.ConfigFolder .. name .. ".json", json_str)
    self.CurrentConfig = name
    self:Notify("Config saved: " .. name, 2)

    if self.ConfigDropdown then
        self.ConfigDropdown:SetValues(self:GetConfigList())
        self.ConfigDropdown:SetValue(name)
    end
    return true
end

function Library:LoadConfig(name)
    local filename = self.ConfigFolder .. name .. ".json"
    if not file.exists(filename) then
        self:Notify("Config not found: " .. name, 3)
        return false
    end

    local json_str = file.read(filename)
    if not json_str or json_str == "" then
        self:Notify("Config is empty: " .. name, 3)
        return false
    end

    local config = self:JSONToTable(json_str)
    if not config then
        self:Notify("Failed to parse config: " .. name, 3)
        return false
    end

    for id, value in pairs(config.toggles or {}) do
        if self.Toggles[id] then
            self.Toggles[id]:SetValue(value)
        end
    end

    for id, data in pairs(config.options or {}) do
        if self.Options[id] then
            if data.type == "Slider" then
                self.Options[id]:SetValue(data.value)
            elseif data.type == "Dropdown" then
                self.Options[id]:SetValue(data.value)
            elseif data.type == "Input" then
                self.Options[id]:SetValue(data.value)
            elseif data.type == "KeyPicker" then
                self.Options[id]:SetValue(data.value)
                if data.mode then self.Options[id].Mode = data.mode end
            elseif data.type == "ColorPicker" then
                local c = data.value
                self.Options[id]:SetValue(color(c.r, c.g, c.b, c.a))
            end
        end
    end

    for i, win_data in ipairs(config.windows or {}) do
        if self.Windows[i] then
            self.Windows[i].Pos = vector2(win_data.pos.x, win_data.pos.y)
        end
    end

    if config.watermark then
        self.Watermark.Pos = vector2(config.watermark.x, config.watermark.y)
    end

    self.ConfigLoaded = true
    self.CurrentConfig = name
    self:Notify("Config loaded: " .. name, 2)

    if self.ConfigDropdown then
        self.ConfigDropdown:SetValue(name)
    end
    return true
end

function Library:DeleteConfig(name)
    local filename = self.ConfigFolder .. name .. ".json"
    if file.exists(filename) then
        pcall(function() file.delete_file(filename) end)
        self:Notify("Config deleted: " .. name, 3)
        if self.CurrentConfig == name then
            self.CurrentConfig = ""
        end
        if self.ConfigDropdown then
            self.ConfigDropdown:SetValues(self:GetConfigList())
            self.ConfigDropdown:SetValue("")
        end
        return true
    end
    return false
end

function Library:ResetAll()
    for id, toggle in pairs(self.Toggles) do
        toggle:SetValue(false)
    end
    for id, opt in pairs(self.Options) do
        if opt.Type == "Slider" then
            opt:SetValue((opt.Min + opt.Max) / 2)
        elseif opt.Type == "Dropdown" and not opt.Multi then
            opt:SetValue(opt.Values[1])
        elseif opt.Type == "Input" then
            opt:SetValue("")
        elseif opt.Type == "KeyPicker" then
            opt:SetValue("...")
        elseif opt.Type == "ColorPicker" then
            opt:SetValue(color(1, 1, 1, 1))
        end
    end
    self.CurrentConfig = ""
    if self.ConfigDropdown then
        self.ConfigDropdown:SetValue("")
    end
    self:Notify("All settings reset!", 2)
end

-- Simple JSON functions
function Library:TableToJSON(tbl)
    local function serialize(val)
        if type(val) == "string" then
            return '"' .. val:gsub('"', '\\"') .. '"'
        elseif type(val) == "number" then
            return tostring(val)
        elseif type(val) == "boolean" then
            return val and "true" or "false"
        elseif type(val) == "table" then
            local items = {}
            local is_array = true
            local max_idx = 0
            for k, v in pairs(val) do
                if type(k) ~= "number" or k ~= math.floor(k) or k <= 0 then
                    is_array = false
                    break
                end
                if k > max_idx then max_idx = k end
            end
            if is_array and max_idx > 0 then
                for i = 1, max_idx do
                    table.insert(items, serialize(val[i]))
                end
                return "[" .. table.concat(items, ",") .. "]"
            else
                for k, v in pairs(val) do
                    table.insert(items, serialize(k) .. ":" .. serialize(v))
                end
                return "{" .. table.concat(items, ",") .. "}"
            end
        else
            return "null"
        end
    end
    return serialize(tbl)
end

function Library:JSONToTable(str)
    local safe_str = "return " .. str
    local func, err = load(safe_str, "json_parse")
    if func then
        local success, result = pcall(func)
        if success then return result end
    end
    return nil
end

-- ============================================================================
-- UI ELEMENT CREATION
-- ============================================================================
local ElementMethods = {}

function ElementMethods:OnChanged(func)
    self.OnChangedFunc = func
    return self
end

function ElementMethods:SetTooltip(text)
    self.Tooltip = text
    return self
end

local function CreateElement(base, methods)
    if type(methods) == "table" then
        for k, v in pairs(methods) do
            base[k] = v
        end
    end
    return setmetatable(base, { __index = ElementMethods })
end

local ToggleMethods = {}
function ToggleMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local SliderMethods = {}
function SliderMethods:SetValue(val)
    local rv = tonumber(string.format("%." .. (self.Rounding or 0) .. "f", val))
    self.Value = math.max(self.Min, math.min(rv, self.Max))
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local DropdownMethods = {}
function DropdownMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end
function DropdownMethods:SetValues(new_values)
    self.Values = new_values
    if not self.Multi and #new_values > 0 then
        self:SetValue(new_values[1])
    end
end

local InputMethods = {}
function InputMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local KeyPickerMethods = {}
function KeyPickerMethods:IsActive()
    if not self.Value or self.Value == "..." then return false end
    local key_map = { RButton = 0x02, LButton = 0x01, LAlt = 0x12, LShift = 0x10, LCtrl = 0x11 }
    local vk = key_map[self.Value]
    if not vk then return false end
    if self.Mode == "Hold" then
        return input.key_down(vk)
    elseif self.Mode == "Toggle" then
        return self.Active or false
    end
    return input.key_down(vk)
end
function KeyPickerMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
end

local ColorPickerMethods = {}
function ColorPickerMethods:SetValue(val)
    self.Value = val
    if self.Callback then self.Callback(self.Value) end
    if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
    local h, s, v = rgb_to_hsv(val)
    self.Hue, self.Saturation, self.ValueHSV = h, s, v
    self.Alpha = val.a
end

