                                render.add_rect(k_pos, k_pos:add(k_size), element.Picking and apply_alpha(accent, wa) or apply_alpha(Library.OutlineColor, wa), 6, 1)
                                render.add_text(k_pos:add(vector2(k_size.x / 2 - render.get_text_size(element.Value).x / 2, 3)), element.Value, apply_alpha(Library.FontColor, wa))
                                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(k_pos, k_size) then
                                    element.Picking = true
                                end
                                
                            elseif element.Type == "ColorPicker" then
