function Library:LoadBrushIcon()
    if self.BrushLoaded then return end
    self.BrushLoaded=true
    local path="icons/brush.png"
    if file.exists(path) then
        local tex=render.load_texture(path)
        if tex then self.BrushTexture=tex.id end
    else
        http.get("https://raw.githubusercontent.com/rghruieohgrw/visuals/refs/heads/main/color.png",
            function(body, status)
                if status==200 then
                    if not file.exists("icons/") then file.write("icons/.keep","") end
                    file.write(path, body, "binary")
                    local tex=render.load_texture(path)
                    if tex then self.BrushTexture=tex.id end
                end
            end)
    end
end

-- ────────────────────────────────────────────
--  WINDOW CREATION
-- ────────────────────────────────────────────
function Library:CreateWindow(cfg)
    local sz  = cfg.Size or vector2(580, 620)
    local scr = get_screen_size()
    local win = {
        Title       = cfg.Title or "Window",
        Pos         = cfg.Center
                        and vector2(scr.x/2 - sz.x/2, scr.y/2 - sz.y/2)
                        or  vector2(175, 50),
        Size        = sz,
        Visible     = cfg.AutoShow or false,
        Tabs        = {},
        ActiveTab   = nil,
        Alpha       = cfg.AutoShow and 1 or 0,
        TargetAlpha = cfg.AutoShow and 1 or 0,
        -- unified appearance
        Glass        = cfg.Glass or false,
        Color        = cfg.Color or color(1, 1, 1, 1),   -- tint for both glass + solid
        Transparency = cfg.Transparency or 0,             -- 0=opaque, 1=transparent
        Blur         = cfg.Blur or 0,                     -- 0..1 fake blur strength
    }

    function win:AddTab(name)
        local tab={Name=name, Parent=win, Groupboxes={}}

        function tab:AddLeftGroupbox(name, info)
            return self:AddGroupbox({Name=name, Side="Left", Dependencies=info and info.Dependencies})
        end
        function tab:AddRightGroupbox(name, info)
            return self:AddGroupbox({Name=name, Side="Right", Dependencies=info and info.Dependencies})
        end

        function tab:AddGroupbox(info)
            local gb={Name=info.Name, Side=info.Side or "Left", Parent=tab, Elements={}, Dependencies=info.Dependencies}

            function gb:IsVisible()
                if not self.Dependencies then return true end
                for _,dep in ipairs(self.Dependencies) do
                    if dep[1] and dep[1].Value~=dep[2] then return false end
                end
                return true
            end

            function gb:AddToggle(id, info)
                local el=CE({Id=id,Type="Toggle",Text=info.Text,Value=info.Default or false,
                    Callback=info.Callback,Height=28,Tooltip=info.Tooltip,Risky=info.Risky,
                    SwitchAnim=info.Default and 1 or 0}, TM)
                table.insert(self.Elements,el); Library.Toggles[id]=el; return el
            end

            function gb:AddSlider(id, info)
                local mn=info.Min or 0; local mx=info.Max or 100; local def=info.Default or 0
                local el=CE({Id=id,Type="Slider",Text=info.Text,Value=def,Min=mn,Max=mx,
                    Rounding=info.Rounding or 0,Suffix=info.Suffix or "",Callback=info.Callback,
                    Height=50,Tooltip=info.Tooltip,
                    ThumbAnim=(mx~=mn) and (def-mn)/(mx-mn) or 0, BubbleAlpha=0}, SM)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end

            function gb:AddButton(info)
                local el={Type="Button",Text=info.Text,Func=info.Func,Height=30,
                    DoubleClick=info.DoubleClick,LastClick=0,Tooltip=info.Tooltip,HoverAnim=0}
                table.insert(self.Elements,el); return el
            end

            function gb:AddDropdown(id, info)
                local vals=info.Values or {}
                local el=CE({Id=id,Type="Dropdown",Text=info.Text,
                    Value=info.Multi and (info.Default or {}) or (info.Default and vals[info.Default] or vals[1]),
                    Values=vals,Open=false,Callback=info.Callback,Height=44,
                    Multi=info.Multi,Tooltip=info.Tooltip,HoverAlpha=0}, DM)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end

            function gb:AddInput(id, info)
                local el=CE({Id=id,Type="Input",Text=info.Text,Value=info.Default or "",
                    Placeholder=info.Placeholder or "",Callback=info.Callback,
                    Height=44,Tooltip=info.Tooltip}, IM)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end

            function gb:AddKeyPicker(id, info)
                local el=CE({Id=id,Type="KeyPicker",Text=info.Text,Value=info.Default or "...",
                    Callback=info.Callback,Picking=false,Height=44,Tooltip=info.Tooltip,
                    Mode=info.Mode or "Hold",Active=false}, KM)
                table.insert(self.Elements,el); Library.Options[id]=el; return el
            end

            function gb:AddColorPicker(id, info)
                local def=info.Default or Library.AccentColor
                local h,s,v=rgb_to_hsv(def)
                local el=CE({Id=id,Type="ColorPicker",Text=info.Text,Value=def,Open=false,
                    Callback=info.Callback,Height=28,Hue=h,Saturation=s,ValueHSV=v,
                    Alpha=def.a or 1,EnableAlpha=info.EnableAlpha or false,
                    Tooltip=info.Tooltip,HoverAnim=0,
                    layout={pos=vector2(0,0),size=vector2(0,0),
                            picker_pos=vector2(0,0),picker_size=vector2(0,0)}}, CPM)
                table.insert(self.Elements,el); Library.Options[id]=el
                el:InitWithTheme(); return el
            end

            function gb:AddDivider(h)
                table.insert(self.Elements,{Type="Divider",Height=h or 12}); return self
            end

            function gb:AddLabel(text)
                table.insert(self.Elements,{Type="Label",Text=text,Height=20}); return self
            end

            table.insert(self.Groupboxes,gb); return gb
        end

        table.insert(win.Tabs,tab)
        if not win.ActiveTab then win.ActiveTab=tab end
        return tab
    end

    table.insert(Library.Windows,win)
    return win
end

-- ────────────────────────────────────────────
--  PUBLIC API
-- ────────────────────────────────────────────
function Library:Notify(text, dur)
    table.insert(self.Notifications,{
        Text=text, Duration=dur or 4, StartTime=get_unixtime(),
        Alpha=0, TargetAlpha=1, OffsetX=28, TargetOffsetX=0,
    })
end
function Library:SetWatermark(t) self.Watermark.Text=t; self.Watermark.Visible=true end
function Library:OpenWindow(w)  w.Visible=true;  w.TargetAlpha=1 end
function Library:CloseWindow(w) w.TargetAlpha=0 end

-- ────────────────────────────────────────────
--  TOOLTIP + WATERMARK
-- ────────────────────────────────────────────
local function render_tooltip(alpha)
    if not Library.Tooltip or alpha<=0.01 then return end
    local mp  = _mp_cache
    local ts  = render.get_text_size(Library.Tooltip.Text)
    local tsz = vector2(ts.x+14, ts.y+10)
    local tp  = mp:add(vector2(16,16))
    draw_shadow(tp, tsz, 6, alpha)
    draw_panel(tp, tsz, 7, alpha, Library._G.glass)
    render.add_text(tp:add(vector2(7,5)), Library.Tooltip.Text, aa(Library.FontColor, alpha))
end

local function draw_watermark()
    if not Library.Watermark.Visible then return end
    local ts  = render.get_text_size(Library.Watermark.Text)
    local wsz = vector2(ts.x+16, 24)
    local pos = Library.Watermark.Pos
    draw_shadow(pos, wsz, 7, 1)
    draw_panel(pos, wsz, 7, 1, Library._G.glass)
    render.add_text(pos:add(vector2(8,4)), Library.Watermark.Text, Library.FontColor)
end

-- ────────────────────────────────────────────
--  MAIN RENDER HOOK
-- ────────────────────────────────────────────
hook.add("render", "auth_photon_render", function()
    -- refresh mouse cache once per frame
    _mp_cache = input.get_mouse_position()
    local mp       = _mp_cache
    local mpressed = input.is_key_pressed(0x01)
    local mdown    = input.key_down(0x01)

    -- tab fade animation
    local anim = Library.Animation
    if anim.State=="FadingOut" then
        anim.CurrentAlpha = anim.CurrentAlpha - anim.Speed
        if anim.CurrentAlpha<=0 then
            anim.CurrentAlpha=0
            if anim.PendingTab then
                anim.PendingTab.Parent.ActiveTab=anim.PendingTab
                anim.PendingTab=nil
            end
            anim.State="FadingIn"
        end
    elseif anim.State=="FadingIn" then
        anim.CurrentAlpha = anim.CurrentAlpha + anim.Speed
        if anim.CurrentAlpha>=1 then anim.CurrentAlpha=1; anim.State="Idle" end
    end

    -- rainbow
    Library.Hue = (Library.Hue + 0.0015) % 1
    Library.CurrentRainbowColor = hsv_to_rgb(Library.Hue, 0.8, 1)

    local accent = Library.AccentColor

    Library.ModalOpen = Library.OpenedDropdown or Library.ActiveColorPicker
        or Library.ActiveKeyPicker or Library.ActiveInput or Library.RightClickMenu

    -- resolve global glass state once per frame
    local G = Library._G
    G.glass = false
    for _, w in ipairs(Library.Windows) do
        if w.Glass and w.Visible and w.Alpha > 0.01 then
            G.glass = true
            G.color = w.Color
            G.trans = w.Transparency or 0
            G.blur  = w.Blur or 0
            break
        end
    end
    -- for non-glass windows, still push Color/Transparency through draw_panel
    if not G.glass then
        for _, w in ipairs(Library.Windows) do
            if w.Visible and w.Alpha > 0.01 then
                G.color = w.Color
                G.trans = w.Transparency or 0
                G.blur  = 0
                break
            end
        end
    end

    -- dismiss modals on outside click
    if mpressed and Library.ModalOpen then
        if Library.OpenedDropdown then
            local dd=Library.OpenedDropdown
            if dd.Layout and not (imr(dd.Layout.pos,dd.Layout.size) or imr(dd.Layout.list_pos,dd.Layout.list_size)) then
                dd.Open=false; Library.OpenedDropdown=nil
            end
        end
        if Library.ActiveColorPicker then
            local acp=Library.ActiveColorPicker
            if not imr(acp.layout.picker_pos, acp.layout.picker_size) then
                acp.obj.Open=false; Library.ActiveColorPicker=nil
            end
        end
        if Library.ActiveKeyPicker then
            if not imr(Library.ActiveKeyPicker.layout.pos, Library.ActiveKeyPicker.layout.size) then
                Library.ActiveKeyPicker.obj.Picking=false; Library.ActiveKeyPicker=nil
            end
        end
        if Library.ActiveInput then
            if not imr(Library.ActiveInput.layout.pos, Library.ActiveInput.layout.size) then
                Library.ActiveInput=nil
            end
        end
    end
    if mpressed and Library.RightClickMenu then
        local rcm=Library.RightClickMenu
        if not imr(rcm.pos, rcm.size) then Library.RightClickMenu=nil end
    end

    -- drags
    if Library.DraggingWindow then
        if mdown then Library.DraggingWindow.Pos=mp:subtract(Library.DragOffset)
        else Library.DraggingWindow=nil end
    end
    if Library.ActiveSlider then
        if mdown then
            local s,l=Library.ActiveSlider.obj, Library.ActiveSlider.layout
            local r=(clamp(mp.x, l.pos.x, l.pos.x+l.size.x)-l.pos.x)/l.size.x
            s:SetValue(s.Min+(s.Max-s.Min)*r)
        else Library.ActiveSlider=nil end
    end
    if Library.ActiveColorPicker and mdown then
        local cp=Library.ActiveColorPicker.obj
        local ly=Library.ActiveColorPicker.layout
        if imr(ly.sv_pos, ly.sv_size) then
            cp.Saturation=clamp((mp.x-ly.sv_pos.x)/ly.sv_size.x,0,1)
            cp.ValueHSV=1-clamp((mp.y-ly.sv_pos.y)/ly.sv_size.y,0,1)
            cp:SetValue(hsv_to_rgb(cp.Hue,cp.Saturation,cp.ValueHSV,cp.Alpha))
        elseif ly.hue_pos and imr(ly.hue_pos, ly.hue_size) then
            cp.Hue=clamp((mp.y-ly.hue_pos.y)/ly.hue_size.y,0,1)
            cp:SetValue(hsv_to_rgb(cp.Hue,cp.Saturation,cp.ValueHSV,cp.Alpha))
        elseif cp.EnableAlpha and ly.alpha_pos and imr(ly.alpha_pos, ly.alpha_size) then
            cp.Alpha=clamp((mp.y-ly.alpha_pos.y)/ly.alpha_size.y,0,1)
            cp:SetValue(hsv_to_rgb(cp.Hue,cp.Saturation,cp.ValueHSV,cp.Alpha))
        end
    end

    -- watermark drag
    local wm_ts  = render.get_text_size(Library.Watermark.Text)
    local wm_sz  = vector2(wm_ts.x+16, 24)
    if not Library.DraggingWatermark and mpressed and imr(Library.Watermark.Pos, wm_sz) then
        Library.DraggingWatermark=true; Library.DragOffset=mp:subtract(Library.Watermark.Pos)
    end
    if Library.DraggingWatermark then
        if mdown then Library.Watermark.Pos=mp:subtract(Library.DragOffset)
        else Library.DraggingWatermark=false end
    end

    local can_interact = not Library.ModalOpen and anim.State=="Idle"
    Library.Tooltip = nil

    -- ════════════════════════ WINDOWS ════════════════════════
    for _, window in ipairs(Library.Windows) do
        if window.Visible then
            window.Alpha = lerp(window.Alpha, window.TargetAlpha, LERP_SLOW)
            if window.TargetAlpha==0 and window.Alpha<0.01 then
                window.Alpha=0; window.Visible=false
                goto continue_window
            end
            local wa    = window.Alpha
            local glass = window.Glass

            -- title bar drag
            if not Library.DraggingWindow and mpressed
                and imr(window.Pos, vector2(window.Size.x,34)) and not Library.ModalOpen
            then
                Library.DraggingWindow=window; Library.DragOffset=mp:subtract(window.Pos)
            end

            -- window background
            draw_shadow(window.Pos, window.Size, 12, wa)
            draw_panel(window.Pos, window.Size, 12, wa, glass)

            -- title
            render.add_text(window.Pos:add(vector2(14,10)), window.Title, aa(Library.FontColor, wa))

            -- divider line under title
            local tdx = window.Pos.x + 8
            render.add_line(vector2(tdx, window.Pos.y+32), vector2(tdx+window.Size.x-16, window.Pos.y+32),
                aa(Library.OutlineColor, wa), 1)

            -- inner pane
            local msp = window.Pos:add(vector2(12,36))
            local mss = vector2(window.Size.x-24, window.Size.y-48)
            render.add_rect_filled(msp, msp:add(mss),
                glass and color(0,0,0,0.06*wa) or aa(Library.BackgroundColor, wa), 8)

            -- tab strip
            local tab_y  = msp:add(vector2(4,4))
            local tab_x  = 0
            for _, tab in ipairs(window.Tabs) do
                local tw  = render.get_text_size(tab.Name).x + 22
                local tp2 = tab_y:add(vector2(tab_x, 0))
                local ts2 = vector2(tw, 26)
                local is_active = (anim.PendingTab or window.ActiveTab)==tab
                local tab_bg, tab_fg
                if glass then
                    tab_bg = is_active and color(1,1,1,0.16*wa) or color(1,1,1,0.04*wa)
                    tab_fg = is_active and aa(Library.FontColor,wa) or aa(Library.SecondaryFontColor,wa)
                else
                    tab_bg = is_active and aa(Library.AccentColor, 0.20*wa)
                                       or  aa(color(0.10,0.10,0.13,1), wa)
                    tab_fg = is_active and aa(Library.FontColor,wa) or aa(Library.SecondaryFontColor,wa)
                end
                render.add_rect_filled(tp2, tp2:add(ts2), tab_bg, 6)
                if is_active then
                    -- active tab bottom indicator line
                    render.add_rect_filled(
                        tp2:add(vector2(6, ts2.y-2)),
                        tp2:add(vector2(ts2.x-6, ts2.y)),
                        aa(Library.AccentColor, wa), 2)
                end
                render.add_text(tp2:add(vector2(11,5)), tab.Name, tab_fg)
                if not Library.DraggingWindow and mpressed and imr(tp2,ts2)
                    and anim.State=="Idle" and window.ActiveTab~=tab
                then
                    anim.State="FadingOut"; anim.PendingTab=tab
                end
                tab_x = tab_x + tw + 5
            end

            -- content
            if window.ActiveTab and anim.CurrentAlpha>0 then
                local op = anim.CurrentAlpha * wa
                local ca = msp:add(vector2(4, 38))
                local gw = window.Size.x/2 - 20
                local left_y, right_y = 0, 0

                for _, groupbox in ipairs(window.ActiveTab.Groupboxes) do
                    if groupbox:IsVisible() then
                        local is_left  = groupbox.Side=="Left"
                        local gp = ca:add(vector2(is_left and 0 or (window.Size.x/2-14),
                                                   is_left and left_y or right_y))
                        -- measure groupbox height
                        local ch = 34
                        for _, e in ipairs(groupbox.Elements) do ch=ch+e.Height end
                        local gs = vector2(gw, ch)

                        draw_shadow(gp, gs, 8, op*0.5)
                        draw_panel(gp, gs, 10, op, glass)

                        -- groupbox title with subtle separator
                        local gt_ts = render.get_text_size(groupbox.Name)
                        render.add_text(gp:add(vector2(10,9)), groupbox.Name, aa(Library.FontColor, op))
                        render.add_line(gp:add(vector2(10+gt_ts.x+6, 16)),
                            gp:add(vector2(gs.x-10, 16)), aa(Library.OutlineColor, op*0.6), 1)

                        local ey = 32
                        for _, element in ipairs(groupbox.Elements) do
                            local ep  = gp:add(vector2(10, ey))
                            local efw = vector2(gw-20, element.Height)
                            if element.Tooltip and imr(ep, efw) then
                                Library.Tooltip={Text=element.Tooltip}
                            end

                            -- ── Toggle ──
                            if element.Type=="Toggle" then
                                local tgt = element.Value and 1 or 0
                                element.SwitchAnim = lerp(element.SwitchAnim, tgt, LERP_FAST)
                                local sw_p = ep:add(vector2(0,5))
                                local sw_s = vector2(32, 18)
                                -- track
                                local fill=color(
                                    lerp(0.10, accent.r, element.SwitchAnim),
                                    lerp(0.10, accent.g, element.SwitchAnim),
                                    lerp(0.12, accent.b, element.SwitchAnim), 1)
                                render.add_rect_filled(sw_p, sw_p:add(sw_s), aa(fill,op), 9)
                                if glass then
                                    render.add_rect(sw_p, sw_p:add(sw_s), color(1,1,1, 0.10*op), 9, 1)
                                end
                                -- knob with smooth position + slight size pulse
                                local kx = lerp(sw_p.x+2, sw_p.x+sw_s.x-14, element.SwitchAnim)
                                local ks = lerp(10, 12, element.SwitchAnim)  -- knob grows when on
                                local kc = lerp(0.55, 1.0, element.SwitchAnim)
                                render.add_rect_filled(vector2(kx, sw_p.y+2), vector2(kx+ks, sw_p.y+sw_s.y-2),
                                    color(kc,kc,kc+0.02, op), 7)
                                render.add_text(ep:add(vector2(40,4)), element.Text,
                                    element.Risky and aa(Library.RiskColor,op) or aa(Library.FontColor,op))
                                if not Library.DraggingWindow and mpressed
                                    and imr(ep, vector2(gw-20,20)) and can_interact
                                then element:SetValue(not element.Value) end

                            -- ── Slider ──
                            elseif element.Type=="Slider" then
                                local ratio=(element.Value-element.Min)/(element.Max-element.Min)
                                element.ThumbAnim=lerp(element.ThumbAnim, ratio, LERP_FAST)
                                local sp   = ep:add(vector2(0,22))
                                local ss   = vector2(gw-20, 12)
                                local tx   = sp.x + ss.x*element.ThumbAnim
                                local hov  = imr(sp, ss)
                                local drag = Library.ActiveSlider and Library.ActiveSlider.obj==element
                                element.BubbleAlpha=lerp(element.BubbleAlpha, (hov or drag) and 1 or 0, LERP_MED)
                                render.add_text(ep, element.Text, aa(Library.SecondaryFontColor,op))
                                -- track bg
                                draw_inset(sp, ss, 6, op, glass, false)
                                -- fill
                                if element.ThumbAnim>0.002 then
                                    local fw=math.max(0, ss.x*element.ThumbAnim-2)
                                    render.add_rect_filled(sp:add(vector2(2,2)),
                                        sp:add(vector2(2+fw, ss.y-2)), aa(accent,op), 4)
                                end
                                -- thumb: pill shape
                                render.add_rect_filled(vector2(tx-4,sp.y-3), vector2(tx+4,sp.y+ss.y+3),
                                    aa(Library.FontColor,op), 4)
                                -- value bubble
                                if element.BubbleAlpha>0.02 then
                                    local vt  = tostring(element.Value)..element.Suffix
                                    local bw2 = render.get_text_size(vt).x+10
                                    local bp  = vector2(tx-bw2/2, sp.y-20)
                                    local ba  = element.BubbleAlpha*op
                                    draw_panel(bp, vector2(bw2,15), 4, ba, glass)
                                    render.add_text(bp:add(vector2(5,0)), vt, aa(Library.FontColor,ba))
                                end
                                if not Library.DraggingWindow and not Library.ActiveSlider
                                    and mpressed and imr(sp,ss) and can_interact
                                then
                                    Library.ActiveSlider={obj=element, layout={pos=sp,size=ss}}
                                end

                            -- ── Button ──
                            elseif element.Type=="Button" then
                                local bp   = ep
                                local bs   = vector2(gw-20, 24)
                                local hov  = imr(bp,bs)
                                element.HoverAnim=lerp(element.HoverAnim, hov and 1 or 0, LERP_MED)
                                local ha = element.HoverAnim
                                if glass then
                                    render.add_rect_filled(bp, bp:add(bs),
                                        color(1,1,1, lerp(0.05,0.18,ha)*op), 6)
                                    render.add_rect(bp, bp:add(bs),
                                        color(1,1,1, lerp(0.08,0.25,ha)*op), 6, 1)
                                else
                                    render.add_rect_filled(bp, bp:add(bs),
                                        color(lerp(Library.BackgroundColor.r,accent.r*0.6+0.12,ha*0.5),
                                              lerp(Library.BackgroundColor.g,accent.g*0.6+0.12,ha*0.5),
                                              lerp(Library.BackgroundColor.b,accent.b*0.6+0.14,ha*0.5), op), 6)
                                    render.add_rect(bp, bp:add(bs),
                                        aa(Library.OutlineColor, lerp(0.6,1,ha)*op), 6, 1)
                                end
                                local btn_text=element.Text
                                if element.DoubleClick and element.LastClick~=0
                                    and get_unixtime()-element.LastClick<1
                                then btn_text="Confirm?" end
                                local clip=clip_text(btn_text, bs.x-12)
                                local ct_x = bs.x/2 - render.get_text_size(clip).x/2
                                render.add_text(bp:add(vector2(ct_x,4)), clip,
                                    aa(Library.FontColor, op))
                                if not Library.DraggingWindow and mpressed and imr(bp,bs) and can_interact then
                                    if element.DoubleClick then
                                        if element.LastClick~=0 and get_unixtime()-element.LastClick<1 then
                                            if element.Func then element.Func() end; element.LastClick=0
                                        else element.LastClick=get_unixtime() end
                                    else
                                        if element.Func then element.Func() end
                                    end
                                end

                            -- ── Dropdown ──
                            elseif element.Type=="Dropdown" then
                                render.add_text(ep, element.Text, aa(Library.SecondaryFontColor,op))
                                local dp  = ep:add(vector2(0,18))
                                local ds  = vector2(gw-20, 22)
                                element.Layout={pos=dp,size=ds,list_pos=vector2(0,0),list_size=vector2(0,0)}
                                local hov = imr(dp,ds)
                                element.HoverAlpha=lerp(element.HoverAlpha, hov and 1 or 0, LERP_MED)
                                draw_inset(dp, ds, 6, op, glass, false)
                                -- hover tint
                                if element.HoverAlpha>0.01 then
                                    render.add_rect_filled(dp, dp:add(ds),
                                        color(1,1,1, 0.04*element.HoverAlpha*op), 6)
                                end
                                local disp
                                if element.Multi then
                                    local sel={}
                                    for k,v in pairs(element.Value) do if v then table.insert(sel,k) end end
                                    disp=#sel>0 and table.concat(sel,", ") or "None"
                                else disp=tostring(element.Value) end
                                render.add_text(dp:add(vector2(8,3)),
                                    clip_text(disp, ds.x-24), aa(Library.FontColor,op))
                                -- chevron ▾
                                render.add_triangle_filled(
                                    dp:add(vector2(ds.x-13,8)),
                                    dp:add(vector2(ds.x-5,8)),
                                    dp:add(vector2(ds.x-9,15)),
                                    aa(Library.FontColor,op))
                                if not Library.DraggingWindow and mpressed and imr(dp,ds) and can_interact then
                                    element.Open=not element.Open
                                    Library.OpenedDropdown=element.Open and element or nil
                                end

                            -- ── Input ──
                            elseif element.Type=="Input" then
                                render.add_text(ep, element.Text, aa(Library.SecondaryFontColor,op))
                                local ip  = ep:add(vector2(0,18))
                                local is  = vector2(gw-20, 22)
                                element.layout={pos=ip,size=is}
                                local act = Library.ActiveInput==element
                                draw_inset(ip, is, 6, op, glass, act)
                                local dt = #element.Value>0 and element.Value or element.Placeholder
                                local tc = #element.Value>0 and Library.FontColor or color(0.35,0.35,0.40,1)
                                render.add_text(ip:add(vector2(8,3)), clip_text(dt,is.x-14), aa(tc,op))
                                -- cursor blink
                                if act and (math.floor(get_unixtime()*2)%2==0) then
                                    local cw=render.get_text_size(clip_text(element.Value,is.x-14)).x
                                    render.add_line(ip:add(vector2(8+cw,5)), ip:add(vector2(8+cw,is.y-5)),
                                        aa(Library.FontColor,op), 1)
                                end
                                if not Library.DraggingWindow and mpressed and imr(ip,is) and can_interact then
                                    Library.ActiveInput=element
                                end

                            -- ── KeyPicker ──
                            elseif element.Type=="KeyPicker" then
                                render.add_text(ep, element.Text, aa(Library.SecondaryFontColor,op))
                                local kp  = ep:add(vector2(0,18))
                                local ks2 = vector2(gw-20, 22)
                                element.layout={pos=kp,size=ks2}
                                draw_inset(kp, ks2, 6, op, glass, element.Picking)
                                local mtag = element.Mode=="Hold" and " [H]" or element.Mode=="Toggle" and " [T]" or ""
                                local kt   = element.Picking and "press a key…" or (element.Value..mtag)
                                local ktw  = render.get_text_size(kt).x
                                render.add_text(kp:add(vector2(ks2.x/2-ktw/2,3)), kt, aa(Library.FontColor,op))
                                if not Library.DraggingWindow and mpressed and imr(kp,ks2) and can_interact then
                                    element.Picking=true
                                    Library.ActiveKeyPicker={obj=element,layout=element.layout}
                                end
                                if not Library.DraggingWindow and input.is_key_pressed(0x02)
                                    and imr(kp,ks2) and can_interact
                                then
                                    Library.RightClickMenu={obj=element,pos=mp,
                                        size=vector2(112,3*24+8),Alpha=0}
                                end

                            -- ── ColorPicker ──
                            elseif element.Type=="ColorPicker" then
                                local rw      = gw-20
                                local btn_sz  = vector2(22, 22)
                                local sw_w    = 22
                                -- label
                                local lh = render.get_text_size(element.Text).y
                                render.add_text(vector2(ep.x, ep.y+btn_sz.y/2-lh/2),
                                    element.Text, aa(Library.SecondaryFontColor,op))
                                -- swatch
                                local sw_p = vector2(ep.x+rw-sw_w-4-btn_sz.x, ep.y+2)
                                render.add_rect_filled(sw_p, sw_p:add(vector2(sw_w,btn_sz.y-4)),
                                    color(element.Value.r,element.Value.g,element.Value.b,op), 4)
                                render.add_rect(sw_p, sw_p:add(vector2(sw_w,btn_sz.y-4)),
                                    color(0,0,0,0.30*op), 4, 1)
                                -- icon button
                                local ico_p = vector2(ep.x+rw-btn_sz.x, ep.y)
                                element.layout.pos  = ico_p
                                element.layout.size = btn_sz
                                local hov   = imr(ico_p,btn_sz)
                                element.HoverAnim=lerp(element.HoverAnim, (hov or element.Open) and 1 or 0, LERP_MED)
                                -- bg
                                if glass then
                                    render.add_rect_filled(ico_p, ico_p:add(btn_sz),
                                        color(1,1,1, lerp(0.06,0.20,element.HoverAnim)*op), 5)
                                else
                                    render.add_rect_filled(ico_p, ico_p:add(btn_sz),
                                        color(lerp(0.10,accent.r*0.5+0.08,element.HoverAnim),
                                              lerp(0.10,accent.g*0.5+0.08,element.HoverAnim),
                                              lerp(0.12,accent.b*0.5+0.12,element.HoverAnim), op), 5)
                                end
                                render.add_rect(ico_p, ico_p:add(btn_sz),
                                    element.Open and aa(accent,0.60*op)
                                               or  (glass and color(1,1,1,0.12*op) or aa(Library.OutlineColor,op)),
                                    5, 1)
                                -- brush icon
                                if not Library.BrushLoaded then Library:LoadBrushIcon() end
                                if Library.BrushTexture then
                                    local iw,ih=14,10
                                    local tx=ico_p.x+(btn_sz.x-iw)/2
                                    local ty=ico_p.y+(btn_sz.y-ih)/2
                                    render.add_texture(Library.BrushTexture,vector2(tx,ty),vector2(tx+iw,ty+ih),op)
                                else
                                    render.add_circle_filled(
                                        vector2(ico_p.x+btn_sz.x/2,ico_p.y+btn_sz.y/2), 5,
                                        color(element.Value.r,element.Value.g,element.Value.b,op))
                                end
                                if not Library.DraggingWindow and mpressed and imr(ico_p,btn_sz) and can_interact then
                                    element.Open=not element.Open
                                    Library.ActiveColorPicker=element.Open and {obj=element,layout=element.layout} or nil
                                end

                            -- ── Divider ──
                            elseif element.Type=="Divider" then
                                local dy=ep.y+element.Height/2
                                render.add_line(vector2(ep.x,dy), vector2(ep.x+gw-20,dy),
                                    aa(Library.OutlineColor,op*0.5), 1)

                            -- ── Label ──
                            elseif element.Type=="Label" then
                                render.add_text(ep:add(vector2(0,2)), element.Text, aa(Library.SecondaryFontColor,op))
                            end

                            ey = ey + element.Height
                        end -- elements

                        if is_left then left_y=left_y+ch+10 else right_y=right_y+ch+10 end
                    end
                end -- groupboxes
            end -- tab content
        end -- window.Visible
        ::continue_window::
    end -- windows

    -- ════════════════ DROPDOWN LIST ════════════════
    if Library.OpenedDropdown then
        local e     = Library.OpenedDropdown
        local lp    = e.Layout.pos:add(vector2(0, e.Layout.size.y+3))
        local lh    = math.min(#e.Values,6)*22+4
        local ls    = vector2(e.Layout.size.x, lh)
        e.Layout.list_pos  = lp
        e.Layout.list_size = ls
        draw_shadow(lp, ls, 7, 1)
        draw_panel(lp, ls, 7, 1, G.glass)
        local iy = 2
        for _, value in ipairs(e.Values) do
            local ip  = lp:add(vector2(1,iy))
            local isz = vector2(ls.x-2, 22)
            local sel = (e.Multi and e.Value[value]) or (e.Value==value)
            local hov = imr(ip,isz)
            if hov then render.add_rect_filled(ip, ip:add(isz), aa(accent,0.15), 5) end
            render.add_text(ip:add(vector2(8,3)), value,
                (sel or hov) and aa(accent,1) or Library.FontColor)
            if sel then
                local dot_x = ip.x + isz.x - 10
                local dot_y = ip.y + isz.y/2
                render.add_circle_filled(vector2(dot_x, dot_y), 3, aa(accent,0.9))
            end
            if mpressed and hov then
                if e.Multi then e.Value[value]=not e.Value[value]; e:SetValue(e.Value)
                else e:SetValue(value); e.Open=false; Library.OpenedDropdown=nil end
            end
            iy = iy + 22
        end
    end

    -- ════════════════ COLOR PICKER ════════════════
    if Library.ActiveColorPicker then
        local e   = Library.ActiveColorPicker.obj
        local pad = 10; local sv_d=150; local bw=14; local br=5; local bg_gap=6
        local n_b = e.EnableAlpha and 2 or 1
        local bx  = pad+sv_d+pad
        local pw  = bx + bw*n_b + bg_gap*(n_b-1) + pad
        local ph  = pad+sv_d+pad
        local scr = get_screen_size()
        local pp  = e.layout.pos:add(vector2(0, e.layout.size.y+6))
        if pp.x+pw > scr.x-4 then pp=vector2(scr.x-pw-4, pp.y) end
        if pp.y+ph > scr.y-4 then pp=vector2(pp.x, e.layout.pos.y-ph-6) end
        e.layout.picker_pos  = pp
        e.layout.picker_size = vector2(pw,ph)
        draw_shadow(pp, vector2(pw,ph), 10, 1)
        draw_panel(pp, vector2(pw,ph), 12, 1, G.glass)

        local sv_p = pp:add(vector2(pad,pad))
        local sv_s = vector2(sv_d,sv_d)
        e.layout.sv_pos=sv_p; e.layout.sv_size=sv_s
        local hc = hsv_to_rgb(e.Hue,1,1)
        render.add_rect_filled(sv_p, sv_p:add(sv_s), color(1,1,1,1), br)
        for i=0,sv_d-1 do
            render.add_line(sv_p:add(vector2(i,0)), sv_p:add(vector2(i,sv_d)), color(hc.r,hc.g,hc.b,i/(sv_d-1)),1)
        end
        for i=0,sv_d-1 do
            render.add_line(sv_p:add(vector2(0,i)), sv_p:add(vector2(sv_d,i)), color(0,0,0,i/(sv_d-1)),1)
        end
        render.add_rect(sv_p, sv_p:add(sv_s), Library.OutlineColor, br, 1)
        local cx=sv_p.x+sv_s.x*e.Saturation; local cy=sv_p.y+sv_s.y*(1-e.ValueHSV)
        local rim=e.ValueHSV>0.4 and color(0,0,0,1) or color(1,1,1,1)
        render.add_circle(vector2(cx,cy),7,color(0,0,0,0.4),1)
        render.add_circle(vector2(cx,cy),5,rim,1)
        render.add_circle_filled(vector2(cx,cy),3,hsv_to_rgb(e.Hue,e.Saturation,e.ValueHSV,1))

        local hp=pp:add(vector2(bx,pad)); local hs=vector2(bw,sv_d)
        e.layout.hue_pos=hp; e.layout.hue_size=hs
        for i=0,sv_d-1 do
            render.add_line(hp:add(vector2(0,i)), hp:add(vector2(bw,i)), hsv_to_rgb(i/(sv_d-1),1,1),1)
        end
        render.add_rect(hp,hp:add(hs),Library.OutlineColor,br,1)
        local hcy=hp.y+hs.y*e.Hue; local th=6
        render.add_rect_filled(vector2(hp.x-2,hcy-th/2),vector2(hp.x+bw+2,hcy+th/2),color(1,1,1,1),3)
        render.add_rect(vector2(hp.x-2,hcy-th/2),vector2(hp.x+bw+2,hcy+th/2),color(0,0,0,0.4),3,1)

        if e.EnableAlpha then
            local ap=pp:add(vector2(bx+bw+bg_gap,pad)); local as2=vector2(bw,sv_d)
            e.layout.alpha_pos=ap; e.layout.alpha_size=as2
            draw_checkerboard(ap,as2,4)
            local bc=hsv_to_rgb(e.Hue,e.Saturation,e.ValueHSV)
            for i=0,sv_d-1 do
                render.add_line(ap:add(vector2(0,i)), ap:add(vector2(bw,i)), color(bc.r,bc.g,bc.b,i/(sv_d-1)),1)
            end
            render.add_rect(ap,ap:add(as2),Library.OutlineColor,br,1)
            local acy=ap.y+as2.y*e.Alpha
            render.add_rect_filled(vector2(ap.x-2,acy-th/2),vector2(ap.x+bw+2,acy+th/2),color(1,1,1,1),3)
            render.add_rect(vector2(ap.x-2,acy-th/2),vector2(ap.x+bw+2,acy+th/2),color(0,0,0,0.4),3,1)
        end
    end

    -- ════════════════ RIGHT-CLICK MENU ════════════════
    if Library.RightClickMenu then
        local rcm  = Library.RightClickMenu
        local opts = {"Always","Hold","Toggle"}
        local scr  = get_screen_size()
        local rp   = vector2(math.min(rcm.pos.x, scr.x-rcm.size.x-4),
                              math.min(rcm.pos.y, scr.y-rcm.size.y-4))
        rcm.Alpha  = lerp(rcm.Alpha, 1, LERP_SNAP)
        draw_shadow(rp, rcm.size, 8, rcm.Alpha)
        draw_panel(rp, rcm.size, 9, rcm.Alpha, G.glass)
        local pad=4; local ih=24
        for i, opt in ipairs(opts) do
            local ip  = rp:add(vector2(pad,pad+(i-1)*ih))
            local isz = vector2(rcm.size.x-pad*2, ih)
            local sel = rcm.obj.Mode==opt or (opt=="Always" and not rcm.obj.Mode)
            local hov = imr(ip,isz)
            if hov then render.add_rect_filled(ip, ip:add(isz), aa(accent,0.12*rcm.Alpha),5) end
            if sel then render.add_rect_filled(ip, ip:add(isz), aa(accent,0.18*rcm.Alpha),5) end
            render.add_text(ip:add(vector2(8,4)), opt,
                (sel or hov) and aa(accent,rcm.Alpha) or aa(Library.FontColor,rcm.Alpha*0.65))
            if sel then
                render.add_circle_filled(vector2(ip.x+isz.x-8, ip.y+ih/2), 3, aa(accent,rcm.Alpha))
            end
            if mpressed and hov then
                rcm.obj.Mode = opt=="Always" and nil or opt; Library.RightClickMenu=nil
            end
        end
    end

    -- ════════════════ NOTIFICATIONS ════════════════
    local sw, sh = get_screen_size().x, get_screen_size().y
    local nx, ny, vdir = 20, 50, 1
    if Library.NotificationPosition=="Top Right" then nx=sw-290; ny=50
    elseif Library.NotificationPosition=="Bottom Right" then nx=sw-290; ny=sh-60; vdir=-1
    elseif Library.NotificationPosition=="Bottom Left" then nx=20; ny=sh-60; vdir=-1 end
    local run_y = 0
    for i=#Library.Notifications,1,-1 do
        local n = Library.Notifications[i]
        if get_unixtime()-n.StartTime>n.Duration then n.TargetAlpha=0; n.TargetOffsetX=30 end
        n.Alpha   = lerp(n.Alpha,   n.TargetAlpha,   LERP_SNAP)
        n.OffsetX = lerp(n.OffsetX, n.TargetOffsetX, LERP_MED)
        if n.TargetAlpha==0 and n.Alpha<0.01 then
            table.remove(Library.Notifications,i)
        else
            local nsz  = vector2(render.get_text_size(n.Text).x+22, 26)
            local cy   = ny + vdir*run_y
            if vdir==-1 then cy=cy-nsz.y end
            local sign = (Library.NotificationPosition:find("Right")) and 1 or -1
            local np   = vector2(nx+sign*n.OffsetX, cy)
            draw_shadow(np, nsz, 7, n.Alpha)
            draw_panel(np, nsz, 7, n.Alpha, G.glass)
            -- accent left bar
            render.add_rect_filled(np:add(vector2(0,4)), np:add(vector2(3,nsz.y-4)),
                aa(Library.AccentColor, n.Alpha), 2)
            render.add_text(np:add(vector2(11,5)), n.Text, aa(Library.FontColor, n.Alpha))
            run_y = run_y + nsz.y + 5
        end
    end

    draw_watermark()
    Library.TooltipAlpha = lerp(Library.TooltipAlpha, Library.Tooltip and 1 or 0, LERP_SNAP)
    if anim.State=="Idle" then render_tooltip(Library.TooltipAlpha) end
end)

-- ────────────────────────────────────────────
--  KEY HANDLERS
-- ────────────────────────────────────────────
hook.add("init", "auth_key_handler_init", function()

    hook.add("render", "kp_capture", function()
        if not Library.ActiveKeyPicker then return end
        for vk, name in pairs(KEY_NAMES) do
            if input.is_key_pressed(vk) then
                Library.ActiveKeyPicker.obj:SetValue(name)
                Library.ActiveKeyPicker.obj.Picking=false
                Library.ActiveKeyPicker=nil
                Library:Notify("Bound: "..name, 2)
                return
            end
        end
    end)

    hook.add("render", "toggle_key_handler", function()
        for _, opt in pairs(Library.Options) do
            if opt.Type=="KeyPicker" and opt.Mode=="Toggle" and opt.Value and opt.Value~="..." then
                local vk
                for code, name in pairs(KEY_NAMES) do if name==opt.Value then vk=code; break end end
                if vk and input.is_key_pressed(vk) then
                    opt.Active=not opt.Active; fire(opt, opt.Active)
                end
            end
        end
    end)

    hook.add("render", "text_input_handler", function()
        if not Library.ActiveInput then return end
        for vk, ch in pairs(CHAR_NORMAL) do
            if input.is_key_pressed(vk) then
                if vk==0x08 then
                    local v=Library.ActiveInput.Value
                    if #v>0 then Library.ActiveInput:SetValue(v:sub(1,-2)) end
                elseif vk==0x0D or vk==0x1B then
                    Library.ActiveInput=nil
                else
                    local c=(input.key_down(0x10) and CHAR_SHIFT[vk]) or ch
                    if c then Library.ActiveInput:SetValue(Library.ActiveInput.Value..c) end
                end
                return
            end
        end
    end)

    local last_menu = 0
    hook.add("render", "menu_toggle_handler", function()
        local mk=Library.Options.menu_key
        if not mk or not mk.Value or mk.Value=="..." then return end
        local vk
        for code, name in pairs(KEY_NAMES) do if name==mk.Value then vk=code; break end end
        if vk and input.is_key_pressed(vk) then
            local now=get_tickcount()
            if now-last_menu>200 then
                for _, w in ipairs(Library.Windows) do
                    if w.TargetAlpha>0.5 then w.TargetAlpha=0
                    else w.Visible=true; w.TargetAlpha=1 end
                end
                last_menu=now
            end
        end
    end)
end)

Library.Options.menu_key = Library.Options.menu_key or { Value="Insert", Mode="Toggle" }

_G.Library = Library
return Library
