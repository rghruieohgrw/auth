-- Main render hook
hook.add("render", "library_render", function()
    local accent = Library.AccentColor
    local mp = input.get_mouse_position()
    local mpressed = input.is_key_pressed(0x01)
    local mdown = input.key_down(0x01)
    
    Library.ModalOpen = Library.OpenedDropdown or Library.ActiveColorPicker or Library.ActiveKeyPicker or Library.ActiveInput or Library.RightClickMenu
    
    -- Dismiss modals
    if mpressed and Library.ModalOpen then
        if Library.OpenedDropdown and Library.OpenedDropdown.Layout then
            local dd = Library.OpenedDropdown
            if not is_mouse_in_rect(dd.Layout.pos, dd.Layout.size) and not is_mouse_in_rect(dd.Layout.list_pos, dd.Layout.list_size) then
                dd.Open = false
                Library.OpenedDropdown = nil
            end
        end
        if Library.ActiveKeyPicker and not is_mouse_in_rect(Library.ActiveKeyPicker.layout.pos, Library.ActiveKeyPicker.layout.size) then
            Library.ActiveKeyPicker.obj.Picking = false
            Library.ActiveKeyPicker = nil
        end
        if Library.ActiveInput and not is_mouse_in_rect(Library.ActiveInput.layout.pos, Library.ActiveInput.layout.size) then
            Library.ActiveInput = nil
        end
        if Library.RightClickMenu then
            local rcm_sz = vector2(110, 3*24+8)
            if not is_mouse_in_rect(Library.RightClickMenu.pos, rcm_sz) then
                Library.RightClickMenu = nil
            end
        end
    end
    
    -- Window drag
    if Library.DraggingWindow then
        if mdown then
            Library.DraggingWindow.Pos = mp:subtract(Library.DragOffset)
        else
            Library.DraggingWindow = nil
        end
    end
    
    -- Watermark drag
    local ts_wm = render.get_text_size(Library.Watermark.Text)
    local wm_size = vector2(ts_wm.x + 16, 28)
    if not Library.DraggingWatermark and mpressed and is_mouse_in_rect(Library.Watermark.Pos, wm_size) then
        Library.DraggingWatermark = true
        Library.DragOffset = mp:subtract(Library.Watermark.Pos)
    end
    if Library.DraggingWatermark then
        if mdown then
            Library.Watermark.Pos = mp:subtract(Library.DragOffset)
        else
            Library.DraggingWatermark = false
        end
    end
    
    -- Draw watermark
    if Library.Watermark.Visible then
        local wsz = vector2(ts_wm.x + 16, 28)
        local pos = Library.Watermark.Pos
        draw_shadow(pos, wsz, 8, 1)
        render.add_rect_filled(pos, pos:add(wsz), Library.MainColor, 8)
        render.add_rect(pos, pos:add(wsz), Library.OutlineColor, 8, 1)
        render.add_text(pos:add(vector2(8, 6)), Library.Watermark.Text, Library.FontColor)
    end
    
    -- Draw windows
    for _, window in ipairs(Library.Windows) do
        if window.Visible then
            window.Alpha = window.Alpha + (window.TargetAlpha - window.Alpha) * 0.1
            local wa = window.Alpha
            if wa < 0.01 then goto continue_window end
            
            local title_bar_pos = window.Pos
            local title_bar_size = vector2(window.Size.x, 38)
            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(title_bar_pos, title_bar_size) and not Library.ModalOpen then
                Library.DraggingWindow = window
                Library.DragOffset = mp:subtract(window.Pos)
            end
            
            draw_shadow(window.Pos, window.Size, 12, wa)
            render.add_rect_filled(window.Pos, window.Pos:add(window.Size), apply_alpha(Library.BackgroundColor, wa), 12)
            render.add_rect(window.Pos, window.Pos:add(window.Size), apply_alpha(Library.OutlineColor, wa), 12, 1)
            render.add_text(window.Pos:add(vector2(16, 11)), window.Title, apply_alpha(accent, wa))
            
            local msp = window.Pos:add(vector2(12, 42))
            local mss = vector2(window.Size.x - 24, window.Size.y - 54)
            render.add_rect_filled(msp, msp:add(mss), apply_alpha(Library.MainColor, wa), 10)
            
            -- Tabs
            local tab_area_pos = msp:add(vector2(6, 6))
            local tab_x = 0
            for _, tab in ipairs(window.Tabs) do
                local tw = render.get_text_size(tab.Name).x + 24
                local tp2 = tab_area_pos:add(vector2(tab_x, 0))
                local ts2 = vector2(tw, 28)
                local is_active = (window.ActiveTab == tab)
                local tab_bg = is_active and apply_alpha(accent, wa) or apply_alpha(color(0.12, 0.12, 0.16, 1), wa)
                local tab_fg = is_active and apply_alpha(Library.BackgroundColor, wa) or apply_alpha(Library.FontColor, wa)
                render.add_rect_filled(tp2, tp2:add(ts2), tab_bg, 8)
                render.add_text(tp2:add(vector2(12, 6)), tab.Name, tab_fg)
                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(tp2, ts2) and window.ActiveTab ~= tab then
                    window.ActiveTab = tab
                end
                tab_x = tab_x + tw + 4
            end
            
            -- Content area
            local content_area = msp:add(vector2(6, 42))
            local left_y = 0
            local right_y = 0
            
            if window.ActiveTab then
                for _, groupbox in ipairs(window.ActiveTab.Groupboxes) do
                    local side_off = (groupbox.Side == "Left") and 0 or (window.Size.x / 2 - 18)
                    local y_off = (groupbox.Side == "Left") and left_y or right_y
                    local group_pos = content_area:add(vector2(side_off, y_off))
                    
                    local group_height = 36
                    for _, e in ipairs(groupbox.Elements) do group_height = group_height + e.Height + 4 end
                    local group_size = vector2(window.Size.x / 2 - 24, group_height)
                    
                    draw_shadow(group_pos, group_size, 10, wa * 0.5)
                    render.add_rect_filled(group_pos, group_pos:add(group_size), apply_alpha(Library.BackgroundColor, wa), 10)
                    render.add_rect(group_pos, group_pos:add(group_size), apply_alpha(Library.OutlineColor, wa), 10, 1)
                    render.add_text(group_pos:add(vector2(14, 10)), groupbox.Name, apply_alpha(accent, wa))
                    
                    local element_y = 40
                    for _, element in ipairs(groupbox.Elements) do
                        local ep = group_pos:add(vector2(12, element_y))
                        local ew = group_size.x - 24
                        
                        if element.Type == "Toggle" then
                            local target_x = element.Value and 1 or 0
                            element.SwitchAnim = element.SwitchAnim + (target_x - element.SwitchAnim) * 0.12
                            local sw_pos = ep:add(vector2(0, 5))
                            local sw_size = vector2(34, 18)
                            local fill_bg = color(
                                0.14 + (accent.r - 0.14) * element.SwitchAnim,
                                0.14 + (accent.g - 0.14) * element.SwitchAnim,
                                0.18 + (accent.b - 0.18) * element.SwitchAnim, 1)
                            render.add_rect_filled(sw_pos, sw_pos:add(sw_size), apply_alpha(fill_bg, wa), 10)
                            render.add_rect(sw_pos, sw_pos:add(sw_size), apply_alpha(Library.OutlineColor, wa), 10, 1)
                            local knob_x = sw_pos.x + 3 + (sw_size.x - 12) * element.SwitchAnim
                            render.add_rect_filled(vector2(knob_x, sw_pos.y + 3), vector2(knob_x + 10, sw_pos.y + 15), apply_alpha(color(1, 1, 1, 1), wa), 8)
                            local text_color = element.Risky and Library.RiskColor or (element.Value and accent or Library.FontColor)
                            render.add_text(ep:add(vector2(42, 4)), element.Text, apply_alpha(text_color, wa))
                            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(ep, vector2(ew, 28)) then
                                element:SetValue(not element.Value)
                            end
                            
                        elseif element.Type == "Slider" then
                            local ratio = (element.Value - element.Min) / (element.Max - element.Min)
                            element.ThumbAnim = element.ThumbAnim + (ratio - element.ThumbAnim) * 0.12
                            local s_pos = ep:add(vector2(0, 24))
                            local s_size = vector2(ew, 6)
                            local thumb_x = s_pos.x + s_size.x * element.ThumbAnim
                            render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                            render.add_text(ep:add(vector2(ew - 45, 0)), tostring(element.Value) .. element.Suffix, apply_alpha(accent, wa))
                            render.add_rect_filled(s_pos, s_pos:add(s_size), apply_alpha(Library.MainColor, wa), 4)
                            render.add_rect_filled(s_pos, s_pos:add(vector2(s_size.x * element.ThumbAnim, s_size.y)), apply_alpha(accent, wa), 4)
                            render.add_circle(vector2(thumb_x, s_pos.y + 3), 7, apply_alpha(Library.FontColor, wa), 2)
                            if is_mouse_in_rect(s_pos, s_size) and mdown then
                                local r = (math.clamp(mp.x, s_pos.x, s_pos.x + s_size.x) - s_pos.x) / s_size.x
                                local v = element.Min + (element.Max - element.Min) * r
                                if element.Value ~= v then element:SetValue(v) end
                            end
                            
                        elseif element.Type == "Button" then
                            local b_pos = ep
                            local b_size = vector2(ew, 32)
                            local is_hover = is_mouse_in_rect(b_pos, b_size)
                            element.HoverAnim = element.HoverAnim + ((is_hover and 1 or 0) - element.HoverAnim) * 0.12
                            local ha = element.HoverAnim
                            local bg = color(
                                accent.r + (Library.FontColor.r - accent.r) * (1 - ha),
                                accent.g + (Library.FontColor.g - accent.g) * (1 - ha),
                                accent.b + (Library.FontColor.b - accent.b) * (1 - ha), 1)
                            local fg = color(
                                Library.FontColor.r + (accent.r - Library.FontColor.r) * ha,
                                Library.FontColor.g + (accent.g - Library.FontColor.g) * ha,
                                Library.FontColor.b + (accent.b - Library.FontColor.b) * ha, 1)
                            render.add_rect_filled(b_pos, b_pos:add(b_size), apply_alpha(bg, wa), 8)
                            render.add_rect(b_pos, b_pos:add(b_size), apply_alpha(Library.OutlineColor, wa), 8, 1)
                            render.add_text(b_pos:add(vector2(b_size.x/2 - render.get_text_size(element.Text).x/2, 8)), element.Text, apply_alpha(fg, wa))
                            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(b_pos, b_size) then
                                if element.DoubleClick then
                                    local now = get_unixtime()
                                    if now - (element.LastClick or 0) < 0.5 then
                                        if element.Func then element.Func() end
                                        element.LastClick = 0
                                    else
                                        element.LastClick = now
                                    end
                                else
                                    if element.Func then element.Func() end
                                end
                            end
                            
                        elseif element.Type == "Dropdown" then
                            render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                            local d_pos = ep:add(vector2(0, 20))
                            local d_size = vector2(ew, 28)
                            element.Layout = { pos = d_pos, size = d_size, list_pos = vector2(0,0), list_size = vector2(0,0) }
                            render.add_rect_filled(d_pos, d_pos:add(d_size), apply_alpha(Library.MainColor, wa), 8)
                            render.add_rect(d_pos, d_pos:add(d_size), apply_alpha(Library.OutlineColor, wa), 8, 1)
                            render.add_text(d_pos:add(vector2(10, 6)), get_clipped_text(tostring(element.Value), d_size.x - 30), apply_alpha(accent, wa))
                            render.add_triangle_filled(d_pos:add(vector2(d_size.x - 16, 10)), d_pos:add(vector2(d_size.x - 8, 10)), d_pos:add(vector2(d_size.x - 12, 16)), apply_alpha(accent, wa))
                            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(d_pos, d_size) then
                                element.Open = not element.Open
                                Library.OpenedDropdown = element.Open and element or nil
                            end
                            
                        elseif element.Type == "Input" then
                            render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                            local i_pos = ep:add(vector2(0, 20))
                            local i_size = vector2(ew, 28)
                            element.layout = { pos = i_pos, size = i_size }
                            local is_active = (Library.ActiveInput == element)
                            render.add_rect_filled(i_pos, i_pos:add(i_size), apply_alpha(Library.MainColor, wa), 8)
                            render.add_rect(i_pos, i_pos:add(i_size), is_active and apply_alpha(accent, wa) or apply_alpha(Library.OutlineColor, wa), 8, 1)
                            local d_text = (element.Value ~= "") and element.Value or element.Placeholder
                            render.add_text(i_pos:add(vector2(10, 6)), get_clipped_text(d_text, i_size.x - 20), apply_alpha(Library.FontColor, wa))
                            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(i_pos, i_size) then
                                Library.ActiveInput = element
                            end
                            
                        elseif element.Type == "KeyPicker" then
                            render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                            local k_pos = ep:add(vector2(0, 20))
                            local k_size = vector2(ew, 28)
                            element.layout = { pos = k_pos, size = k_size }
                            render.add_rect_filled(k_pos, k_pos:add(k_size), apply_alpha(Library.MainColor, wa), 8)
                            render.add_rect(k_pos, k_pos:add(k_size), element.Picking and apply_alpha(accent, wa) or apply_alpha(Library.OutlineColor, wa), 8, 1)
                            local mode_tag = (element.Mode == "Hold" and " [H]") or (element.Mode == "Toggle" and " [T]") or ""
                            local ktext = element.Picking and "press a key..." or (element.Value .. mode_tag)
                            render.add_text(k_pos:add(vector2(k_size.x/2 - render.get_text_size(ktext).x/2, 6)), ktext, apply_alpha(accent, wa))
                            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(k_pos, k_size) then
                                element.Picking = true
                                Library.ActiveKeyPicker = { obj = element, layout = element.layout }
                            end
                            if not Library.DraggingWindow and input.is_key_pressed(0x02) and is_mouse_in_rect(k_pos, k_size) then
                                Library.RightClickMenu = { obj = element, pos = mp, Alpha = 0 }
                            end
                            
                        elseif element.Type == "ColorPicker" then
                            local box_size = vector2(24, 20)
                            local box_pos = ep:add(vector2(ew - box_size.x, 2))
                            element.layout.pos = box_pos
                            element.layout.size = box_size
                            render.add_text(ep:add(vector2(0, 3)), element.Text, apply_alpha(Library.SecondaryFontColor, wa))
                            render.add_rect_filled(box_pos:add(vector2(1, 1)), box_pos:add(box_size):subtract(vector2(1, 1)), apply_alpha(element.Value, wa), 6)
                            render.add_rect(box_pos, box_pos:add(box_size), apply_alpha(Library.OutlineColor, wa), 6, 1)
                            
                        elseif element.Type == "Divider" then
                            local dy = ep.y + element.Height / 2
                            render.add_line(vector2(ep.x, dy), vector2(ep.x + ew, dy), apply_alpha(Library.OutlineColor, wa), 1)
                            
                        elseif element.Type == "Label" then
                            render.add_text(ep:add(vector2(0, 4)), element.Text, apply_alpha(Library.FontColor, wa))
                        end
                        
                        element_y = element_y + element.Height + 4
                    end
                    
                    if groupbox.Side == "Left" then
                        left_y = left_y + group_size.y + 12
                    else
                        right_y = right_y + group_size.y + 12
                    end
                end
            end
        end
        ::continue_window::
    end
    
    -- Dropdown list
    if Library.OpenedDropdown then
        local e = Library.OpenedDropdown
        local list_pos = e.Layout.pos:add(vector2(0, e.Layout.size.y + 2))
        local list_h = math.min(#e.Values, 6) * 26 + 6
        local list_size = vector2(e.Layout.size.x, list_h)
        e.Layout.list_pos = list_pos
        e.Layout.list_size = list_size
        draw_shadow(list_pos, list_size, 8, 1)
        render.add_rect_filled(list_pos, list_pos:add(list_size), Library.MainColor, 8)
        render.add_rect(list_pos, list_pos:add(list_size), Library.OutlineColor, 8, 1)
        local item_y = 3
        for _, value in ipairs(e.Values) do
            local ip = list_pos:add(vector2(3, item_y))
            local isz = vector2(list_size.x - 6, 24)
            local is_sel = (e.Value == value)
            local tc = is_sel and accent or Library.FontColor
            if is_mouse_in_rect(ip, isz) then
                render.add_rect_filled(ip, ip:add(isz), apply_alpha(accent, 0.15), 6)
                tc = accent
                if mpressed then
                    e:SetValue(value)
                    e.Open = false
                    Library.OpenedDropdown = nil
                end
            end
            render.add_text(ip:add(vector2(10, 4)), value, tc)
            item_y = item_y + 26
        end
    end
    
    -- Right-click menu
    if Library.RightClickMenu then
        local rcm = Library.RightClickMenu
        local options = { "Hold", "Toggle" }
        local item_h = 28
        local pad = 6
        local rcm_w = 100
        local rcm_h = #options * item_h + pad * 2
        local rcm_sz = vector2(rcm_w, rcm_h)
        local scr = get_screen_size()
        local rp = vector2(math.min(rcm.pos.x, scr.x - rcm_w - 4), math.min(rcm.pos.y, scr.y - rcm_h - 4))
        rcm.Alpha = rcm.Alpha + (1 - rcm.Alpha) * 0.12
        draw_shadow(rp, rcm_sz, 8, rcm.Alpha)
        render.add_rect_filled(rp, rp:add(rcm_sz), apply_alpha(Library.MainColor, rcm.Alpha), 8)
        for i, opt in ipairs(options) do
            local ip = rp:add(vector2(pad, pad + (i - 1) * item_h))
            local isz = vector2(rcm_w - pad * 2, item_h)
            local is_sel = (rcm.obj.Mode == opt)
            local is_hov = is_mouse_in_rect(ip, isz)
            if is_hov or is_sel then
                render.add_rect_filled(ip, ip:add(isz), apply_alpha(accent, (is_sel and 0.25 or 0.1) * rcm.Alpha), 6)
            end
            local tc = (is_sel or is_hov) and apply_alpha(accent, rcm.Alpha) or apply_alpha(Library.FontColor, rcm.Alpha * 0.7)
            render.add_text(ip:add(vector2(10, 6)), opt, tc)
            if is_sel then
                render.add_rect_filled(ip:add(vector2(rcm_w - pad * 2 - 12, item_h/2 - 3)), ip:add(vector2(rcm_w - pad * 2 - 6, item_h/2 + 3)), apply_alpha(accent, rcm.Alpha), 3)
            end
            if mpressed and is_hov then
                rcm.obj.Mode = opt
                Library.RightClickMenu = nil
            end
        end
    end
    
    -- Notifications
    local scr_w = get_screen_size().x
    local notif_y = 60
    for i = #Library.Notifications, 1, -1 do
        local n = Library.Notifications[i]
        local t = get_unixtime() - n.StartTime
        if t > n.Duration then
            n.TargetAlpha = 0
            n.TargetOffsetX = 30
        end
        n.Alpha = n.Alpha + (n.TargetAlpha - n.Alpha) * 0.1
        n.OffsetX = n.OffsetX + (n.TargetOffsetX - n.OffsetX) * 0.1
        if n.TargetAlpha == 0 and n.Alpha < 0.01 then
            table.remove(Library.Notifications, i)
        else
            local nsz = vector2(render.get_text_size(n.Text).x + 24, 32)
            local np = vector2(scr_w - 320 + n.OffsetX, notif_y)
            draw_shadow(np, nsz, 8, n.Alpha)
            render.add_rect_filled(np, np:add(nsz), color(Library.MainColor.r, Library.MainColor.g, Library.MainColor.b, n.Alpha), 8)
            render.add_rect(np, np:add(nsz), color(Library.OutlineColor.r, Library.OutlineColor.g, Library.OutlineColor.b, n.Alpha), 8, 1)
            render.add_rect_filled(np:add(vector2(0, 6)), np:add(vector2(3, nsz.y - 12)), color(accent.r, accent.g, accent.b, n.Alpha), 4)
            render.add_text(np:add(vector2(14, 8)), n.Text, color(Library.FontColor.r, Library.FontColor.g, Library.FontColor.b, n.Alpha))
            notif_y = notif_y + nsz.y + 6
        end
    end
    
    -- Tooltip
    if Library.Tooltip and Library.Tooltip.Text then
        local mp = input.get_mouse_position()
        local ts = render.get_text_size(Library.Tooltip.Text)
        local tsz = vector2(ts.x + 18, ts.y + 12)
        local tp = mp:add(vector2(16, 18))
        draw_shadow(tp, tsz, 8, 1)
        render.add_rect_filled(tp, tp:add(tsz), Library.MainColor, 8)
        render.add_rect(tp, tp:add(tsz), Library.OutlineColor, 8, 1)
        render.add_text(tp:add(vector2(9, 6)), Library.Tooltip.Text, accent)
    end
end)

-- Key handler
hook.add("render", "key_handler", function()
    for _, opt in pairs(Library.Options) do
        if opt.Type == "KeyPicker" and opt.Picking then
            for vk, name in pairs(KEY_NAMES) do
                if input.is_key_pressed(vk) then
                    opt:SetValue(name)
                    opt.Picking = false
                    Library.ActiveKeyPicker = nil
                    Library:Notify("Key bound to: " .. name, 2)
                    break
                end
            end
        end
    end
    
    if Library.ActiveInput then
        for vk, char in pairs(CHAR_MAP_NORMAL) do
            if input.is_key_pressed(vk) then
                if vk == 0x08 then
                    local v = Library.ActiveInput.Value
                    if #v > 0 then Library.ActiveInput:SetValue(string.sub(v, 1, -2))
                    end
                elseif vk == 0x0D or vk == 0x1B then
                    Library.ActiveInput = nil
                else
                    Library.ActiveInput:SetValue(Library.ActiveInput.Value .. char)
                end
                break
            end
        end
    end
end)

-- Menu key
hook.add("init", "menu_key_init", function()
    local last_press = 0
    hook.add("render", "menu_key_handler", function()
        local menu_key_opt = Library.Options.menu_key
        if menu_key_opt and menu_key_opt.Value and menu_key_opt.Value ~= "..." then
            local vk = nil
            for code, name in pairs(KEY_NAMES) do
                if name == menu_key_opt.Value then
                    vk = code
                    break
                end
            end
            if vk and input.is_key_pressed(vk) then
                local now = get_tickcount()
                if now - last_press > 200 then
                    for _, w in ipairs(Library.Windows) do
                        if w.TargetAlpha > 0.5 then
                            w.TargetAlpha = 0
                            w.Visible = false
                        else
                            w.Visible = true
                            w.TargetAlpha = 1
                        end
                    end
                    last_press = now
                end
            end
        end
    end)
end)

Library.Options.menu_key = Library.Options.menu_key or { Value = "Insert", Mode = "Toggle" }

_G.Library = Library
return Library
