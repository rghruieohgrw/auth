-- Helper function for mouse rect detection (since it was missing)
local function is_mouse_in_rect(pos, size)
    local mouse = input.get_mouse_position()
    return mouse.x >= pos.x and mouse.x <= pos.x + size.x and
           mouse.y >= pos.y and mouse.y <= pos.y + size.y
end

