    -- ========== CONFIG SYSTEM ==========
    ConfigFolder = "photon_configs/",

    GetConfigList = function(self)
        local configs = {}
        local manifest_file = self.ConfigFolder .. "manifest.json"
        if file.exists(manifest_file) then
            local manifest_data = file.read(manifest_file)
            local manifest = self:JSONToTable(manifest_data)
            if manifest and manifest.configs then
                configs = manifest.configs
            end
        end
        return configs
    end,

    UpdateManifest = function(self, config_name)
        local configs = self:GetConfigList()
        local found = false
        for i, name in ipairs(configs) do
            if name == config_name then found = true; break end
        end
        if not found then table.insert(configs, config_name) end
        local manifest = { configs = configs, last_updated = get_unixtime() }
        file.write(self.ConfigFolder .. "manifest.json", self:TableToJSON(manifest))
        self.ConfigList = configs
        return configs
    end,

    RemoveFromManifest = function(self, config_name)
        local configs = self:GetConfigList()
        local new_configs = {}
        for i, name in ipairs(configs) do
            if name ~= config_name then table.insert(new_configs, name) end
        end
        local manifest = { configs = new_configs, last_updated = get_unixtime() }
        file.write(self.ConfigFolder .. "manifest.json", self:TableToJSON(manifest))
        self.ConfigList = new_configs
        return new_configs
    end,

    SaveConfig = function(self, name)
        if not file.exists(self.ConfigFolder) then
            file.write(self.ConfigFolder .. ".keep", "")
        end
        local config = {
            toggles = {}, options = {},
            version = 2, saved_at = get_unixtime(), game = get_placeid()
        }
        for id, toggle in pairs(self.Toggles) do
            config.toggles[id] = toggle.Value
        end
        for id, opt in pairs(self.Options) do
            if opt.Type == "Slider" then
                config.options[id] = { type = "Slider", value = opt.Value }
            elseif opt.Type == "Dropdown" then
                config.options[id] = { type = "Dropdown", value = opt.Value, multi = opt.Multi or false }
            elseif opt.Type == "Input" then
                config.options[id] = { type = "Input", value = opt.Value }
            elseif opt.Type == "KeyPicker" then
                config.options[id] = { type = "KeyPicker", value = opt.Value, mode = opt.Mode or "Hold" }
            elseif opt.Type == "ColorPicker" then
                local c = opt.Value
                config.options[id] = { type = "ColorPicker", value = { r = c.r, g = c.g, b = c.b, a = c.a } }
            end
        end
        config.windows = {}
        for i, win in ipairs(self.Windows) do
            config.windows[i] = { pos = { x = win.Pos.x, y = win.Pos.y } }
        end
        config.watermark = { x = self.Watermark.Pos.x, y = self.Watermark.Pos.y }
        local g = self.Glass
        config.glass = {
            enabled = g.Enabled, transparency = g.Transparency, blur = g.Blur,
            tint = { r = g.Tint.r, g = g.Tint.g, b = g.Tint.b, a = g.Tint.a },
            highlight = { r = g.Highlight.r, g = g.Highlight.g, b = g.Highlight.b, a = g.Highlight.a },
            border = { r = g.Border.r, g = g.Border.g, b = g.Border.b, a = g.Border.a },
        }
        file.write(self.ConfigFolder .. name .. ".json", self:TableToJSON(config))
        self:UpdateManifest(name)
        self.CurrentConfig = name
        self:Notify("Config saved: " .. name, 3)
        if self.ConfigDropdown then
            self.ConfigDropdown:SetValues(self:GetConfigList())
            self.ConfigDropdown:SetValue(name)
        end
        return true
    end,

    LoadConfig = function(self, name)
        local filename = self.ConfigFolder .. name .. ".json"
        if not file.exists(filename) then self:Notify("Config not found: " .. name, 3); return false end
        local config = self:JSONToTable(file.read(filename))
        if not config then self:Notify("Failed to load config: " .. name, 3); return false end
        for id, value in pairs(config.toggles or {}) do
            if self.Toggles[id] then self.Toggles[id]:SetValue(value) end
        end
        for id, data in pairs(config.options or {}) do
            if self.Options[id] then
                if data.type == "Slider" then self.Options[id]:SetValue(data.value)
                elseif data.type == "Dropdown" then self.Options[id]:SetValue(data.value)
                elseif data.type == "Input" then self.Options[id]:SetValue(data.value)
                elseif data.type == "KeyPicker" then
                    self.Options[id]:SetValue(data.value)
                    if data.mode then self.Options[id].Mode = data.mode end
                elseif data.type == "ColorPicker" then
                    local c = data.value
                    self.Options[id]:SetValue(color(c.r, c.g, c.b, c.a))
                end
            end
        end
        for i, win_data in ipairs(config.windows or {}) do
            if self.Windows[i] then
                self.Windows[i].Pos = clamp_position(
                    vector2(win_data.pos.x, win_data.pos.y), self.Windows[i].Size)
            end
        end
        if config.watermark then
            self.Watermark.Pos = clamp_position(
                vector2(config.watermark.x, config.watermark.y), vector2(220, 24))
        end
        if config.glass then
            local gd = config.glass
            self.Glass.Enabled = gd.enabled ~= false
            if gd.transparency then self.Glass.Transparency = gd.transparency end
            if gd.blur then self.Glass.Blur = gd.blur end
            if gd.tint then
                local t = gd.tint
                self.Glass.Tint = color(t.r, t.g, t.b, t.a or 1)
            end
            if gd.highlight then
                local h = gd.highlight
                self.Glass.Highlight = color(h.r, h.g, h.b, h.a or 1)
            end
            if gd.border then
                local b = gd.border
                self.Glass.Border = color(b.r, b.g, b.b, b.a or 1)
            end
        end
        self.ConfigLoaded = true
        self.CurrentConfig = name
        self:Notify("Config loaded: " .. name, 3)
        if self.ConfigDropdown then self.ConfigDropdown:SetValue(name) end
        return true
    end,

    DeleteConfig = function(self, name)
        local filename = self.ConfigFolder .. name .. ".json"
        if file.exists(filename) then
            file.write(filename, "")
            self:RemoveFromManifest(name)
            self:Notify("Config deleted: " .. name, 3)
            if self.CurrentConfig == name then self.CurrentConfig = "" end
            if self.ConfigDropdown then
                self.ConfigDropdown:SetValues(self:GetConfigList())
                self.ConfigDropdown:SetValue("")
            end
            return true
        end
        return false
    end,

    ListConfigs = function(self) return self:GetConfigList() end,

    ResetAll = function(self)
        for id, toggle in pairs(self.Toggles) do toggle:SetValue(false) end
        for id, opt in pairs(self.Options) do
            if opt.Type == "Slider" then opt:SetValue((opt.Min + opt.Max) / 2)
            elseif opt.Type == "Dropdown" and not opt.Multi then opt:SetValue(opt.Values[1])
            elseif opt.Type == "Input" then opt:SetValue("")
            elseif opt.Type == "KeyPicker" then opt:SetValue("...")
            elseif opt.Type == "ColorPicker" then opt:SetValue(color(1, 1, 1, 1)) end
        end
        self.CurrentConfig = ""
        if self.ConfigDropdown then self.ConfigDropdown:SetValue("") end
        self:Notify("All settings reset!", 3)
    end,

    TableToJSON = function(self, tbl)
        local function serialize(val)
            if type(val) == "string" then
                return '"' .. val:gsub('"', '\\"') .. '"'
            elseif type(val) == "number" then
                return tostring(val)
            elseif type(val) == "boolean" then
                return val and "true" or "false"
            elseif type(val) == "table" then
                local items = {}
                local is_array = true
                local max_idx = 0
                for k, v in pairs(val) do
                    if type(k) ~= "number" or k ~= math.floor(k) or k <= 0 then
                        is_array = false; break
                    end
                    if k > max_idx then max_idx = k end
                end
                if is_array and max_idx > 0 then
                    for i = 1, max_idx do table.insert(items, serialize(val[i])) end
                    return "[" .. table.concat(items, ",") .. "]"
                else
                    for k, v in pairs(val) do
                        table.insert(items, serialize(k) .. ":" .. serialize(v))
                    end
                    return "{" .. table.concat(items, ",") .. "}"
                end
            else
                return "null"
            end
        end
        return serialize(tbl)
    end,

    JSONToTable = function(self, str)
        local func, err = load("return " .. str, "json_parse")
        if func then
            local success, result = pcall(func)
            if success then return result end
        end
        return nil
    end,

    CreateConfigDropdown = function(self, groupbox, id)
        local configs = self:GetConfigList()
        local dropdown = groupbox:AddDropdown(id, {
            Text = "Config Profile", Default = 1, Values = configs,
            Tooltip = "Select a config to load"
        })
        self.ConfigDropdown = dropdown
        groupbox:AddButton({
            Text = "Save Current Config",
            Func = function() self:ShowConfigNameInput("Save Config", function(name)
                if name and name ~= "" then self:SaveConfig(name) end
            end) end,
            Tooltip = "Save current settings to a config"
        })
        groupbox:AddButton({
            Text = "Delete Selected Config", DoubleClick = true,
            Func = function()
                local current = dropdown.Value
                if current and current ~= "" then self:DeleteConfig(current)
                else self:Notify("No config selected to delete", 3) end
            end,
            Tooltip = "Double click to delete selected config"
        })
        groupbox:AddButton({
            Text = "Reset All Settings", DoubleClick = true,
            Func = function() self:ResetAll() end,
            Tooltip = "Double click to reset all settings to default"
        })
        dropdown:OnChanged(function(value)
            if value and value ~= "" then self:LoadConfig(value) end
        end)
        return dropdown
    end,

    ShowConfigNameInput = function(self, title, callback)
        self:Notify("Type config name in console", 3)
        print("Enter config name for '" .. title .. "':")
    end,

    CreateConfigSection = function(self, groupbox)
        local configs = self:GetConfigList()
        local dropdown = groupbox:AddDropdown("config_dropdown", {
            Text = "Load Config", Default = 1, Values = configs,
            Tooltip = "Select a config to load"
