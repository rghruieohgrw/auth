                        [0x4D]="M",[0x4E]="N",[0x4F]="O",[0x50]="P",[0x51]="Q",[0x52]="R",
                        [0x53]="S",[0x54]="T",[0x55]="U",[0x56]="V",[0x57]="W",[0x58]="X",
                        [0x59]="Y",[0x5A]="Z",[0x70]="F1",[0x71]="F2",[0x72]="F3",[0x73]="F4",
                        [0x74]="F5",[0x75]="F6",[0x76]="F7",[0x77]="F8",[0x78]="F9",[0x79]="F10",
                        [0x7A]="F11",[0x7B]="F12"
                    }
                    local el = {
                        Id = id, Type = "KeyPicker", Text = info.Text,
                        Value = info.Default or "...", Callback = info.Callback,
                        Picking = false, Height = 44, Tooltip = info.Tooltip,
                        Mode = info.Mode or "Hold", Active = false, layout = nil
                    }
                    function el:IsActive()
                        if not self.Value or self.Value == "..." then return false end
                        local vk = nil
                        for code, name in pairs(KEY_NAMES) do
                            if name == self.Value then vk = code; break end
                        end
                        if not vk then return false end
                        if self.Mode == "Hold" then
                            return input.key_down(vk)
                        elseif self.Mode == "Toggle" then
                            return self.Active or false
                        end
                        return input.key_down(vk)
                    end
                    function el:SetValue(val)
                        self.Value = val
                        if self.Callback then self.Callback(self.Value) end
                        if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
                    end
                    function el:OnChanged(func) self.OnChangedFunc = func; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end

                function groupbox:AddColorPicker(id, info)
                    local val = info.Default or color(1, 1, 1, 1)
                    local function rgb_to_hsv(c)
                        local r,g,b = c.r,c.g,c.b
                        local maxc = math.max(r,g,b); local minc = math.min(r,g,b)
                        local h,s,v = 0,0,maxc; local diff = maxc-minc
                        if maxc~=0 then s=diff/maxc else return 0,0,0 end
                        if diff>1e-5 then
                            if maxc==r then h=(g-b)/diff
                            elseif maxc==g then h=2+(b-r)/diff
                            else h=4+(r-g)/diff end
                            h=h/6; if h<0 then h=h+1 end
                        end
                        return h,s,v
                    end
                    local h,s,v = rgb_to_hsv(val)
                    local el = {
                        Id = id, Type = "ColorPicker", Text = info.Text,
                        Value = val, Open = false, Callback = info.Callback,
                        Height = 24, Hue = h, Saturation = s, ValueHSV = v,
                        Alpha = val.a, EnableAlpha = info.EnableAlpha or false,
                        Tooltip = info.Tooltip, layout = {pos=vector2(0,0),size=vector2(0,0),picker_pos=vector2(0,0),picker_size=vector2(0,0)}
                    }
                    function el:SetValue(val)
                        self.Value = val
                        if self.Callback then self.Callback(self.Value) end
                        if self.OnChangedFunc then self.OnChangedFunc(self.Value) end
                    end
                    function el:OnChanged(func) self.OnChangedFunc = func; return self end
                    table.insert(self.Elements, el)
                    Library.Options[id] = el
                    return el
                end

                function groupbox:AddDivider(height)
                    table.insert(self.Elements, {Type="Divider", Height=height or 14})
                    return self
                end

                function groupbox:AddLabel(text)
                    table.insert(self.Elements, {Type="Label", Text=text, Height=22})
                    return self
                end

                table.insert(self.Groupboxes, groupbox)
                return groupbox
            end
            
            table.insert(window.Tabs, tab)
            if not window.ActiveTab then window.ActiveTab = tab end
            return tab
        end

        table.insert(self.Windows, window)
        return window
    end,

    Notify = function(self, text, duration)
        table.insert(self.Notifications, {
            Text = text, Duration = duration or 4, StartTime = get_unixtime(),
            Alpha = 0, TargetAlpha = 1, OffsetX = 30, TargetOffsetX = 0,
        })
    end,

    SetWatermark = function(self, text)
        self.Watermark.Text = text
        self.Watermark.Visible = true
    end,
}

-- ========== RENDER FUNCTIONS FOR THE LIBRARY ==========
-- These need to be defined after the Library table is created

-- Helper functions
local function apply_alpha(col, mult)
    return color(col.r, col.g, col.b, (col.a or 1) * mult)
end

local function is_mouse_in_rect(pos, size)
    if not pos or not size then return false end
    local m = input.get_mouse_position()
    return m.x >= pos.x and m.x <= pos.x + size.x and m.y >= pos.y and m.y <= pos.y + size.y
end

local function draw_shadow(pos, size, radius, alpha_mult)
    local layers = 8
    for i = 1, layers do
        local spread = i * 3
        local a = (1 - i / layers) * 0.18 * (alpha_mult or 1)
        local sp = pos:add(vector2(-spread, -spread + spread * 0.5))
        local ss = size:add(vector2(spread * 2, spread * 2))
        render.add_rect_filled(sp, sp:add(ss), color(0, 0, 0, a), radius + i)
    end
end

