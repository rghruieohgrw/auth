local function draw_watermark()
    if not Library.Watermark.Visible then return end
    local ts  = render.get_text_size(Library.Watermark.Text)
    local wsz = vector2(ts.x+14, 22)
    local pos = Library.Watermark.Pos
    draw_shadow(pos, wsz, 5, 1)
    render.add_rect_filled(pos, pos:add(wsz), Library.MainColor, 5)
    -- accent pip
    render.add_rect_filled(pos, pos:add(vector2(2, wsz.y)), Library.AccentColor, 2)
    render.add_text(pos:add(vector2(8,3)), Library.Watermark.Text, Library.FontColor)
end

-- ══════════════════════════════════════════════
--  Dropdown list renderer
-- ══════════════════════════════════════════════
local DD_ITEM_H = 20
local DD_INNER_PAD = 6
local DD_V_PAD = 3

local function draw_dropdown_list(e, mpressed, mdown, mp)
    if not e._dd_layout then return end
    local layout = e._dd_layout
    if not e._list_scroll_id then e._list_scroll_id = "dd_"..tostring(e) end

    local total = #e.Values
    if total == 0 then e.Open=false; Library.OpenedDropdown=nil; return end

    local max_vis    = e.MaxVisible or 6
    local vis_items  = math.min(total, max_vis)
    local needs_sb   = total > max_vis
    local list_w     = layout.d_size.x
    local list_h     = vis_items * DD_ITEM_H + DD_V_PAD*2
    local text_col_w = list_w - DD_INNER_PAD*2 - (needs_sb and (SB_WIDTH+SB_PAD) or 0)

    local scr      = get_screen_size()
    local list_pos = layout.d_pos:add(vector2(0, layout.d_size.y+2))
    if list_pos.y + list_h > scr.y - 4 then list_pos = vector2(list_pos.x, layout.d_pos.y-list_h-2) end
    local list_size = vector2(list_w, list_h)
    layout.list_pos=list_pos; layout.list_size=list_size

    local scroll    = get_scroll_state(e._list_scroll_id)
    local content_h = total*DD_ITEM_H + DD_V_PAD*2
    clamp_scroll(scroll, content_h, list_h)

    draw_shadow(list_pos, list_size, 5, 1)
    render.add_rect_filled(list_pos, list_pos:add(list_size), Library.MainColor, 5)
    render.add_rect(list_pos, list_pos:add(list_size), apply_alpha(Library.AccentColor, 0.25), 5, 1)

    if needs_sb then
        local sb_x = list_pos.x + list_w - SB_WIDTH - 2
        draw_scrollbar(vector2(sb_x, list_pos.y+DD_V_PAD), list_h-DD_V_PAD*2, content_h, list_h, scroll, 1, mpressed, mdown, mp)
    end

    local clip_top = list_pos.y + DD_V_PAD
    local clip_bot = list_pos.y + list_h - DD_V_PAD
    for i, value in ipairs(e.Values) do
        local item_y   = list_pos.y + DD_V_PAD + (i-1)*DD_ITEM_H - scroll.offset
        local item_pos = vector2(list_pos.x+1, item_y)
        local item_sz  = vector2(list_w-2-(needs_sb and (SB_WIDTH+SB_PAD) or 0), DD_ITEM_H)
        if item_y+DD_ITEM_H < clip_top or item_y > clip_bot then goto continue_dd end

        local is_sel = e.Multi and e.Value[value] or (e.Value==value)
        local is_hov = is_mouse_in_rect(item_pos, item_sz)
                       and item_y >= clip_top-DD_ITEM_H*0.5
                       and item_y+DD_ITEM_H <= clip_bot+DD_ITEM_H*0.5

        if is_sel then render.add_rect_filled(item_pos, item_pos:add(item_sz), apply_alpha(Library.AccentColor, 0.12), 3) end
        if is_hov then render.add_rect_filled(item_pos, item_pos:add(item_sz), apply_alpha(Library.AccentColor, 0.20), 3) end

        local tc = (is_sel or is_hov) and Library.AccentColor or Library.FontColor
        render.add_text(
            vector2(item_pos.x+DD_INNER_PAD, item_y+(DD_ITEM_H - render.get_text_size("A").y)*0.5),
            get_clipped_text(tostring(value), text_col_w), tc)

        if is_hov and mpressed then
            if e.Multi then e.Value[value]=not e.Value[value]; e:SetValue(e.Value)
            else e:SetValue(value); e.Open=false; Library.OpenedDropdown=nil end
        end
        ::continue_dd::
    end

    -- fringe mask + border redraw
    render.add_rect_filled(vector2(list_pos.x, list_pos.y-32), vector2(list_pos.x+list_w, list_pos.y+DD_V_PAD), Library.MainColor, 0)
    render.add_rect_filled(vector2(list_pos.x, list_pos.y+list_h-DD_V_PAD), vector2(list_pos.x+list_w, list_pos.y+list_h+32), Library.MainColor, 0)
    render.add_rect(list_pos, list_pos:add(list_size), apply_alpha(Library.AccentColor, 0.25), 5, 1)
end

-- ══════════════════════════════════════════════
--  MAIN RENDER HOOK
-- ══════════════════════════════════════════════
hook.add("render", "auth_photon_render", function()
    local anim = Library.Animation
    if anim.State == "FadingOut" then
        anim.CurrentAlpha = anim.CurrentAlpha - anim.Speed
        if anim.CurrentAlpha <= 0 then
            anim.CurrentAlpha = 0
            if anim.PendingTab then anim.PendingTab.Parent.ActiveTab=anim.PendingTab; anim.PendingTab=nil end
            anim.State = "FadingIn"
        end
    elseif anim.State == "FadingIn" then
        anim.CurrentAlpha = anim.CurrentAlpha + anim.Speed
        if anim.CurrentAlpha >= 1 then anim.CurrentAlpha=1; anim.State="Idle" end
    end

    Library.Hue = (Library.Hue + 0.002) % 1
    Library.CurrentRainbowColor = hsv_to_rgb(Library.Hue, 0.8, 1)

    local accent   = Library.AccentColor
    local mp       = input.get_mouse_position()
    local mpressed = input.is_key_pressed(0x01)
    local mdown    = input.key_down(0x01)

    Library.ModalOpen = Library.OpenedDropdown or Library.ActiveColorPicker or Library.ActiveKeyPicker or Library.ActiveInput or Library.RightClickMenu

    -- scrollbar drag release
    if Library.ActiveScrollbar and not mdown then
        Library.ActiveScrollbar.dragging=false; Library.ActiveScrollbar=nil
    end
    -- scrollbar drag update
    if Library.ActiveScrollbar and mdown then
        local s = Library.ActiveScrollbar
        if s._track_h and s._track_h > 0 then
            local max_off    = math.max(0, s._content_h-s._visible_h)
            local ratio      = s._visible_h/s._content_h
            local thumb_h    = math.max(SB_MIN_THUMB, math.floor(s._track_h*ratio))
            local thumb_travel = s._track_h - thumb_h
            if thumb_travel > 0 then
                local delta = mp.y - s.drag_start_y
                s.offset = s.drag_start_off + delta*(max_off/thumb_travel)
                clamp_scroll(s, s._content_h, s._visible_h)
            end
        end
    end

    -- dismiss modals on outside click
    if mpressed and Library.ModalOpen then
        if Library.OpenedDropdown then
            local dd = Library.OpenedDropdown
            local lay = dd._dd_layout
            if lay then
                local in_ctrl = is_mouse_in_rect(lay.d_pos, lay.d_size)
                local in_list = lay.list_pos and is_mouse_in_rect(lay.list_pos, lay.list_size)
                if not in_ctrl and not in_list then dd.Open=false; Library.OpenedDropdown=nil end
            end
        end
        if Library.ActiveColorPicker then
            local acp = Library.ActiveColorPicker
            if not is_mouse_in_rect(acp.layout.picker_pos, acp.layout.picker_size) then
                acp.obj.Open=false; Library.ActiveColorPicker=nil
            end
        end
        if Library.ActiveKeyPicker then
            if not is_mouse_in_rect(Library.ActiveKeyPicker.layout.pos, Library.ActiveKeyPicker.layout.size) then
                Library.ActiveKeyPicker.obj.Picking=false; Library.ActiveKeyPicker=nil
            end
        end
        if Library.ActiveInput then
            if not is_mouse_in_rect(Library.ActiveInput.layout.pos, Library.ActiveInput.layout.size) then
                Library.ActiveInput=nil
            end
        end
    end
    if mpressed and Library.RightClickMenu then
        if not is_mouse_in_rect(Library.RightClickMenu.pos, vector2(110, 3*22+8)) then
            Library.RightClickMenu=nil
        end
    end

    -- window drag
    if Library.DraggingWindow then
        if mdown then Library.DraggingWindow.Pos=mp:subtract(Library.DragOffset)
        else Library.DraggingWindow=nil end
    end
    -- slider drag
    if Library.ActiveSlider then
        if mdown then
            local s,l = Library.ActiveSlider.obj, Library.ActiveSlider.layout
            local r = (math.clamp(mp.x, l.pos.x, l.pos.x+l.size.x) - l.pos.x) / l.size.x
            s:SetValue(s.Min + (s.Max-s.Min)*r)
        else Library.ActiveSlider=nil end
    end
    -- colour picker drag
    if Library.ActiveColorPicker and mdown then
        local cp  = Library.ActiveColorPicker.obj
        local lay = Library.ActiveColorPicker.layout
        if is_mouse_in_rect(lay.sv_pos, lay.sv_size) then
            cp.Saturation = math.clamp((mp.x-lay.sv_pos.x)/lay.sv_size.x, 0, 1)
            cp.ValueHSV   = 1-math.clamp((mp.y-lay.sv_pos.y)/lay.sv_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        elseif lay.hue_pos and is_mouse_in_rect(lay.hue_pos, lay.hue_size) then
            cp.Hue = math.clamp((mp.y-lay.hue_pos.y)/lay.hue_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        elseif cp.EnableAlpha and lay.alpha_pos and is_mouse_in_rect(lay.alpha_pos, lay.alpha_size) then
            cp.Alpha = math.clamp((mp.y-lay.alpha_pos.y)/lay.alpha_size.y, 0, 1)
            cp:SetValue(hsv_to_rgb(cp.Hue, cp.Saturation, cp.ValueHSV, cp.Alpha))
        end
    end
    -- watermark drag
    local ts_wm  = render.get_text_size(Library.Watermark.Text)
    local wm_size = vector2(ts_wm.x+14, 22)
    if not Library.DraggingWatermark and mpressed and is_mouse_in_rect(Library.Watermark.Pos, wm_size) then
        Library.DraggingWatermark=true; Library.DragOffset=mp:subtract(Library.Watermark.Pos)
    end
    if Library.DraggingWatermark then
        if mdown then Library.Watermark.Pos=mp:subtract(Library.DragOffset)
        else Library.DraggingWatermark=false end
    end

    local can_interact = not Library.ModalOpen and anim.State=="Idle"
    Library.Tooltip = nil

    -- ──────────────────────────────────────────
    --  Windows
    -- ──────────────────────────────────────────
    for win_idx, window in ipairs(Library.Windows) do
        if window.Visible then
            window.Alpha = window.Alpha + (window.TargetAlpha - window.Alpha) * 0.07
            local wa = window.Alpha
            if wa < 0.01 then goto continue_window end

            if not window.TabScrollId then window.TabScrollId="win_tab_"..tostring(win_idx) end

            local tbpos  = window.Pos
            local tbsize = vector2(window.Size.x, 30)
            if not Library.DraggingWindow and mpressed and is_mouse_in_rect(tbpos, tbsize) and not Library.ModalOpen then
                Library.DraggingWindow=window; Library.DragOffset=mp:subtract(window.Pos)
            end

            draw_shadow(window.Pos, window.Size, 10, wa)
            render.add_rect_filled(window.Pos, window.Pos:add(window.Size), apply_alpha(Library.BackgroundColor, wa), 8)
            render.add_rect(window.Pos, window.Pos:add(window.Size), apply_alpha(Library.OutlineColor, wa), 8, 1)

            -- Title bar
            render.add_text(window.Pos:add(vector2(12, 8)), window.Title, apply_alpha(Library.FontColor, wa))

            local msp = window.Pos:add(vector2(10, 30))
            local mss = vector2(window.Size.x-20, window.Size.y-40)
            render.add_rect_filled(msp, msp:add(mss), apply_alpha(Library.BackgroundColor, wa), 6)

            -- ── Tab bar  (REDESIGNED)
            -- inactive = dim filled pill   active = no fill + 2px accent underline
            local tab_area = msp:add(vector2(4, 4))
            local tab_x = 0
            for _, tab in ipairs(window.Tabs) do
                local tw   = render.get_text_size(tab.Name).x + 18
                local tp2  = tab_area:add(vector2(tab_x, 0))
                local ts2  = vector2(tw, 22)
                local active_target = anim.PendingTab or window.ActiveTab
                local is_active = (active_target == tab)

                if not is_active then
                    -- inactive: very subtle fill, secondary text
                    render.add_rect_filled(tp2, tp2:add(ts2), apply_alpha(color(0.09,0.09,0.11,1), wa), 5)
                    render.add_text(tp2:add(vector2(9, 4)), tab.Name, apply_alpha(Library.SecondaryFontColor, wa))
                else
                    -- active: primary text + accent underline (no background fill)
                    render.add_text(tp2:add(vector2(9, 4)), tab.Name, apply_alpha(Library.FontColor, wa))
                    render.add_rect_filled(
                        tp2:add(vector2(4, ts2.y-2)),
                        tp2:add(vector2(ts2.x-4, ts2.y)),
                        apply_alpha(accent, wa), 1)
                end

                if not Library.DraggingWindow and mpressed and is_mouse_in_rect(tp2, ts2) and anim.State=="Idle" and window.ActiveTab~=tab then
                    anim.State="FadingOut"; anim.PendingTab=tab
                end
                tab_x = tab_x + tw + 4
            end

            -- ── Tab content
            local tab_cont_pos  = msp:add(vector2(0, 30))
            local tab_cont_size = vector2(window.Size.x-20, mss.y-30)

            if window.ActiveTab and anim.CurrentAlpha > 0 then
                local op = anim.CurrentAlpha * wa

                -- measure tab content height
                local left_h, right_h = 0, 0
                for _, gb in ipairs(window.ActiveTab.Groupboxes) do
                    if gb:IsVisible() then
                        local raw_h = 28
                        for _, e in ipairs(gb.Elements) do raw_h=raw_h+e.Height end
                        local used_h = gb.MaxHeight and math.min(raw_h, gb.MaxHeight) or raw_h
                        if gb.Side=="Left" then left_h=left_h+used_h+10 else right_h=right_h+used_h+10 end
                    end
                end
                local tab_content_h = math.max(left_h, right_h)
                local tab_needs_sb  = tab_content_h > tab_cont_size.y

                local tab_scroll = get_scroll_state(window.TabScrollId)
                clamp_scroll(tab_scroll, tab_content_h, tab_cont_size.y)

                if tab_needs_sb then
                    local sb_pos = tab_cont_pos:add(vector2(tab_cont_size.x-SB_WIDTH, 4))
                    draw_scrollbar(sb_pos, tab_cont_size.y-8, tab_content_h, tab_cont_size.y, tab_scroll, op, mpressed, mdown, mp)
                end

                local inner_w = tab_cont_size.x - (tab_needs_sb and (SB_WIDTH+SB_PAD) or 0) - 8
                local origin  = tab_cont_pos:add(vector2(4, 4-tab_scroll.offset))
                local left_y, right_y = 0, 0

                for gb_idx, gb in ipairs(window.ActiveTab.Groupboxes) do
                    if gb:IsVisible() then
                        if not gb._scroll_id then gb._scroll_id="gb_"..tostring(win_idx).."_"..tostring(gb_idx) end

                        local side_off = gb.Side=="Left" and 0 or (inner_w/2+2)
                        local y_off    = gb.Side=="Left" and left_y or right_y
                        local gpos     = origin:add(vector2(side_off, y_off))

                        local raw_h = 28
                        for _, e in ipairs(gb.Elements) do raw_h=raw_h+e.Height end

                        local gb_vis_h    = gb.MaxHeight and math.min(raw_h, gb.MaxHeight) or raw_h
                        local gb_size     = vector2(inner_w/2-6, gb_vis_h)
                        local gb_needs_sb = gb.MaxHeight ~= nil and raw_h > gb_vis_h

                        local gb_scroll = gb_needs_sb and get_scroll_state(gb._scroll_id) or {offset=0}
                        if gb_needs_sb then clamp_scroll(gb_scroll, raw_h, gb_vis_h) end

                        -- Groupbox background
                        draw_shadow(gpos, gb_size, 6, op*0.45)
                        render.add_rect_filled(gpos, gpos:add(gb_size), apply_alpha(Library.MainColor, op), 6)

                        -- ★ Accent left bar (2px) — visual anchor replacing floating title
                        render.add_rect_filled(
                            gpos:add(vector2(0, 6)),
                            gpos:add(vector2(2, gb_size.y-6)),
                            apply_alpha(accent, op*0.7), 1)

                        -- Header strip: thin separator line under title
                        render.add_text(gpos:add(vector2(9, 6)), gb.Name, apply_alpha(Library.FontColor, op))
                        render.add_line(
                            gpos:add(vector2(9, 20)),
                            gpos:add(vector2(gb_size.x-9, 20)),
                            apply_alpha(color(0.13,0.13,0.16,1), op), 1)

                        if gb_needs_sb then
                            local sb_pos = gpos:add(vector2(gb_size.x-SB_WIDTH-2, 26))
                            local sb_h   = gb_vis_h - 30
                            gb_scroll._track_h=sb_h; gb_scroll._content_h=raw_h; gb_scroll._visible_h=gb_vis_h
                            draw_scrollbar(sb_pos, sb_h, raw_h, gb_vis_h, gb_scroll, op, mpressed, mdown, mp)
                        end

                        local efw_w   = gb_size.x - 18 - (gb_needs_sb and (SB_WIDTH+SB_PAD) or 0)
                        local elem_y  = 24 - gb_scroll.offset   -- tighter: 24 vs 30

                        for _, element in ipairs(gb.Elements) do
                            local ep  = gpos:add(vector2(9, elem_y))
                            local efw = vector2(efw_w, element.Height)

                            local is_clipped = false
                            if gb_needs_sb then
                                local clip_top = gpos.y + 22
                                local clip_bot = gpos.y + gb_vis_h - 2
                                is_clipped = (ep.y+element.Height < clip_top) or (ep.y > clip_bot)
                            end

                            if not is_clipped then
                                if is_mouse_in_rect(ep, efw) and element.Tooltip then
                                    Library.Tooltip={Text=element.Tooltip, Element=element}
                                end

                                -- ── Toggle ──
                                if element.Type=="Toggle" then
                                    local tgt = element.Value and 1 or 0
                                    element.SwitchAnim = element.SwitchAnim + (tgt-element.SwitchAnim)*0.08
                                    local is_hov = is_mouse_in_rect(ep, efw)
                                    element.HoverAlpha = element.HoverAlpha + ((is_hov and 1 or 0)-element.HoverAlpha)*0.08
                                    -- row hover tint
                                    if element.HoverAlpha > 0.01 then
                                        render.add_rect_filled(ep:subtract(vector2(0,2)), ep:add(vector2(efw_w, element.Height)),
                                            apply_alpha(accent, 0.06*element.HoverAlpha*op), 3)
                                    end
                                    -- switch track  (26x14 — compact)
                                    local sw_sz  = vector2(26, 14)
                                    local sw_pos = ep:add(vector2(0, 4))
                                    local base_bg = color(0.08,0.08,0.10,1)
                                    local fill_bg = color(
                                        lerp(base_bg.r, accent.r, element.SwitchAnim),
                                        lerp(base_bg.g, accent.g, element.SwitchAnim),
                                        lerp(base_bg.b, accent.b, element.SwitchAnim), 1)
                                    render.add_rect_filled(sw_pos, sw_pos:add(sw_sz), apply_alpha(fill_bg, op), 7)
                                    local knob_x = lerp(sw_pos.x+2, sw_pos.x+sw_sz.x-11, element.SwitchAnim)
                                    local knob_c = color(
                                        lerp(0.48, Library.BackgroundColor.r, element.SwitchAnim),
                                        lerp(0.48, Library.BackgroundColor.g, element.SwitchAnim),
                                        lerp(0.52, Library.BackgroundColor.b, element.SwitchAnim), 1)
                                    render.add_rect_filled(vector2(knob_x, sw_pos.y+2), vector2(knob_x+9, sw_pos.y+12), apply_alpha(knob_c, op), 5)
                                    render.add_text(ep:add(vector2(33,3)), element.Text,
                                        element.Risky and apply_alpha(Library.RiskColor,op) or apply_alpha(Library.FontColor,op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(ep, vector2(160,16)) and can_interact then
                                        element:SetValue(not element.Value)
                                    end

                                -- ── Slider ──
                                elseif element.Type=="Slider" then
                                    local ratio = (element.Value-element.Min)/(element.Max-element.Min)
                                    element.ThumbAnim = element.ThumbAnim + (ratio-element.ThumbAnim)*0.09
                                    local s_pos  = ep:add(vector2(0, 16))
                                    local s_size = vector2(efw_w, 12)
                                    local thumb_x = s_pos.x + s_size.x*element.ThumbAnim
                                    local is_hov = is_mouse_in_rect(s_pos, s_size)
                                    local is_drag = Library.ActiveSlider and Library.ActiveSlider.obj==element
                                    element.HoverAlpha = element.HoverAlpha + (((is_hov or is_drag) and 1 or 0)-element.HoverAlpha)*0.09
                                    element.BubbleAlpha = element.HoverAlpha

                                    -- Label left, value right (monospaced-width field)
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local val_str = tostring(element.Value)..element.Suffix
                                    local val_w   = render.get_text_size(val_str).x
                                    render.add_text(ep:add(vector2(efw_w-val_w, 0)), val_str, apply_alpha(accent, op))

                                    -- Track: MainColor (visible against BackgroundColor)
                                    render.add_rect_filled(s_pos, s_pos:add(s_size), apply_alpha(Library.MainColor, op), 6)
                                    -- Fill
                                    if element.ThumbAnim > 0.001 then
                                        local fw = math.max(0, s_size.x*element.ThumbAnim-2)
                                        render.add_rect_filled(s_pos:add(vector2(1,1)), s_pos:add(vector2(1+fw, s_size.y-1)), apply_alpha(accent, op*0.85), 5)
                                    end
                                    -- Thumb handle
                                    local th_pos = vector2(thumb_x-3, s_pos.y-2)
                                    render.add_rect_filled(th_pos, th_pos:add(vector2(6, s_size.y+4)), apply_alpha(Library.FontColor, op), 3)
                                    -- Bubble (hover value label above thumb)
                                    if element.BubbleAlpha > 0.01 then
                                        local bub_w   = render.get_text_size(val_str).x + 8
                                        local bub_pos = vector2(thumb_x-bub_w/2, s_pos.y-18)
                                        local bub_a   = element.BubbleAlpha * op
                                        render.add_rect_filled(bub_pos, bub_pos:add(vector2(bub_w,14)), apply_alpha(Library.MainColor, bub_a), 3)
                                        render.add_rect(bub_pos, bub_pos:add(vector2(bub_w,14)), apply_alpha(accent, bub_a*0.4), 3, 1)
                                        render.add_text(bub_pos:add(vector2(4,1)), val_str, apply_alpha(Library.FontColor, bub_a))
                                    end
                                    if not Library.DraggingWindow and not Library.ActiveSlider and mpressed and is_mouse_in_rect(s_pos, s_size) and can_interact then
                                        Library.ActiveSlider={obj=element, layout={pos=s_pos, size=s_size}}
                                    end

                                -- ── Button ──
                                elseif element.Type=="Button" then
                                    local b_pos  = ep
                                    local b_size = vector2(efw_w, 20)
                                    local is_hov = is_mouse_in_rect(b_pos, b_size)
                                    element.HoverAnim = element.HoverAnim + ((is_hov and 1 or 0)-element.HoverAnim)*0.08
                                    local ha = element.HoverAnim
                                    -- hover: accent tint instead of full invert
                                    local bg = color(
                                        lerp(Library.BackgroundColor.r, accent.r*0.18+Library.BackgroundColor.r*0.82, ha),
                                        lerp(Library.BackgroundColor.g, accent.g*0.18+Library.BackgroundColor.g*0.82, ha),
                                        lerp(Library.BackgroundColor.b, accent.b*0.18+Library.BackgroundColor.b*0.82, ha), 1)
                                    render.add_rect_filled(b_pos, b_pos:add(b_size), apply_alpha(bg, op), 5)
                                    -- 1px accent border always visible
                                    render.add_rect(b_pos, b_pos:add(b_size), apply_alpha(color(accent.r,accent.g,accent.b,0.30+ha*0.45), op), 5, 1)
                                    local btn_text = element.Text
                                    if element.DoubleClick and get_unixtime()-element.LastClick<1 and element.LastClick~=0 then btn_text="Confirm?" end
                                    local clip = get_clipped_text(btn_text, b_size.x-10)
                                    render.add_text(b_pos:add(vector2(b_size.x/2 - render.get_text_size(clip).x/2, 3)), clip, apply_alpha(Library.FontColor, op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(b_pos, b_size) and can_interact then
                                        if element.DoubleClick then
                                            if get_unixtime()-element.LastClick < 1 then
                                                if element.Func then element.Func() end; element.LastClick=0
                                            else element.LastClick=get_unixtime() end
                                        else
                                            if element.Func then element.Func() end
                                        end
                                    end

                                -- ── Dropdown ──
                                elseif element.Type=="Dropdown" then
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local d_pos  = ep:add(vector2(0, 16))
                                    local d_size = vector2(efw_w, 18)
                                    if not element._dd_layout then element._dd_layout={} end
                                    element._dd_layout.d_pos  = d_pos
                                    element._dd_layout.d_size = d_size
                                    element._dd_layout.list_pos  = element._dd_layout.list_pos  or vector2(0,0)
                                    element._dd_layout.list_size = element._dd_layout.list_size or vector2(0,0)

                                    local is_hov = is_mouse_in_rect(d_pos, d_size)
                                    element.HoverAlpha = element.HoverAlpha + ((is_hov and 1 or 0)-element.HoverAlpha)*0.08
                                    local bg = color(
                                        lerp(Library.BackgroundColor.r, Library.MainColor.r, element.HoverAlpha),
                                        lerp(Library.BackgroundColor.g, Library.MainColor.g, element.HoverAlpha),
                                        lerp(Library.BackgroundColor.b, Library.MainColor.b, element.HoverAlpha), 1)
                                    render.add_rect_filled(d_pos, d_pos:add(d_size), apply_alpha(bg, op), 4)
                                    render.add_rect(d_pos, d_pos:add(d_size), apply_alpha(color(accent.r,accent.g,accent.b,0.28), op), 4, 1)

                                    local display_text
                                    if element.Multi then
                                        local sel={}; for k,v in pairs(element.Value) do if v then table.insert(sel,k) end end
                                        display_text = #sel>0 and table.concat(sel,", ") or "None"
                                    else display_text = tostring(element.Value or "") end
                                    render.add_text(d_pos:add(vector2(7,2)), get_clipped_text(display_text, d_size.x-22), apply_alpha(Library.FontColor, op))
                                    render.add_triangle_filled(
                                        d_pos:add(vector2(d_size.x-11,6)), d_pos:add(vector2(d_size.x-4,6)), d_pos:add(vector2(d_size.x-7.5,12)),
                                        apply_alpha(Library.SecondaryFontColor, op))

                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(d_pos, d_size) and can_interact then
                                        element.Open = not element.Open
                                        Library.OpenedDropdown = element.Open and element or nil
                                    end

                                -- ── Input ──
                                elseif element.Type=="Input" then
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local i_pos  = ep:add(vector2(0, 16))
                                    local i_size = vector2(efw_w, 18)
                                    element.layout = {pos=i_pos, size=i_size}
                                    local is_active = Library.ActiveInput==element
                                    render.add_rect_filled(i_pos, i_pos:add(i_size), apply_alpha(Library.BackgroundColor, op), 4)
                                    -- active: accent border; inactive: subtle accent tint
                                    render.add_rect(i_pos, i_pos:add(i_size),
                                        is_active and apply_alpha(accent, op)
                                        or apply_alpha(color(accent.r,accent.g,accent.b,0.22), op), 4, 1)
                                    local d_text = #element.Value>0 and element.Value or element.Placeholder
                                    local tc = #element.Value>0 and Library.FontColor or color(0.30,0.30,0.38,1)
                                    render.add_text(i_pos:add(vector2(7,2)), get_clipped_text(d_text, i_size.x-12), apply_alpha(tc, op))
                                    if is_active and (math.floor(get_unixtime()*2)%2==0) then
                                        local tw2 = render.get_text_size(get_clipped_text(element.Value, i_size.x-12)).x
                                        render.add_line(i_pos:add(vector2(7+tw2,3)), i_pos:add(vector2(7+tw2,i_size.y-3)), apply_alpha(Library.FontColor, op), 1)
                                    end
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(i_pos, i_size) and can_interact then
                                        Library.ActiveInput=element
                                    end

                                -- ── KeyPicker ──
                                elseif element.Type=="KeyPicker" then
                                    render.add_text(ep, element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    local k_pos  = ep:add(vector2(0, 16))
                                    local k_size = vector2(efw_w, 18)
                                    element.layout = {pos=k_pos, size=k_size}
                                    render.add_rect_filled(k_pos, k_pos:add(k_size), apply_alpha(Library.BackgroundColor, op), 4)
                                    render.add_rect(k_pos, k_pos:add(k_size),
                                        element.Picking and apply_alpha(accent, op)
                                        or apply_alpha(color(accent.r,accent.g,accent.b,0.22), op), 4, 1)
                                    local mode_tag = element.Mode=="Hold" and " [H]" or (element.Mode=="Toggle" and " [T]" or "")
                                    local ktext = element.Picking and "press a key..." or (element.Value..mode_tag)
                                    render.add_text(k_pos:add(vector2(k_size.x/2-render.get_text_size(ktext).x/2, 2)), ktext, apply_alpha(Library.FontColor, op))
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(k_pos, k_size) and can_interact then
                                        element.Picking=true; Library.ActiveKeyPicker={obj=element, layout=element.layout}
                                    end
                                    if not Library.DraggingWindow and input.is_key_pressed(0x02) and is_mouse_in_rect(k_pos, k_size) and can_interact then
                                        Library.RightClickMenu={obj=element, pos=mp, Alpha=0}
                                    end

                                -- ── ColorPicker ──
                                elseif element.Type=="ColorPicker" then
                                    local box_sz = vector2(16, 12)
                                    local box_pos = ep:add(vector2(efw_w-box_sz.x, 4))
                                    element.layout.pos=box_pos; element.layout.size=box_sz
                                    render.add_text(ep:add(vector2(0,3)), element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                    if element.EnableAlpha then draw_checkerboard(box_pos:add(vector2(1,1)), box_sz:subtract(vector2(2,2)), 3) end
                                    render.add_rect_filled(box_pos:add(vector2(1,1)), box_pos:add(box_sz):subtract(vector2(1,1)), apply_alpha(element.Value,op), 3)
                                    render.add_rect(box_pos, box_pos:add(box_sz), apply_alpha(color(accent.r,accent.g,accent.b,0.35), op), 3, 1)
                                    if not Library.DraggingWindow and mpressed and is_mouse_in_rect(box_pos, box_sz) and can_interact then
                                        element.Open=not element.Open
                                        Library.ActiveColorPicker = element.Open and {obj=element, layout=element.layout} or nil
                                    end

                                -- ── Divider ──
                                elseif element.Type=="Divider" then
                                    local dy = ep.y + element.Height/2
                                    render.add_line(vector2(ep.x,dy), vector2(ep.x+efw_w,dy), apply_alpha(color(0.13,0.13,0.16,1), op), 1)

                                -- ── Label ──
                                elseif element.Type=="Label" then
                                    render.add_text(ep:add(vector2(0,3)), element.Text, apply_alpha(Library.SecondaryFontColor, op))
                                end
                            end -- not is_clipped

                            elem_y = elem_y + element.Height
                        end -- elements loop

                        if gb_needs_sb then
                            apply_clip_mask(gpos:add(vector2(0,22)), vector2(gb_size.x, gb_vis_h-22), Library.MainColor, op)
                            render.add_rect(gpos, gpos:add(gb_size), apply_alpha(Library.OutlineColor, op), 6, 1)
                            render.add_text(gpos:add(vector2(9,6)), gb.Name, apply_alpha(Library.FontColor, op))
                        end

                        local used_h = gb.MaxHeight and math.min(raw_h, gb.MaxHeight) or raw_h
                        if gb.Side=="Left" then left_y=left_y+used_h+10 else right_y=right_y+used_h+10 end
                    end
                end -- groupboxes

                if tab_needs_sb then
                    apply_clip_mask(tab_cont_pos:add(vector2(0,4)), vector2(tab_cont_size.x, tab_cont_size.y-4), Library.BackgroundColor, wa)
                    render.add_rect(window.Pos, window.Pos:add(window.Size), apply_alpha(Library.OutlineColor, wa), 8, 1)
                end
            end
        end
        ::continue_window::
    end

    -- ── Dropdown list (above everything)
    if Library.OpenedDropdown then
        draw_dropdown_list(Library.OpenedDropdown, mpressed, mdown, mp)
    end

    -- ── Colour picker panel (unchanged logic, compact sizing)
    if Library.ActiveColorPicker then
        local e      = Library.ActiveColorPicker.obj
        local pad    = 7
        local sv_dim = 128
        local bar_w  = 10
        local bar_gap= 5
        local bars_x = pad + sv_dim + pad
        local num_bars = e.EnableAlpha and 2 or 1
        local p_w = bars_x + bar_w*num_bars + bar_gap*(num_bars-1) + pad
        local p_h = pad + sv_dim + pad
        local p_size = vector2(p_w, p_h)

        local scr   = get_screen_size()
        local p_pos = e.layout.pos:add(vector2(e.layout.size.x+8, 0))
        if p_pos.x+p_w > scr.x-4 then p_pos=vector2(e.layout.pos.x-p_w-8, p_pos.y) end
        if p_pos.y+p_h > scr.y-4 then p_pos=vector2(p_pos.x, scr.y-p_h-4) end
        e.layout.picker_pos=p_pos; e.layout.picker_size=p_size

        draw_shadow(p_pos, p_size, 7, 1)
        render.add_rect_filled(p_pos, p_pos:add(p_size), Library.MainColor, 7)
        render.add_rect(p_pos, p_pos:add(p_size), apply_alpha(accent, 0.28), 7, 1)

        local sv_pos  = p_pos:add(vector2(pad, pad))
        local sv_size = vector2(sv_dim, sv_dim)
        e.layout.sv_pos=sv_pos; e.layout.sv_size=sv_size

        local ahr = hsv_to_rgb(e.Hue, 1, 1)
        render.add_rect_filled(sv_pos, sv_pos:add(sv_size), color(1,1,1,1), 0)
        for i=0,sv_size.x-1 do render.add_line(sv_pos:add(vector2(i,0)), sv_pos:add(vector2(i,sv_size.y)), color(ahr.r,ahr.g,ahr.b, i/sv_size.x), 1) end
        for i=0,sv_size.y-1 do render.add_line(sv_pos:add(vector2(0,i)), sv_pos:add(vector2(sv_size.x,i)), color(0,0,0, i/sv_size.y), 1) end
        render.add_rect(sv_pos, sv_pos:add(sv_size), Library.OutlineColor, 0, 1)
        local cx = sv_pos.x + sv_size.x*e.Saturation
        local cy = sv_pos.y + sv_size.y*(1-e.ValueHSV)
        render.add_circle(vector2(cx,cy), 4, e.ValueHSV>0.5 and color(0,0,0,1) or color(1,1,1,1), 1)

        local hue_pos  = p_pos:add(vector2(bars_x, pad))
        local hue_size = vector2(bar_w, sv_dim)
        e.layout.hue_pos=hue_pos; e.layout.hue_size=hue_size
        for i=0,hue_size.y-1 do render.add_line(hue_pos:add(vector2(0,i)), hue_pos:add(vector2(hue_size.x,i)), hsv_to_rgb(i/hue_size.y,1,1), 1) end
        render.add_rect(hue_pos, hue_pos:add(hue_size), Library.OutlineColor, 0, 1)
        local hcy = hue_pos.y + hue_size.y*e.Hue
        render.add_rect(vector2(hue_pos.x-2,hcy-2), vector2(hue_pos.x+hue_size.x+2,hcy+2), color(1,1,1,1), 2, 1)

        if e.EnableAlpha then
            local a_pos  = p_pos:add(vector2(bars_x+bar_w+bar_gap, pad))
            local a_size = vector2(bar_w, sv_dim)
            e.layout.alpha_pos=a_pos; e.layout.alpha_size=a_size
            draw_checkerboard(a_pos, a_size, 4)
            local rop = hsv_to_rgb(e.Hue, e.Saturation, e.ValueHSV)
            for i=0,a_size.y-1 do render.add_line(a_pos:add(vector2(0,i)), a_pos:add(vector2(a_size.x,i)), color(rop.r,rop.g,rop.b, i/a_size.y), 1) end
            render.add_rect(a_pos, a_pos:add(a_size), Library.OutlineColor, 0, 1)
            local acy = a_pos.y + a_size.y*e.Alpha
            render.add_rect(vector2(a_pos.x-2,acy-2), vector2(a_pos.x+a_size.x+2,acy+2), color(1,1,1,1), 2, 1)
        end
    end

    -- ── Right-click menu (KeyPicker mode)
    if Library.RightClickMenu then
        local rcm     = Library.RightClickMenu
        local options = {"Always","Hold","Toggle"}
        local item_h  = 22
        local pad     = 4
        local rcm_w   = 100
        local rcm_h   = #options*item_h + pad*2
        local rcm_sz  = vector2(rcm_w, rcm_h)
        local scr     = get_screen_size()
        local rp      = vector2(math.min(rcm.pos.x, scr.x-rcm_w-4), math.min(rcm.pos.y, scr.y-rcm_h-4))
        rcm.Alpha = rcm.Alpha + (1-rcm.Alpha)*0.14
        draw_shadow(rp, rcm_sz, 6, rcm.Alpha)
        render.add_rect_filled(rp, rp:add(rcm_sz), apply_alpha(Library.MainColor, rcm.Alpha), 6)
        render.add_rect(rp, rp:add(rcm_sz), apply_alpha(color(accent.r,accent.g,accent.b,0.30), rcm.Alpha), 6, 1)
        for i, opt in ipairs(options) do
            local ip  = rp:add(vector2(pad, pad+(i-1)*item_h))
            local isz = vector2(rcm_w-pad*2, item_h)
            local is_sel = (rcm.obj.Mode==opt) or (opt=="Always" and not rcm.obj.Mode)
            local is_hov = is_mouse_in_rect(ip, isz)
            if is_sel then render.add_rect_filled(ip, ip:add(isz), apply_alpha(accent, 0.14*rcm.Alpha), 3) end
            if is_hov then render.add_rect_filled(ip, ip:add(isz), apply_alpha(accent, 0.20*rcm.Alpha), 3) end
            local tc = (is_sel or is_hov) and apply_alpha(accent, rcm.Alpha) or apply_alpha(Library.FontColor, rcm.Alpha*0.65)
            render.add_text(ip:add(vector2(7,3)), opt, tc)
            if mpressed and is_hov then rcm.obj.Mode = (opt=="Always") and nil or opt; Library.RightClickMenu=nil end
        end
    end

    -- ── Notifications  (faster lerp 0.16, 3px left pip)
    local scr_w, scr_h = get_screen_size().x, get_screen_size().y
    local nx, ny, vdir = 20, 50, 1
    if     Library.NotificationPosition=="Top Right"    then nx=scr_w-280; ny=50
    elseif Library.NotificationPosition=="Top Left"     then nx=20;         ny=50
    elseif Library.NotificationPosition=="Bottom Right" then nx=scr_w-280; ny=scr_h-56; vdir=-1
    elseif Library.NotificationPosition=="Bottom Left"  then nx=20;         ny=scr_h-56; vdir=-1 end

    local run_y = 0
    for i = #Library.Notifications, 1, -1 do
        local n = Library.Notifications[i]
        local t = get_unixtime()-n.StartTime
        if t > n.Duration then n.TargetAlpha=0; n.TargetOffsetX=28 end
        n.Alpha   = n.Alpha   + (n.TargetAlpha   - n.Alpha)   * 0.08
        n.OffsetX = n.OffsetX + (n.TargetOffsetX - n.OffsetX) * 0.16  -- faster slide
        if n.TargetAlpha==0 and n.Alpha<0.01 then
            table.remove(Library.Notifications, i)
        else
            local nsz   = vector2(render.get_text_size(n.Text).x+18, 24)
            local cur_y = ny + vdir*run_y
            if vdir==-1 then cur_y=cur_y-nsz.y end
            local slide_sign = (Library.NotificationPosition=="Top Right" or Library.NotificationPosition=="Bottom Right") and 1 or -1
            local np = vector2(nx + slide_sign*n.OffsetX, cur_y)
            draw_shadow(np, nsz, 5, n.Alpha)
            render.add_rect_filled(np, np:add(nsz), color(Library.MainColor.r,Library.MainColor.g,Library.MainColor.b,n.Alpha), 5)
            -- ★ 3px left accent pip (matches groupbox + watermark language)
            render.add_rect_filled(np:add(vector2(0,3)), np:add(vector2(3,nsz.y-3)), color(accent.r,accent.g,accent.b,n.Alpha), 2)
            render.add_text(np:add(vector2(9,4)), n.Text, color(Library.FontColor.r,Library.FontColor.g,Library.FontColor.b,n.Alpha))
            run_y = run_y + nsz.y + 5
        end
    end

    draw_watermark()
    local tt_tgt = (Library.Tooltip ~= nil) and 1 or 0
    Library.TooltipAlpha = Library.TooltipAlpha + (tt_tgt-Library.TooltipAlpha)*0.13  -- faster
    if anim.State=="Idle" then render_tooltip(Library.TooltipAlpha) end
end)

