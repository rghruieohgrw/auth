-- COLOUR PICKER
-- ============================================================================
function Library:ToggleColourPicker(button_pos, button_size, target_colour)
    local ui = self.ColourPickerUI
    ui.pos = button_pos + vector2(button_size.x + 10, -50)
    ui.current_colour = target_colour
    ui.hue, ui.saturation, ui.value = rgb_to_hsv(target_colour)
    ui.alpha = target_colour.a or 1
    ui.hex_input = color_to_hex(target_colour)

    if ui.open then
        ui.anim_target = 0
        ui.open = false
    else
        ui.anim_target = 1
        ui.open = true
    end
end

function Library:DrawColourPicker()
    local ui = self.ColourPickerUI
    if ui.anim_alpha <= 0.01 and not ui.open then return end

    if ui.anim_alpha < ui.anim_target then
        ui.anim_alpha = math.min(ui.anim_alpha + ui.anim_speed, ui.anim_target)
    elseif ui.anim_alpha > ui.anim_target then
        ui.anim_alpha = math.max(ui.anim_alpha - ui.anim_speed, ui.anim_target)
    end

    local alpha_mult = ui.anim_alpha
    render.add_rect_filled(ui.pos, ui.pos + ui.size, color(0.15, 0.15, 0.18, alpha_mult), 10)

    -- Hue bar
    local spectrum_pos = ui.pos + vector2(10, 10)
    local spectrum_size = vector2(ui.size.x - 20, 20)
    for i = 0, 1, 0.02 do
        local grad_col = hsv_to_rgb(i, 1, 1, alpha_mult)
        render.add_rect_filled(
            spectrum_pos + vector2(spectrum_size.x * i, 0),
            spectrum_pos + vector2(spectrum_size.x * (i + 0.02), spectrum_size.y),
            grad_col
        )
    end

    -- SV square
    local sv_pos = ui.pos + vector2(10, 40)
    local sv_size = vector2(200, 130)
    for y = 0, 1, 0.05 do
        for x = 0, 1, 0.05 do
            local col = hsv_to_rgb(ui.hue, x, 1 - y, alpha_mult * 0.8)
            render.add_rect_filled(
                sv_pos + vector2(sv_size.x * x, sv_size.y * y),
                sv_pos + vector2(sv_size.x * (x + 0.05), sv_size.y * (y + 0.05)),
                col
            )
        end
    end

    -- Preview
    local preview_size = vector2(45, 45)
    local preview_pos = ui.pos + vector2(ui.size.x - preview_size.x - 10, 40)
    render.add_rect_filled(preview_pos, preview_pos + preview_size, ui.current_colour, 6)
    render.add_rect(preview_pos, preview_pos + preview_size, color(1, 1, 1, 0.3 * alpha_mult), 6, 1)

    -- Hex input
    local hex_pos = ui.pos + vector2(ui.size.x - 95, 100)
    local hex_size = vector2(80, 28)
    render.add_rect_filled(hex_pos, hex_pos + hex_size, color(0.08, 0.08, 0.1, alpha_mult), 4)
    render.add_rect(hex_pos, hex_pos + hex_size, color(1, 1, 1, 0.2 * alpha_mult), 4, 1)

    local display_text = ui.hex_input_active and ui.hex_input .. "|" or ui.hex_input
    render.add_text(hex_pos + vector2(8, 6), display_text, color(1, 1, 1, alpha_mult), 12)

    -- Info text
    local info_pos = ui.pos + vector2(10, 180)
    render.add_text(info_pos, string.format("H: %.0f°", ui.hue * 360), self.SecondaryFontColor, 11)
    render.add_text(info_pos + vector2(80, 0), string.format("S: %.0f%%", ui.saturation * 100), self.SecondaryFontColor, 11)
    render.add_text(info_pos + vector2(160, 0), string.format("V: %.0f%%", ui.value * 100), self.SecondaryFontColor, 11)
    render.add_text(info_pos + vector2(0, 16), string.format("R: %.0f G: %.0f B: %.0f",
        ui.current_colour.r * 255, ui.current_colour.g * 255, ui.current_colour.b * 255),
        self.SecondaryFontColor, 11)

    -- Mouse interaction
    local mouse = input.get_mouse_position()
    local hex_hover = mouse.x >= hex_pos.x and mouse.x <= hex_pos.x + hex_size.x and
                      mouse.y >= hex_pos.y and mouse.y <= hex_pos.y + hex_size.y
    if input.is_key_pressed(0x01) and hex_hover then
        ui.hex_input_active = true
    elseif input.is_key_pressed(0x01) then
        ui.hex_input_active = false
    end

    if ui.hex_input_active and input.key_down(0x0D) then
        local new_col = hex_to_color(ui.hex_input)
        if new_col then
            ui.current_colour = new_col
            ui.hue, ui.saturation, ui.value = rgb_to_hsv(new_col)
            ui.alpha = new_col.a or 1
        end
    end
end

-- ============================================================================
-- BRUSH BUTTON
-- ============================================================================
function Library:DrawBrushButton()
    if not self.Icons.loaded or not self.Icons.brush then
        self:LoadBrushIcon()
        return
    end

    local btn_pos = vector2(50, 50)
    local btn_size = vector2(36, 36)
    local mouse = input.get_mouse_position()
    local hover = mouse.x >= btn_pos.x and mouse.x <= btn_pos.x + btn_size.x and
                  mouse.y >= btn_pos.y and mouse.y <= btn_pos.y + btn_size.y

    local bg_col = hover and color(0.3, 0.3, 0.35, 1) or color(0.2, 0.2, 0.25, 1)
    render.add_rect_filled(btn_pos, btn_pos + btn_size, bg_col, 8)
    render.add_texture(self.Icons.brush, btn_pos, btn_pos + btn_size, 1.0)

    if self.ColourPickerUI.open then
        render.add_rect(btn_pos, btn_pos + btn_size, self.AccentColor, 8, 2)
    end

    if hover and input.is_key_pressed(0x01) then
        self:ToggleColourPicker(btn_pos, btn_size, self.ColourPickerUI.current_colour)
    end
end

